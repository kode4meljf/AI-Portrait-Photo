/* packageOrder/pages/frame-template/frame-template.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 140rpx;
}

/* 顶部预览区 */
.preview-section {
  background: #fff;
  margin: 30rpx 30rpx 20rpx;
  border-radius: 32rpx;
  padding: 24rpx 0 20rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}
.preview-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 0 30rpx 20rpx;
  border-bottom: 2rpx solid #f5f5f5;
}
.preview-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}
.photo-count {
  font-size: 24rpx;
  color: #999;
}
.preview-scroll {
  white-space: nowrap;
  padding: 20rpx 0 10rpx;
}
.preview-list {
  display: inline-flex;
  padding: 0 30rpx;
  gap: 20rpx;
}
.preview-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: #f0f0f0;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}
.preview-img {
  width: 100%;
  height: 100%;
}

/* 相框模板区域 */
.template-section {
  background: #fff;
  margin: 0 30rpx;
  border-radius: 32rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}
.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 30rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
}
.title-bar {
  width: 6rpx;
  height: 30rpx;
  background: linear-gradient(180deg, #e8b86d, #c9922a);
  border-radius: 3rpx;
}
.template-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.template-card {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fafafa;
  border-radius: 24rpx;
  position: relative;
  transition: all 0.2s;
  border: 2rpx solid transparent;
}
.template-card.selected {
  border-color: #ff69b4;
  background: #fff0f5;
  box-shadow: 0 4rpx 12rpx rgba(255,105,180,0.15);
}
.template-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  margin-right: 24rpx;
  background: #e8e8e8;
}
.template-info {
  flex: 1;
}
.template-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}
.template-spec {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}
.template-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff69b4;
}
.selected-mark {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 48rpx;
  height: 48rpx;
  background: #ff69b4;
  border-radius: 50%;
  text-align: center;
  line-height: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(255,105,180,0.3);
}

/* 底部固定栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255,255,255,0.96);
  backdrop-filter: blur(20rpx);
  padding: 24rpx 30rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 2rpx solid rgba(0,0,0,0.05);
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
}
.total-price {
  display: flex;
  flex-direction: column;
}
.total-label {
  font-size: 24rpx;
  color: #999;
}
.total-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #ff69b4;
  line-height: 1.2;
}
.confirm-btn {
  background: linear-gradient(135deg, #ff69b4, #ff8c69);
  color: #fff;
  border-radius: 60rpx;
  width: 280rpx;
  height: 88rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin: 0;
  box-shadow: 0 8rpx 20rpx rgba(255,105,180,0.3);
  border: none;
}
.confirm-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}