{
  "envId": "ai-ymcx-d0gcwabfjd375ffae",
  "functionRoot": "../cloudfunctions",
  "functions": [
    {
      "name": "adminApi",
      "dir": "../cloudfunctions/adminApi",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "timeout": 120
    },
    {
      "name": "photoRetention",
      "dir": "../cloudfunctions/photoRetention",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "timeout": 60,
      "triggers": [
        {
          "name": "photoRetentionDaily",
          "type": "timer",
          "config": "0 0 4 * * * *"
        }
      ]
    },
    {
      "name": "jimengPortraitWorker",
      "dir": "../cloudfunctions/jimengPortraitWorker",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "timeout": 60,
      "triggers": [
        {
          "name": "jimengPortraitWorkerTimer",
          "type": "timer",
          "config": "*/15 * * * * * *"
        }
      ]
    },
    {
      "name": "jimengPortraitMaterializer",
      "dir": "../cloudfunctions/jimengPortraitMaterializer",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "timeout": 60
    },
    {
      "name": "jimengPortraitAi",
      "dir": "../cloudfunctions/jimengPortraitAi",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "timeout": 30
    }
  ],
  "hosting": {
    "public": "dist",
    "ignore": ["node_modules/**", ".git/**"],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
