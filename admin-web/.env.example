# ── 开发（npm run dev）────────────────────────────────────────
# 云函数 HTTP 访问地址（在微信云开发控制台为 adminApi 开启 URL 化后填写）
# 示例：https://ai-photo-0g22lzk94d0b6846.service.tcloudbase.com/adminApi
VITE_API_BASE_URL=

# 开发时无云环境可开启 Mock（true / false）
VITE_USE_MOCK=false

# 开发时用 Vite 代理：/admin-api → VITE_API_BASE_URL
VITE_API_PREFIX=/admin-api

# ── 生产（npm run build，见 .env.production）────────────────
# 静态托管无代理，VITE_API_PREFIX 必须留空，VITE_API_BASE_URL 填完整 adminApi URL
