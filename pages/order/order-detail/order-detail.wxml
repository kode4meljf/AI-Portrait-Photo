<view class="container" wx:if="{{order}}">
  <view class="order-info">
    <view class="info-item">
      <text class="label">订单号：</text>
      <text class="value">{{order.orderNo}}</text>
    </view>
    <view class="info-item">
      <text class="label">状态：</text>
      <text class="value status {{order.status === '已发货' ? 'shipped' : 'processing'}}">{{order.status}}</text>
    </view>
    <view class="info-item">
      <text class="label">下单时间：</text>
      <text class="value">{{order.createTimeStr}}</text>
    </view>
    <view class="info-item" wx:if="{{order.estimatedCompleteTime}}">
      <text class="label">预计完成：</text>
      <text class="value">{{order.estimatedCompleteTime}}</text>
    </view>
  </view>

  <view class="frame-info">
    <image class="frame-img" src="{{order.frameThumb || '/assets/icons/album-placeholder.png'}}" mode="aspectFill"></image>
    <view class="frame-desc">
      <text class="frame-name">{{order.frameName}}</text>
      <text class="frame-spec">{{order.size}} / {{order.material}}</text>
      <text class="frame-price">¥{{order.price}}</text>
    </view>
  </view>

  <view class="photos-section">
    <view class="section-title">关联照片（{{photos.length}}张）</view>
    <view class="photos-grid">
      <image wx:for="{{photos}}" wx:key="index" src="{{item}}" mode="aspectFill" class="photo-item" bindtap="previewImage" data-url="{{item}}"></image>
    </view>
  </view>

  <view class="logistics" wx:if="{{order.shippingNo}}">
    <view class="section-title">物流信息</view>
    <view class="logistics-content">
      <text>运单号：{{order.shippingNo}}</text>
      <button class="track-btn" open-type="contact">联系客服查询</button>
    </view>
  </view>
</view>
<view wx:else class="empty-tip">订单不存在或加载失败</view>