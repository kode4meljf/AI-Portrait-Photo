<view class="container">
  <view class="card">
    <view class="field">
      <text class="label">客户昵称</text>
      <input class="input" placeholder="请输入客户昵称" value="{{form.nickName}}" bindinput="onInput" data-key="nickName"/>
    </view>

    <view class="field">
      <text class="label">手机号</text>
      <input class="input" type="number" maxlength="11" placeholder="请输入手机号" value="{{form.phone}}" bindinput="onInput" data-key="phone"/>
    </view>
  </view>

  <button class="save-btn" disabled="{{saving || !changed}}" bindtap="onSave">保存</button>
</view>
