/* packageProfile/pages/profile/profile.wxss */
.profile-container {
  background-color: #f5f5f5;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.scroll-area {
  flex: 1;
  overflow-y: auto;
}

/* 门店头部 */
.store-header {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 48rpx 40rpx 64rpx;
  position: relative;
  overflow: hidden;
}
.store-header::before {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 320rpx;
  height: 320rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 50%;
}
.store-header::after {
  content: '';
  position: absolute;
  bottom: -40rpx;
  left: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255,255,255,0.03);
  border-radius: 50%;
}
.store-top {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 40rpx;
}
.store-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 32rpx;
  overflow: hidden;
  flex-shrink: 0;
}
.store-avatar-img {
  width: 100%;
  height: 100%;
}
.store-avatar-emoji {
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, #e8b86d, #c9922a);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  box-shadow: 0 8rpx 24rpx rgba(232,184,109,0.4);
  flex-shrink: 0;
}
.store-info {
  flex: 1;
}
.store-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}
.store-contact {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.store-contact .dot {
  width: 8rpx;
  height: 8rpx;
  background: rgba(255,255,255,0.4);
  border-radius: 50%;
}
.edit-btn {
  background: rgba(255,255,255,0.12);
  border: 2rpx solid rgba(255,255,255,0.2);
  border-radius: 40rpx;
  padding: 12rpx 28rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  flex-shrink: 0;
}
.store-address {
  background: rgba(255,255,255,0.07);
  border-radius: 20rpx;
  padding: 20rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}
.addr-icon {
  font-size: 28rpx;
}

/* 会员余额卡 */
.balance-card {
  margin: -32rpx 32rpx 0;
  background: #fff;
  border-radius: 32rpx;
  padding: 36rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.08);
  position: relative;
  z-index: 10;
}
.balance-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32rpx;
}
.balance-left .label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}
.balance-left .amount {
  font-size: 56rpx;
  font-weight: 700;
  color: #1a1a2e;
  line-height: 1;
}
.balance-left .amount .unit {
  font-size: 28rpx;
  font-weight: 500;
  color: #666;
  margin-left: 4rpx;
}
.level-badge {
  background: linear-gradient(135deg, #e8b86d, #c9922a);
  border-radius: 40rpx;
  padding: 8rpx 24rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #fff;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.crown {
  font-size: 26rpx;
}
.quota-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 28rpx;
}
.quota-item {
  flex: 1;
  background: #f8f8f8;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
}
.q-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 12rpx;
}
.q-val {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 12rpx;
}
.q-val text {
  font-size: 22rpx;
  font-weight: 400;
  color: #999;
}
.progress-bar {
  height: 8rpx;
  background: #ebebeb;
  border-radius: 4rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  border-radius: 4rpx;
  background: linear-gradient(90deg, #e8b86d, #c9922a);
}
.recharge-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  gap: 12rpx;
}

/* 数据看板 */
.section-header {
  padding: 40rpx 32rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.s-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.s-title::before {
  content: '';
  width: 6rpx;
  height: 30rpx;
  background: linear-gradient(180deg, #e8b86d, #c9922a);
  border-radius: 3rpx;
}
.s-more {
  font-size: 24rpx;
  color: #999;
  display: flex;
  align-items: center;
  gap: 4rpx;
}
.order-summary {
  margin: 0 32rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
  margin-bottom: 24rpx;
}
.summary-amount {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 32rpx;
  padding-bottom: 28rpx;
  border-bottom: 2rpx solid #f5f5f5;
}
.amt-label {
  font-size: 24rpx;
  color: #999;
}
.amt-val {
  font-size: 52rpx;
  font-weight: 700;
  color: #1a1a2e;
}
.category-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}
.cat-item {
  background: #f8f9ff;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.cat-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}
.cat-icon.blue { background: #e8f0fe; }
.cat-icon.purple { background: #f3e8ff; }
.cat-icon.orange { background: #fff3e0; }
.cat-icon.green { background: #e8f5e9; }
.cat-info .cat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  line-height: 1.2;
}
.cat-info .cat-name {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 打卡活跃 */
.checkin-card {
  margin: 0 32rpx 24rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}
.checkin-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 28rpx;
}
.checkin-item {
  flex: 1;
  border-radius: 24rpx;
  padding: 28rpx;
  position: relative;
  overflow: hidden;
}
.checkin-item.yesterday {
  background: linear-gradient(135deg, #667eea, #764ba2);
}
.checkin-item.today {
  background: linear-gradient(135deg, #f093fb, #f5576c);
}
.ci-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.75);
  margin-bottom: 12rpx;
}
.ci-num {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
  margin-bottom: 8rpx;
}
.ci-sub {
  font-size: 22rpx;
  color: rgba(255,255,255,0.65);
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.ci-deco {
  position: absolute;
  right: -20rpx;
  bottom: -20rpx;
  font-size: 100rpx;
  opacity: 0.12;
}
.uncheckin-tip {
  background: #fff8f0;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.tip-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 26rpx;
  color: #e67e22;
}
.warn-icon {
  font-size: 32rpx;
}
.tip-left .bold {
  font-weight: 700;
}
.tip-right {
  font-size: 24rpx;
  color: #e67e22;
  background: rgba(230,126,34,0.1);
  padding: 8rpx 20rpx;
  border-radius: 40rpx;
}