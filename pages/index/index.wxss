/* pages/index/index.wxss */
.phone-container {
  background-color: #f5f5f5;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.scroll-area {
  flex: 1;
  overflow-y: auto;
}

/* 头部 */
.home-header {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 32rpx 40rpx 40rpx;
  position: relative;
  overflow: hidden;
}
.home-header::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 50%;
}
.home-header::after {
  content: '';
  position: absolute;
  bottom: -20rpx;
  left: -20rpx;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255,255,255,0.03);
  border-radius: 50%;
}

.header-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 28rpx;
}
.store-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #e8b86d, #c9922a);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 6rpx 20rpx rgba(232,184,109,0.35);
}
.store-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}
.store-sub {
  font-size: 22rpx;
  color: rgba(255,255,255,0.55);
  margin-top: 4rpx;
}

.quick-stats {
  display: flex;
  gap: 20rpx;
}
.stat-chip {
  background: rgba(255,255,255,0.1);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 40rpx;
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}
.stat-chip .val {
  color: #e8b86d;
  font-weight: 700;
}

/* 拍摄卡片 */
.shoot-section {
  padding: 40rpx 40rpx 0;
  margin-top: -40rpx;
  position: relative;
  z-index: 2;
}
.shoot-card {
  background: #fff;
  border-radius: 40rpx;
  padding: 48rpx 40rpx 40rpx;
  box-shadow: 0 12rpx 48rpx rgba(0,0,0,0.08);
  text-align: center;
}
.camera-wrap {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
  box-shadow: 0 16rpx 48rpx rgba(26,26,46,0.3);
  position: relative;
}
.camera-wrap::before {
  content: '';
  position: absolute;
  inset: 8rpx;
  border: 4rpx dashed rgba(232,184,109,0.6);
  border-radius: 50%;
  animation: rotate 12s linear infinite;
}
@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
.camera-icon {
  font-size: 80rpx;
}
.shoot-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 12rpx;
}
.shoot-sub {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 36rpx;
}
.shoot-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #e8b86d, #c9922a);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  gap: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(232,184,109,0.4);
  letter-spacing: 2rpx;
  border: none;
  outline: none;
  padding: 0;
  line-height: 1;
}
.shoot-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}
.shoot-tip {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-top: 28rpx;
}
.shoot-tip text {
  font-size: 22rpx;
  color: #bbb;
  display: flex;
  align-items: center;
  gap: 6rpx;
}


/* 客户卡片 */
.customer-card {
  background: #fff;
  margin: 40rpx 40rpx 20rpx;
  border-radius: 28rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.customer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.customer-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
}
.btn-select, .btn-cancel {
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  background: #f0f0f0;
  color: #666;
  border: none;
  line-height: 1.2;
}
.btn-select {
  background: #e8b86d;
  color: #fff;
}
.customer-placeholder {
  text-align: center;
  padding: 40rpx 0;
  color: #aaa;
  font-size: 28rpx;
}
.customer-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.customer-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  background: #f0f0f0;
}
.customer-detail {
  flex: 1;
}
.customer-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
}
.customer-equity {
  display: flex;
  gap: 24rpx;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #e8b86d;
}

/* 最近服务 */
.section-header {
  padding: 40rpx 40rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.s-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.s-title::before {
  content: '';
  width: 6rpx;
  height: 30rpx;
  background: linear-gradient(180deg, #e8b86d, #c9922a);
  border-radius: 3rpx;
}
.s-more {
  font-size: 24rpx;
  color: #999;
  display: flex;
  align-items: center;
  gap: 4rpx;
}
.recent-list {
  padding: 0 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.recent-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.recent-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: #f0f0f0;
}
.recent-avatar image {
  width: 100%;
  height: 100%;
}
.recent-info {
  flex: 1;
}
.recent-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 6rpx;
}
.recent-meta {
  font-size: 22rpx;
  color: #999;
  display: flex;
  gap: 12rpx;
  align-items: center;
}
.recent-tag {
  background: #f0fdf4;
  color: #22c55e;
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}
.recent-tag.waiting {
  background: #fffbeb;
  color: #d97706;
}
.recent-tag.done {
  background: #f0fdf4;
  color: #22c55e;
}
.recent-action {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  color: #666;
  flex-shrink: 0;
}

/* 样板展示 */
.showcase-section {
  padding: 20rpx 40rpx 40rpx;
}
.showcase-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}
.showcase-item {
  border-radius: 28rpx;
  overflow: hidden;
  aspect-ratio: 1;
  background: #f0f0f0;
  position: relative;
}
.showcase-item image {
  width: 100%;
  height: 100%;
}
.showcase-label {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.5));
  padding: 40rpx 20rpx 16rpx;
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
  text-align: center;
}

