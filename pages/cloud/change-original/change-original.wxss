.change-page {
  min-height: 100vh;
  background: #f6f7f9;
  padding: 20rpx 24rpx 28rpx;
  box-sizing: border-box;
}

.subtitle-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 30rpx;
  color: #1f2937;
}

.count-text {
  font-size: 24rpx;
  color: #6b7280;
}

.preview-box {
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  background: #fff;
  height: 760rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.preview-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx;
  background: linear-gradient(180deg, rgba(17, 24, 39, 0) 0%, rgba(17, 24, 39, 0.68) 100%);
}

.preview-main-tip {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.preview-sub-tip {
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
}

.sample-card {
  margin-top: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx;
}

.tips-title {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.sample-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.sample-item {
  border-radius: 12rpx;
  overflow: hidden;
  background: #f9fafb;
}

.sample-thumb {
  height: 112rpx;
}

.sample-thumb.bad-bg {
  background: linear-gradient(135deg, #e5e7eb, #d1d5db);
}

.sample-thumb.good-bg {
  background: linear-gradient(135deg, #c7f9e5, #99f6e4);
}

.sample-tag {
  text-align: center;
  font-size: 22rpx;
  padding: 10rpx 0;
}

.sample-tag.bad {
  background: #fef2f2;
  color: #dc2626;
}

.sample-tag.good {
  background: #ecfdf5;
  color: #059669;
}
