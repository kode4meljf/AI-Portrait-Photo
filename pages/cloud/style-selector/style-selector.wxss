.style-page {
  min-height: 100vh;
  background: #f6f7f9;
  padding: 16rpx 24rpx 24rpx;
  box-sizing: border-box;
}

.preview-swiper {
  width: 100%;
  height: 760rpx;
}

.preview-card {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  overflow: hidden;
  background: #e9edf3;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.list-title {
  margin-top: 18rpx;
  margin-bottom: 14rpx;
  font-size: 24rpx;
  color: #4b5563;
}

.thumb-scroll {
  width: 100%;
  white-space: nowrap;
}

.thumb-row {
  display: inline-flex;
  gap: 14rpx;
  padding-bottom: 10rpx;
}

.thumb-item {
  width: 150rpx;
  border-radius: 14rpx;
  overflow: hidden;
  background: #fff;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.thumb-item.active {
  border-color: #111827;
}

.thumb-image {
  width: 100%;
  height: 188rpx;
  display: block;
}

.thumb-name {
  display: block;
  padding: 8rpx 8rpx 10rpx;
  font-size: 20rpx;
  color: #374151;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.bottom-bar {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.origin-box {
  height: 96rpx;
  border-radius: 16rpx;
  background: #fff;
  display: inline-flex;
  align-items: center;
  justify-content: flex-start;
  padding: 0 12rpx;
  gap: 8rpx;
  box-sizing: border-box;
  flex-shrink: 0;
}

.origin-thumb {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  background: #edf1f6;
}

.swap-icon {
  font-size: 28rpx;
  color: #9ca3af;
}

.origin-text {
  font-size: 24rpx;
  color: #374151;
}

.count-switch {
  height: 72rpx;
  border-radius: 36rpx;
  background: #fff;
  padding: 6rpx 6rpx 6rpx 16rpx;
  display: inline-flex;
  align-items: center;
  justify-content: flex-start;
  gap: 6rpx;
  box-sizing: border-box;
  flex-shrink: 0;
}

.count-label {
  font-size: 24rpx;
  color: #374151;
  white-space: nowrap;
  margin-right: 12rpx;
}

.count-btn {
  min-width: 76rpx;
  height: 60rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #6b7280;
  display: flex;
  align-items: center;
  justify-content: center;
}

.count-btn.active {
  background: #111827;
  color: #fff;
}

.submit-wrap {
  margin-top: 22rpx;
}

.submit-btn {
  width: 100%;
  height: 92rpx;
  border-radius: 28rpx;
  background: #111827;
  color: #fff;
  font-size: 30rpx;
  line-height: 92rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn::after {
  border: none;
}

.submit-btn-hover {
  transform: scale(0.985);
  background: #1f2937;
  opacity: 0.94;
}
