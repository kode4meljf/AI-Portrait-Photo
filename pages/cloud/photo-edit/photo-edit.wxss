.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #000;
}

.image-area {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-image {
  width: 100%;
  height: 100%;
}

.toolbar {
  background: #1a1a1a;
  padding: 30rpx;
}

.slider-item {
  margin-bottom: 30rpx;
  color: #fff;
}

.save-btn {
  background: #ff69b4;
  color: #fff;
  border-radius: 0;
  margin: 0;
  height: 100rpx;
  line-height: 100rpx;
  font-size: 32rpx;
}