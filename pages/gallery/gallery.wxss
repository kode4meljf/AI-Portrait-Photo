/* pages/gallery/gallery.wxss */
.gallery-container {
  background-color: #f5f5f5;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 顶部导航栏 */
.nav-bar {
  background: #fff;
  padding: 24rpx 0 16rpx;
  text-align: center;
  border-bottom: 2rpx solid #f0f0f0;
}
.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a2e;
}

/* Tab栏 */
.tabs {
  display: flex;
  background: #fff;
  padding: 0 40rpx;
  border-bottom: 2rpx solid #f0f0f0;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #999;
  position: relative;
}
.tab.active {
  color: #1a1a2e;
  font-weight: 600;
}
.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: #e8b86d;
  border-radius: 2rpx;
}

/* 滚动区域 */
.scroll-area {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx 32rpx 40rpx;
}

/* 月份分组 */
.month-group {
  margin-top: 32rpx;
  margin-bottom: 20rpx;
}
.month-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  padding-left: 10rpx;
  border-left: 6rpx solid #e8b86d;
}

/* 批次列表 */
.batch-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

/* 批次卡片 */
.batch-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

/* 批次头部 */
.batch-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.batch-date {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}
.batch-status {
  flex: 1;
  margin-left: 24rpx;
  font-size: 24rpx;
  color: #999;
}
.batch-status.completed {
  color: #22c55e;
}
.batch-status.generating {
  color: #e67e22;
}
.download-btn {
  background: #f5f5f5;
  border-radius: 60rpx;
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  color: #666;
  border: 2rpx solid #eee;
  flex-shrink: 0;
}

/* 缩略图网格 */
.batch-thumbs {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}
.thumb-item {
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f0f0f0;
}
.thumb-img {
  width: 100%;
  height: 100%;
}

/* 空状态等 */
.empty-tip, .loading-tip, .no-more {
  text-align: center;
  padding: 80rpx;
  color: #999;
  font-size: 28rpx;
}