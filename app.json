{
  "pages": [
    "pages/index/index",
    "pages/gallery/gallery",
    "pages/order-list/order-list",
    "pages/profile/profile"
  ],
  "subpackages": [
    {
      "root": "packageCloud",
      "name": "cloud",
      "pages": [
        "pages/browse/browse",
        "pages/photo-edit/photo-edit"
      ]
    },
    {
      "root": "packageOrder",
      "name": "order",
      "pages": [
        "pages/order-detail/order-detail",
        "pages/frame-template/frame-template"
      ]
    },
    {
      "root": "packageProfile",
      "name": "profile",
      "pages": [
        "pages/customer-list/customer-list",
        "pages/recharge/recharge",
        "pages/unchecked-list/unchecked-list",
        "pages/edit-store/edit-store"
      ]
    }
  ],
  "preloadRule": {
    "pages/index/index": {
      "network": "all",
      "packages": [
        "cloud"
      ]
    },
    "pages/gallery/gallery": {
      "network": "all",
      "packages": [
        "cloud"
      ]
    }
  },
  "lazyCodeLoading": "requiredComponents",
  "window": {
    "navigationBarBackgroundColor": "#ffffff",
    "navigationBarTitleText": "AI写真馆",
    "navigationBarTextStyle": "black",
    "backgroundColor": "#f5f5f5"
  },
  "tabBar": {
    "color": "#999999",
    "selectedColor": "#ff69b4",
    "backgroundColor": "#ffffff",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页"
      },
      {
        "pagePath": "pages/gallery/gallery",
        "text": "云相册"
      },
      {
        "pagePath": "pages/order-list/order-list",
        "text": "订单"
      },
      {
        "pagePath": "pages/profile/profile",
        "text": "我的"
      }
    ]
  },
  "style": "v2",
  "sitemapLocation": "sitemap.json",
  "cloud": true
}