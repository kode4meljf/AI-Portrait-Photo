.privacy-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 10000;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 40rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.privacy-dialog {
  width: 100%;
  max-width: 620rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx 32rpx;
  box-sizing: border-box;
}

.privacy-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
  text-align: center;
  margin-bottom: 24rpx;
}

.privacy-body {
  font-size: 28rpx;
  color: #4b5563;
  line-height: 1.65;
  margin-bottom: 36rpx;
}

.privacy-text {
  color: #4b5563;
}

.privacy-link {
  color: #0f3460;
  font-weight: 600;
}

.privacy-actions {
  display: flex;
  gap: 20rpx;
}

.privacy-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 42rpx;
  font-size: 28rpx;
  padding: 0;
  margin: 0;
}

.privacy-btn::after {
  border: none;
}

.privacy-btn--ghost {
  background: #f3f4f6;
  color: #6b7280;
}

.privacy-btn--primary {
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
  color: #fff;
  font-weight: 600;
}
