.showcase-section {
  padding: 8rpx 0 0;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.showcase-status,
.showcase-empty {
  text-align: center;
  padding: 48rpx 0;
  font-size: 26rpx;
  color: #9ca3af;
}

.showcase-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.grid-item {
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
  background: #eef0f4;
  box-shadow: 0 4rpx 16rpx rgba(26, 26, 46, 0.06);
  aspect-ratio: 3 / 4;
}

.grid-img {
  width: 100%;
  height: 100%;
  display: block;
  position: absolute;
  left: 0;
  top: 0;
}

.grid-img--empty {
  background: linear-gradient(145deg, #d1d5db, #e5e7eb);
  position: relative;
}

.c-grad-name {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  padding: 48rpx 12rpx 14rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.58));
  color: #fff;
  font-size: 22rpx;
  text-align: center;
  box-sizing: border-box;
}

.showcase-foot {
  margin-top: 20rpx;
  padding-bottom: 8rpx;
  text-align: center;
  font-size: 24rpx;
  color: #9ca3af;
}

.showcase-foot--done {
  color: #c4c9d0;
}
