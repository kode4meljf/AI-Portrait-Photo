<view class="showcase-section">
  <view class="section-head">
    <text class="section-title">{{title}}</text>
  </view>

  <view wx:if="{{loading}}" class="showcase-status">加载中…</view>
  <view wx:elif="{{!items.length}}" class="showcase-empty">暂无风格展示</view>
  <block wx:else>
    <view class="showcase-grid">
      <view
        wx:for="{{items}}"
        wx:key="id"
        class="grid-item"
        bindtap="onPreview"
        data-index="{{item.index}}"
      >
        <image wx:if="{{item.cover}}" class="grid-img" src="{{item.cover}}" mode="aspectFill" />
        <view wx:else class="grid-img grid-img--empty" />
        <text class="c-grad-name">{{item.name}}</text>
      </view>
    </view>
    <view wx:if="{{loadingMore}}" class="showcase-foot">加载中…</view>
    <view wx:elif="{{!hasMore}}" class="showcase-foot showcase-foot--done">已展示全部风格</view>
  </block>
</view>
