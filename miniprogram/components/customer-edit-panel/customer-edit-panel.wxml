<view class="edit-root {{embed === 'page' ? 'edit-root--page' : 'edit-root--sheet'}}">
  <view wx:if="{{embed !== 'page'}}" class="edit-header">
    <view class="nav-back" bindtap="onBack" hover-class="nav-back--active" hover-stay-time="80">
      <view class="nav-back-chevron"></view>
    </view>
    <text class="edit-title">编辑客户</text>
    <view class="header-spacer"></view>
  </view>

  <!-- 弹层：固定高度内 scroll-view -->
  <scroll-view
    wx:if="{{embed !== 'page'}}"
    class="edit-scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
  >
    <view class="edit-profile">
      <view wx:if="{{editAvatarUrl}}" class="edit-avatar edit-avatar--image">
        <image class="edit-avatar-img" src="{{editAvatarUrl}}" mode="aspectFill" />
      </view>
      <view wx:else class="edit-avatar edit-avatar--initial" style="background-color: {{editAvatarTint}};">
        <text class="edit-avatar-initial">{{editAvatarInitial}}</text>
      </view>
      <text class="edit-avatar-hint">头像来自客户码，客户打卡后自动更新</text>
    </view>
    <view class="edit-form">
      <view class="edit-field edit-field--readonly">
        <text class="edit-label">微信昵称</text>
        <text class="edit-readonly">{{editWxNickName || '暂未同步，客户打卡后将自动更新'}}</text>
      </view>
      <view class="edit-field">
        <text class="edit-label">客户称呼</text>
        <input
          class="edit-input"
          placeholder-class="edit-placeholder"
          placeholder="店长备注，方便识别客户"
          value="{{editForm.nickName}}"
          bindinput="onEditInput"
          data-key="nickName"
        />
      </view>
      <view class="edit-field">
        <text class="edit-label">手机号 <text class="edit-required">*</text></text>
        <input
          wx:if="{{!editPhoneLocked}}"
          class="edit-input"
          type="number"
          maxlength="11"
          placeholder-class="edit-placeholder"
          placeholder="请输入 11 位手机号"
          value="{{editForm.phone}}"
          bindinput="onEditInput"
          data-key="phone"
        />
        <text wx:else class="edit-readonly">{{editForm.phone}}</text>
        <text wx:if="{{editPhoneLocked}}" class="edit-field-hint">已绑定微信，手机号仅可由客户在顾客端更换</text>
      </view>
      <view class="edit-field edit-field--gender">
        <view class="gender-row">
          <text class="edit-label">性别</text>
          <view class="gender-row-ctrl">
            <view class="gender-filter">
              <view
                class="gender-filter-btn {{editForm.gender === 'male' ? 'active' : ''}}"
                bindtap="onGenderTap"
                data-value="male"
              >男</view>
              <view
                class="gender-filter-btn {{editForm.gender === 'female' ? 'active' : ''}}"
                bindtap="onGenderTap"
                data-value="female"
              >女</view>
            </view>
          </view>
        </view>
      </view>
      <view class="edit-field edit-field--textarea">
        <text class="edit-label">住址</text>
        <textarea
          class="edit-textarea"
          placeholder-class="edit-placeholder"
          placeholder="选填，仅门店可见"
          value="{{editForm.address}}"
          bindinput="onEditInput"
          data-key="address"
          maxlength="200"
          auto-height
          show-confirm-bar="{{false}}"
        />
        <text class="edit-field-hint--store">仅门店端可见，顾客不可见</text>
      </view>
      <view class="edit-field edit-field--textarea">
        <text class="edit-label">备注</text>
        <textarea
          class="edit-textarea"
          placeholder-class="edit-placeholder"
          placeholder="选填，可记录客户偏好、拍摄要求等"
          value="{{editForm.remark}}"
          bindinput="onEditInput"
          data-key="remark"
          maxlength="200"
          auto-height
          show-confirm-bar="{{false}}"
        />
      </view>
    </view>
  </scroll-view>

  <!-- 整页：页面级滚动（真机避免 scroll-view 高度塌缩） -->
  <view wx:else class="edit-body-page">
    <view class="edit-profile">
      <view wx:if="{{editAvatarUrl}}" class="edit-avatar edit-avatar--image">
        <image class="edit-avatar-img" src="{{editAvatarUrl}}" mode="aspectFill" />
      </view>
      <view wx:else class="edit-avatar edit-avatar--initial" style="background-color: {{editAvatarTint}};">
        <text class="edit-avatar-initial">{{editAvatarInitial}}</text>
      </view>
      <text class="edit-avatar-hint">头像来自客户码，客户打卡后自动更新</text>
    </view>
    <view class="edit-form">
      <view class="edit-field edit-field--readonly">
        <text class="edit-label">微信昵称</text>
        <text class="edit-readonly">{{editWxNickName || '暂未同步，客户打卡后将自动更新'}}</text>
      </view>
      <view class="edit-field">
        <text class="edit-label">客户称呼</text>
        <input
          class="edit-input"
          placeholder-class="edit-placeholder"
          placeholder="店长备注，方便识别客户"
          value="{{editForm.nickName}}"
          bindinput="onEditInput"
          data-key="nickName"
        />
      </view>
      <view class="edit-field">
        <text class="edit-label">手机号 <text class="edit-required">*</text></text>
        <input
          wx:if="{{!editPhoneLocked}}"
          class="edit-input"
          type="number"
          maxlength="11"
          placeholder-class="edit-placeholder"
          placeholder="请输入 11 位手机号"
          value="{{editForm.phone}}"
          bindinput="onEditInput"
          data-key="phone"
        />
        <text wx:else class="edit-readonly">{{editForm.phone}}</text>
        <text wx:if="{{editPhoneLocked}}" class="edit-field-hint">已绑定微信，手机号仅可由客户在顾客端更换</text>
      </view>
      <view class="edit-field edit-field--gender">
        <view class="gender-row">
          <text class="edit-label">性别</text>
          <view class="gender-row-ctrl">
            <view class="gender-filter">
              <view
                class="gender-filter-btn {{editForm.gender === 'male' ? 'active' : ''}}"
                bindtap="onGenderTap"
                data-value="male"
              >男</view>
              <view
                class="gender-filter-btn {{editForm.gender === 'female' ? 'active' : ''}}"
                bindtap="onGenderTap"
                data-value="female"
              >女</view>
            </view>
          </view>
        </view>
      </view>
      <view class="edit-field edit-field--textarea">
        <text class="edit-label">住址</text>
        <textarea
          class="edit-textarea"
          placeholder-class="edit-placeholder"
          placeholder="选填，仅门店可见"
          value="{{editForm.address}}"
          bindinput="onEditInput"
          data-key="address"
          maxlength="200"
          auto-height
          show-confirm-bar="{{false}}"
        />
        <text class="edit-field-hint--store">仅门店端可见，顾客不可见</text>
      </view>
      <view class="edit-field edit-field--textarea">
        <text class="edit-label">备注</text>
        <textarea
          class="edit-textarea"
          placeholder-class="edit-placeholder"
          placeholder="选填，可记录客户偏好、拍摄要求等"
          value="{{editForm.remark}}"
          bindinput="onEditInput"
          data-key="remark"
          maxlength="200"
          auto-height
          show-confirm-bar="{{false}}"
        />
      </view>
    </view>
  </view>

  <view class="edit-save-bar {{embed === 'page' ? 'edit-save-bar--fixed' : ''}}">
    <view
      wx:if="{{editCanDelete}}"
      class="edit-delete-btn {{editDeleting || editSaving ? 'edit-delete-btn--disabled' : ''}}"
      hover-class="edit-delete-btn-hover"
      hover-stay-time="80"
      bindtap="onDelete"
    >删除档案</view>
    <view
      class="edit-save-btn {{editSaving || !editCanSave ? 'edit-save-btn--disabled' : ''}}"
      hover-class="edit-save-btn-hover"
      hover-stay-time="80"
      bindtap="onSave"
    >保存</view>
  </view>
</view>
