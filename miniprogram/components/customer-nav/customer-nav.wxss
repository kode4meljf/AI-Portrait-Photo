/* 对齐 app.json tabBar：纯文字、无 icon */
.customer-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: stretch;
  background: #ffffff;
  border-top: 1rpx solid #e5e5e5;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.nav-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  color: #999999;
}

.nav-item.active {
  color: #ff69b4;
}

.nav-text {
  font-size: 20rpx;
  line-height: 1.2;
}
