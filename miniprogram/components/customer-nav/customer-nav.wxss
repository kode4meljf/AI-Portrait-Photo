.customer-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  background: #fff;
  border-top: 2rpx solid #f0f0f0;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0 10rpx;
  color: #999;
}

.nav-item.active {
  color: #ff69b4;
}

.nav-icon {
  font-size: 28rpx;
  line-height: 1.2;
}

.nav-text {
  font-size: 20rpx;
  margin-top: 4rpx;
}
