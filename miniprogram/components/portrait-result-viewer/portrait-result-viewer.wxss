.page-shell {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
}

.result-nav {
  flex-shrink: 0;
  background: #f6f7f9;
  box-sizing: border-box;
}

.result-nav-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 16rpx 0 8rpx;
  box-sizing: border-box;
}

.nav-back {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
}

.nav-back--active {
  opacity: 0.55;
}

.nav-back-chevron {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid rgba(0, 0, 0, 0.88);
  border-bottom: 4rpx solid rgba(0, 0, 0, 0.88);
  transform: rotate(45deg);
  margin-left: 8rpx;
}

.result-nav-title {
  flex: 1;
  min-width: 0;
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a2e;
  text-align: center;
  padding-right: 72rpx;
  box-sizing: border-box;
}

.result-page {
  flex: 1;
  min-height: 0;
  background: #f6f7f9;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.page-body {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  padding: 0 24rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.image-zone {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  padding: 8rpx 0 0;
  overflow: hidden;
}

.hero-tip-row {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin: 4rpx 0 0;
  padding: 0 4rpx 16rpx;
  box-sizing: border-box;
}

.origin-toggle {
  flex-shrink: 0;
  min-height: 80rpx;
  padding: 0 8rpx 0 24rpx;
  font-size: 28rpx;
  color: #1a1a2e;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  background: transparent;
}

.origin-toggle.is-on {
  color: #c49a3d;
  font-weight: 600;
}

.origin-toggle--press {
  opacity: 0.45;
}

.hero-stage {
  flex: 1;
  min-height: 360rpx;
  width: 100%;
  display: flex;
  flex-direction: column;
}

.hero-frame {
  width: 100%;
  border-radius: 28rpx;
  background: #e9edf3;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  position: relative;
  overflow: hidden;
}

.result-swiper {
  width: 100%;
}

.result-swiper swiper-item {
  height: 100%;
}

.swiper-item-inner {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: 8rpx;
  position: relative;
}

.result-image {
  width: 100%;
  height: 100%;
  display: block;
}

.frame-overlay {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 4;
}

.hero-chrome {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  pointer-events: none;
}

.pill-count {
  padding: 8rpx 20rpx;
  border-radius: 40rpx;
  background: rgba(0, 0, 0, 0.52);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.2;
  backdrop-filter: blur(8px);
}

.pill-dl {
  padding: 8rpx 22rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.94);
  color: #1a1a2e;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.2;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  pointer-events: auto;
}

.pill-dl--active {
  opacity: 0.82;
}

.origin-float {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  width: 144rpx;
  border-radius: 16rpx;
  overflow: hidden;
  border: 4rpx solid #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.22);
  pointer-events: auto;
  transition: opacity 0.2s ease, transform 0.2s ease;
}

.origin-float.is-hidden {
  opacity: 0;
  pointer-events: none;
  transform: scale(0.92);
}

.origin-float--press {
  opacity: 0.88;
  transform: scale(0.96);
}

.origin-float image {
  width: 100%;
  height: 144rpx;
  display: block;
}

.origin-float .mini-label {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 8rpx 6rpx;
  font-size: 20rpx;
  color: #fff;
  text-align: center;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.55));
}

.swipe-toast {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  max-width: 88%;
  padding: 20rpx 28rpx;
  border-radius: 20rpx;
  background: rgba(0, 0, 0, 0.72);
  color: #fff;
  font-size: 24rpx;
  line-height: 1.45;
  text-align: center;
}

.swiper-item-inner.is-failed,
.swiper-item-inner.is-generating {
  background: #e8e8e8;
}

.swiper-item-inner.is-retrying {
  background: #ececec;
}

.fail-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.72);
  z-index: 2;
  padding: 40rpx;
  box-sizing: border-box;
  pointer-events: none;
}

.fail-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #c0392b;
  margin-bottom: 12rpx;
}

.fail-hint {
  font-size: 24rpx;
  color: #888;
}

.retry-fab {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 6;
  pointer-events: auto;
}

.retry-fab--active {
  opacity: 0.82;
  transform: scale(0.96);
}

.retry-fab-icon {
  width: 42rpx;
  height: 42rpx;
  border: 4rpx solid #c49a3d;
  border-right-color: transparent;
  border-radius: 50%;
  animation: retry-spin 4s linear infinite;
}

@keyframes retry-spin {
  to {
    transform: rotate(360deg);
  }
}

.retrying-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.78);
  z-index: 3;
}

.retrying-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid #c49a3d;
  border-top-color: transparent;
  border-radius: 50%;
  animation: retry-spin 0.9s linear infinite;
  margin-bottom: 16rpx;
}

.retrying-text {
  font-size: 26rpx;
  color: #666;
}

.style-tray {
  flex-shrink: 0;
  margin: 8rpx 0 12rpx;
  box-sizing: border-box;
}

.list-title {
  margin-bottom: 14rpx;
  font-size: 24rpx;
  color: #4b5563;
}

.thumb-scroll {
  width: 100%;
  white-space: nowrap;
}

.thumb-row {
  display: inline-flex;
  gap: 14rpx;
  padding-bottom: 10rpx;
}

.thumb-item {
  width: 150rpx;
  border-radius: 14rpx;
  overflow: hidden;
  background: #fff;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.thumb-item.active {
  border-color: #111827;
}

.thumb-item.is-processing {
  opacity: 0.55;
}

.thumb-item.is-failed .thumb-image {
  filter: grayscale(0.45);
}

.thumb-image-wrap {
  position: relative;
  width: 100%;
  background: #edf1f6;
}

.thumb-image {
  width: 100%;
  height: 188rpx;
  display: block;
}

.thumb-name {
  display: block;
  padding: 8rpx 8rpx 10rpx;
  font-size: 20rpx;
  color: #374151;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.state-dot {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  border: 2rpx solid #fff;
  box-sizing: border-box;
}

.state-dot.ing {
  background: #e8a045;
}

.state-dot.fail {
  background: #e74c3c;
}

.hero-tip {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  color: #6f6f6f;
  line-height: 1.45;
}

.footer {
  flex-shrink: 0;
  padding: 20rpx 0 calc(28rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #ececec;
}

.action-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.btn {
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 0;
  margin: 0;
  line-height: 88rpx;
}

.btn-outline {
  background: #fff;
  color: #1a1a2e;
  border: 3rpx solid #d8d8d8;
}

.btn-primary {
  border: none;
  background: linear-gradient(135deg, #f4cf63, #e8b86d);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(232, 184, 109, 0.45);
}

.btn-primary.is-disabled {
  opacity: 0.38;
}

.btn::after {
  border: none;
}

.preview-layer {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  width: 100vw;
  height: 100vh;
  z-index: 1000;
}

.preview-layer.is-expanded {
  background: #000;
}

.preview-dim {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  transition: background 0.36s ease;
}

.preview-layer.is-expanded .preview-dim {
  background: #000;
}

.preview-fly {
  position: fixed;
  z-index: 1002;
  transform: translate(var(--tx, 0px), var(--ty, 0px)) scale(var(--scale, 1));
  transform-origin: center center;
  transition: transform 0.36s cubic-bezier(0.22, 0.61, 0.36, 1);
  pointer-events: none;
}

.preview-fly.is-expanded {
  opacity: 0;
}

.preview-fly-img {
  width: 100%;
  height: 100%;
  display: block;
}

.preview-ui {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1001;
  display: flex;
  flex-direction: column;
  padding-top: env(safe-area-inset-top);
  box-sizing: border-box;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s ease 0.12s;
}

.preview-ui.is-visible {
  opacity: 1;
  pointer-events: auto;
}

.preview-swiper {
  flex: 1;
  width: 100%;
  height: 100%;
}

.preview-slide {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0 8rpx;
  box-sizing: border-box;
}

.preview-slide-img {
  width: 100%;
  height: 100%;
  max-height: 100%;
}

.preview-progress-track {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 0 28rpx 12rpx;
  box-sizing: border-box;
}

.preview-segment {
  flex: 1;
  height: 6rpx;
  border-radius: 3rpx;
  background: rgba(255, 255, 255, 0.28);
  transition: background 0.25s ease;
}

.preview-segment.active {
  background: rgba(255, 255, 255, 0.95);
}

.preview-actions {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 36rpx calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.preview-action-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: rgba(42, 42, 42, 0.88);
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-icon-close {
  position: relative;
  width: 30rpx;
  height: 30rpx;
}

.preview-icon-close::before,
.preview-icon-close::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 30rpx;
  height: 4rpx;
  background: #fff;
  border-radius: 2rpx;
}

.preview-icon-close::before {
  transform: translate(-50%, -50%) rotate(45deg);
}

.preview-icon-close::after {
  transform: translate(-50%, -50%) rotate(-45deg);
}

.preview-icon-down {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.preview-icon-down-stem {
  width: 5rpx;
  height: 18rpx;
  background: #fff;
  border-radius: 3rpx;
}

.preview-icon-down-head {
  width: 0;
  height: 0;
  margin-top: -1rpx;
  border-left: 9rpx solid transparent;
  border-right: 9rpx solid transparent;
  border-top: 8rpx solid #fff;
}

.loading-body {
  flex: 1;
  height: 100%;
  min-height: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx calc(64rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  text-align: center;
}

.loading-main {
  width: 100%;
  max-width: 560rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transform: translateY(48rpx);
}

.spinner {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 8rpx solid #e0e0e0;
  border-top-color: #e8b86d;
  animation: spin 0.9s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f1f1f;
  margin-bottom: 16rpx;
}

.loading-hint {
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1.5;
}

.loading-hint-row {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 4rpx;
  margin-bottom: 4rpx;
}

.loading-gallery-link {
  display: inline-flex;
  align-items: center;
  min-height: 56rpx;
  padding: 0 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #c49a3d;
  line-height: 1.5;
}

.loading-gallery-link--press {
  opacity: 0.55;
}

.loading-preview {
  margin-top: 28rpx;
  width: 300rpx;
  height: 380rpx;
  max-height: 38vh;
  border-radius: 24rpx;
  overflow: hidden;
  background: #e4e4e4;
  opacity: 0.55;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-preview--press {
  opacity: 0.72;
  transform: scale(0.98);
}

.loading-preview image {
  width: 100%;
  height: 100%;
}
