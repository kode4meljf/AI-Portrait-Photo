/* 遮罩层 */
.picker-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 999;
  pointer-events: none;
  transition: background 0.3s ease;
}

.picker-overlay.active {
  background: rgba(0, 0, 0, 0.5);
  pointer-events: auto;
}

/* 滑出面板 */
.picker-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 72vh;
  max-height: 72vh;
  padding-bottom: 0;
  box-sizing: border-box;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.12);
  z-index: 1000;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.picker-sheet.active {
  transform: translateY(0);
}

/* 顶部栏 */
.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 24rpx;
  flex-shrink: 0;
}

.picker-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.close-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  padding: 0;
  box-sizing: border-box;
  line-height: 0;
}

.close-btn-x {
  font-size: 40rpx;
  color: #999;
  font-weight: 300;
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  display: block;
}

.close-btn:active {
  opacity: 0.7;
}

.header-line {
  height: 1rpx;
  background: #f0f0f0;
  flex-shrink: 0;
}

/* 搜索栏 */
.search-bar-wrap {
  padding: 20rpx 32rpx 16rpx;
  flex-shrink: 0;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 44rpx;
  padding: 16rpx 24rpx;
  gap: 12rpx;
}

.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1;
}

.clear-icon {
  font-size: 32rpx;
  color: #ccc;
  padding: 4rpx;
  flex-shrink: 0;
}

/* 编辑面板在弹层内占满剩余高度 */
customer-edit-panel {
  flex: 1;
  min-height: 0;
  width: 100%;
}
/* 客户列表行（首页 customer-picker / 工作台客户列表共用） */

.customer-scroll {
  flex: 1;
  height: 0;
  width: 100%;
  box-sizing: border-box;
  padding: 0 24rpx;
  -webkit-overflow-scrolling: touch;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

.customer-item {
  display: flex;
  align-items: stretch;
  width: 100%;
  box-sizing: border-box;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  gap: 12rpx;
}

.customer-item:last-child {
  border-bottom: none;
}

.customer-item.selected {
  background: rgba(59, 130, 246, 0.04);
  border-radius: 16rpx;
  border-bottom: none;
}

.store-scope-avatar {
  background: linear-gradient(145deg, #4a4a4a, #1a1a1a);
}

.customer-avatar {
  width: 74rpx;
  height: 74rpx;
  border-radius: 50%;
  flex-shrink: 0;
  overflow: hidden;
  align-self: center;
}

.customer-avatar--image {
  background: #eee;
}

.customer-avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}

.customer-avatar--initial {
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-initial-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1;
}

.customer-info {
  flex: 1 1 0;
  min-width: 0;
  overflow: hidden;
  align-self: center;
}

.customer-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.35;
}

.customer-gender {
  margin-left: 16rpx;
  font-size: 24rpx;
  font-weight: 400;
  color: #8a8a8a;
}

.customer-phone {
  display: block;
  font-size: 22rpx;
  color: #999;
  line-height: 1.4;
}

.customer-right {
  display: flex;
  align-items: stretch;
  justify-content: flex-end;
  flex: 0 1 auto;
  max-width: 52%;
  margin-left: auto;
  box-sizing: border-box;
}

.right-status-col {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-end;
  align-self: center;
  gap: 6rpx;
  min-width: 0;
  flex: 1;
  text-align: right;
  padding: 8rpx 0;
}

.right-checkins {
  display: block;
  color: #b5b5b5;
  font-size: 20rpx;
  text-align: right;
  line-height: 1.3;
}

.right-checkins-num {
  font-size: 22rpx;
  color: #6f6f6f;
  font-weight: 600;
}

.right-tag {
  display: block;
  font-size: 20rpx;
  color: #ef4444;
  max-width: 100%;
  text-align: right;
  line-height: 1.25;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.edit-hit {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  align-self: center;
  margin-left: 8rpx;
  padding: 18rpx 12rpx 18rpx 20rpx;
  min-width: 72rpx;
  min-height: 72rpx;
  box-sizing: border-box;
}

.edit-hit--active {
  opacity: 0.45;
}

.edit-hit--active .edit-hit-icon {
  transform: scale(0.88);
}

.edit-hit-icon {
  width: 32rpx;
  height: 32rpx;
  display: block;
  transition: transform 0.12s ease;
}

.list-loading-tip,
.list-no-more {
  text-align: center;
  padding: 24rpx;
  color: #999;
  font-size: 24rpx;
}

.stats-bar {
  flex-shrink: 0;
  background: #f7f7f7;
  padding: 28rpx 32rpx calc(36rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
  text-align: center;
}

.stats-bar text {
  font-size: 24rpx;
  color: #999;
}
