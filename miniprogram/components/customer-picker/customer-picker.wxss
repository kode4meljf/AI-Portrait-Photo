/* 遮罩层 */
.picker-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 999;
  pointer-events: none;
  transition: background 0.3s ease;
}

.picker-overlay.active {
  background: rgba(0, 0, 0, 0.5);
  pointer-events: auto;
}

/* 滑出面板 */
.picker-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 72vh;
  max-height: 72vh;
  padding-bottom: 0;
  box-sizing: border-box;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.12);
  z-index: 1000;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.picker-sheet.active {
  transform: translateY(0);
}

/* 顶部栏 */
.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 24rpx;
  flex-shrink: 0;
}

.picker-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.close-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  padding: 0;
  box-sizing: border-box;
  line-height: 0;
}

.close-btn-x {
  font-size: 40rpx;
  color: #999;
  font-weight: 300;
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  display: block;
}

.close-btn:active {
  opacity: 0.7;
}

.header-line {
  height: 1rpx;
  background: #f0f0f0;
  flex-shrink: 0;
}

/* 搜索栏 */
.search-bar-wrap {
  padding: 20rpx 32rpx 16rpx;
  flex-shrink: 0;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 44rpx;
  padding: 16rpx 24rpx;
  gap: 12rpx;
}

.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1;
}

.clear-icon {
  font-size: 32rpx;
  color: #ccc;
  padding: 4rpx;
  flex-shrink: 0;
}

/* 客户列表 */
.customer-scroll {
  flex: 1;
  height: 0;
  width: 100%;
  box-sizing: border-box;
  padding: 0 24rpx;
  -webkit-overflow-scrolling: touch;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

.customer-item {
  display: flex;
  align-items: stretch;
  width: 100%;
  box-sizing: border-box;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  gap: 12rpx;
}

.customer-item:last-child {
  border-bottom: none;
}

.store-scope-avatar {
  background: linear-gradient(145deg, #4a4a4a, #1a1a1a) !important;
}

.customer-item.selected {
  background: rgba(59, 130, 246, 0.04);
  border-radius: 16rpx;
  margin: 0;
  padding: 22rpx 0;
  border-bottom: none;
}

.customer-avatar {
  width: 74rpx;
  height: 74rpx;
  border-radius: 50%;
  flex-shrink: 0;
  overflow: hidden;
}

.customer-avatar--image {
  background: #eee;
}

.customer-avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}

.customer-avatar--initial {
  display: flex;
  align-items: center;
  justify-content: center;
}

.customer-avatar,
.customer-avatar--image,
.customer-avatar--initial {
  align-self: center;
}

.avatar-initial-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1;
}

.customer-info {
  flex: 1 1 0;
  min-width: 0;
  overflow: hidden;
  align-self: center;
}

.customer-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.35;
}

.customer-wx-line {
  display: block;
  margin-bottom: 4rpx;
  font-size: 22rpx;
  color: #a1a1aa;
  line-height: 1.35;
}

.customer-phone {
  display: block;
  font-size: 22rpx;
  color: #999;
  line-height: 1.4;
}

.customer-right {
  display: flex;
  align-items: stretch;
  justify-content: flex-end;
  flex: 0 1 auto;
  max-width: 52%;
  margin-left: auto;
  padding: 0;
  box-sizing: border-box;
}

.right-status-col {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-end;
  align-self: center;
  gap: 6rpx;
  min-width: 0;
  flex: 1;
  text-align: right;
  padding: 8rpx 0;
}

.right-checkins {
  display: block;
  color: #b5b5b5;
  font-size: 20rpx;
  text-align: right;
  line-height: 1.3;
  white-space: normal;
  word-break: break-word;
}

.right-checkins-num {
  font-size: 22rpx;
  color: #6f6f6f;
  font-weight: 600;
}

.right-tag {
  display: block;
  font-size: 20rpx;
  color: #ef4444;
  max-width: 100%;
  text-align: right;
  line-height: 1.25;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.edit-hit {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  align-self: center;
  margin-left: 8rpx;
  padding: 18rpx 12rpx 18rpx 20rpx;
  min-width: 72rpx;
  min-height: 72rpx;
  box-sizing: border-box;
}

.edit-hit--active {
  opacity: 0.45;
}

.edit-hit--active .edit-hit-icon {
  transform: scale(0.88);
}

.edit-hit-icon {
  width: 32rpx;
  height: 32rpx;
  display: block;
  transition: transform 0.12s ease;
}

.loading-tip,
.no-more {
  text-align: center;
  padding: 24rpx;
  color: #999;
  font-size: 24rpx;
}

/* 底部统计栏 */
.stats-bar {
  flex-shrink: 0;
  background: #f7f7f7;
  padding: 28rpx 32rpx calc(36rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
  text-align: center;
}

.stats-bar text {
  font-size: 24rpx;
  color: #999;
}

/* 弹窗内编辑 · 方案 2 线框极简 */
.edit-header {
  position: relative;
  padding-left: 16rpx;
  padding-right: 16rpx;
  background: #fff;
  border-bottom: 1rpx solid #e5e5e5;
}

.edit-header .picker-title {
  flex: 1;
  text-align: center;
  font-weight: 600;
}

.header-spacer {
  width: 64rpx;
  flex-shrink: 0;
}

/* 贴近小程序导航栏返回：无底色、无阴影 */
.nav-back {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  flex-shrink: 0;
  background: transparent;
  box-shadow: none;
  border: none;
  padding: 0;
  margin: 0;
}

.nav-back--active {
  opacity: 0.55;
}

.nav-back-chevron {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid rgba(0, 0, 0, 0.9);
  border-bottom: 4rpx solid rgba(0, 0, 0, 0.9);
  transform: rotate(45deg);
  margin-left: 8rpx;
}

.edit-scroll {
  flex: 1;
  height: 0;
  box-sizing: border-box;
  padding: 0 48rpx;
  background: #fff;
}

.edit-profile {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 32rpx;
  box-sizing: border-box;
}

.edit-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  overflow: hidden;
  box-sizing: border-box;
  flex-shrink: 0;
}

.edit-avatar--image {
  background: #f4f4f5;
  border: 2rpx solid #e4e4e7;
}

.edit-avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}

.edit-avatar--initial {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #d4d4d8;
  background: #fafafa;
}

.edit-avatar-initial {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1;
}

.edit-avatar-hint {
  width: 100%;
  margin-top: 12rpx;
  font-size: 20rpx;
  color: #a1a1aa;
  text-align: center;
  line-height: 1.4;
}

.edit-form {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: 32rpx;
}

.edit-field {
  width: 100%;
  padding: 24rpx;
  border: 1rpx solid #e4e4e7;
  border-radius: 16rpx;
  background: transparent;
  box-sizing: border-box;
}

.edit-label {
  display: block;
  width: 100%;
  font-size: 26rpx;
  font-weight: 400;
  color: #71717a;
  margin: 0 0 12rpx;
  padding: 0;
  line-height: 36rpx;
  box-sizing: border-box;
}

.edit-input {
  display: block;
  width: 100%;
  height: 44rpx;
  min-height: 44rpx;
  margin: 0;
  padding: 0;
  font-size: 30rpx;
  color: #18181b;
  line-height: 44rpx;
  box-sizing: border-box;
}

.edit-placeholder {
  color: #d4d4d8;
  font-size: 30rpx;
  line-height: 44rpx;
}

.edit-field--readonly {
  background: #fafafa;
}

.edit-readonly {
  display: block;
  font-size: 30rpx;
  color: #52525b;
  line-height: 44rpx;
}

.edit-field--textarea {
  padding-bottom: 20rpx;
}

.edit-textarea {
  display: block;
  width: 100%;
  min-height: 132rpx;
  margin: 0;
  padding: 0;
  font-size: 30rpx;
  color: #18181b;
  line-height: 1.5;
  box-sizing: border-box;
}

.edit-save-bar {
  flex-shrink: 0;
  padding: 20rpx 48rpx calc(20rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #fff;
}

.edit-save-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  background: #18181b;
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  box-sizing: border-box;
}

.edit-save-btn-hover {
  background: #27272a;
}

.edit-save-btn--disabled {
  background: #e5e7eb;
  color: #9ca3af;
  pointer-events: none;
}
