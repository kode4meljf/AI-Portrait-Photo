.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.intro {
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.item {
  border-radius: 24rpx;
  overflow: hidden;
  background: #fff;
  position: relative;
  height: 0;
  padding-bottom: 120%;
}

.item image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.name {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 40rpx 16rpx 16rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.55));
  color: #fff;
  font-size: 24rpx;
  text-align: center;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
  color: #aaa;
  font-size: 28rpx;
}
