<view class="page">
  <view class="navy-top">
    <view class="top-row">
      <view class="avatar-shell">
        <image
          wx:if="{{profile.avatarUrl}}"
          class="avatar-img"
          src="{{profile.avatarUrl}}"
          mode="aspectFill"
        />
        <view wx:else class="avatar-img avatar-placeholder">{{avatarInitial}}</view>
        <button
          class="avatar-hit"
          open-type="chooseAvatar"
          bind:chooseavatar="onChooseAvatar"
        />
      </view>
      <view class="top-main">
          <view class="top-name-row">
          <view class="name-tap" bindtap="onOpenProfileModal">
            <text class="name-text">{{wxNickName}}</text>
          </view>
          <view class="help-entry" bindtap="onOpenHelp">
            <text class="help-entry-mark">?</text>
            <text>帮助</text>
          </view>
        </view>
        <text class="tap-hint" bindtap="onOpenProfileModal">点击修改资料</text>
        <view class="store-chip">
          <text class="chip-prefix">所属·</text>
          <text class="chip-name">{{storeName}}</text>
        </view>
      </view>
    </view>
    <view class="qr-strip" bindtap="onGoHome">
      <text class="qr-strip-t">到店出示打卡码</text>
      <text class="qr-strip-a">去首页 ›</text>
    </view>
  </view>

  <view class="white-card">
    <view class="phone-row">
      <text class="row-k">手机号</text>
      <text class="row-v">{{phoneMasked}}</text>
      <button class="link-btn" open-type="getPhoneNumber" bindgetphonenumber="onChangePhone">更换</button>
    </view>
  </view>
</view>

<view
  wx:if="{{showProfileModal}}"
  class="nick-mask"
  catchtouchmove="preventMove"
  bindtap="onCloseProfileModal"
>
  <view class="nick-dialog" catchtap="preventMove">
    <text class="dialog-title">修改资料</text>
    <text class="dialog-label">昵称</text>
    <input
      class="dialog-input"
      value="{{nickDraft}}"
      placeholder="请输入昵称"
      maxlength="20"
      focus="{{showProfileModal}}"
      bindinput="onNickDraftInput"
    />
    <view class="gender-row gender-row--dialog">
      <text class="dialog-label">性别</text>
      <view class="gender-row-ctrl">
        <view class="gender-filter">
          <view
            class="gender-filter-btn {{genderDraft === 'male' ? 'active' : ''}}"
            bindtap="onGenderDraftTap"
            data-value="male"
          >男</view>
          <view
            class="gender-filter-btn {{genderDraft === 'female' ? 'active' : ''}}"
            bindtap="onGenderDraftTap"
            data-value="female"
          >女</view>
        </view>
      </view>
    </view>
    <text class="dialog-hint">昵称 2～20 字；保存后顶区名称同步更新</text>
    <view class="dialog-btns">
      <view class="dialog-cancel" bindtap="onCloseProfileModal">取消</view>
      <view class="dialog-ok" bindtap="onConfirmProfile">确定</view>
    </view>
  </view>
</view>

<customer-nav current="profile" />
