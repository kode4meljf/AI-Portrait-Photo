.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx 24rpx calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.profile-head {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.avatar.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 40rpx;
  font-weight: 600;
}

.name {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.store {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #888;
}

.form {
  padding: 8rpx 0 24rpx;
}

.row {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  gap: 20rpx;
}

.label {
  width: 120rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.row-readonly {
  border-bottom: none;
  padding-bottom: 8rpx;
}

.readonly-val {
  flex: 1;
  font-size: 28rpx;
  color: #52525b;
  text-align: right;
}

.readonly-hint {
  display: block;
  padding: 0 32rpx 16rpx;
  font-size: 22rpx;
  color: #a1a1aa;
  line-height: 1.5;
}

.phone-row {
  border-bottom: none;
}

.phone-val {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.link-btn {
  margin: 0;
  padding: 0 16rpx;
  font-size: 26rpx;
  color: #2563eb;
  background: transparent;
  line-height: 1.5;
}

.link-btn::after {
  border: none;
}
