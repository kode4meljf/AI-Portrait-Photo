@import "../../../styles/help-entry.shared.wxss";

.page {
  min-height: 100vh;
  background: #eef0f4;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* 藏青顶区 */
.navy-top {
  padding: 36rpx 32rpx 32rpx;
  background: linear-gradient(145deg, #1a1a2e 0%, #16213e 55%, #0f3460 100%);
  border-radius: 0 0 40rpx 40rpx;
  box-sizing: border-box;
}

.top-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.top-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.top-name-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 外层裁切正圆；透明 button 仅负责选图，避免 button 默认样式把头像挤成异形 */
.avatar-shell {
  position: relative;
  width: 128rpx;
  height: 128rpx;
  flex-shrink: 0;
  border-radius: 50%;
  overflow: hidden;
}

.avatar-img {
  width: 128rpx;
  height: 128rpx;
  display: block;
  border-radius: 50%;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f0cc72, #c9922a);
  color: #1a1a2e;
  font-size: 52rpx;
  font-weight: 700;
}

.avatar-hit {
  position: absolute;
  left: 0;
  top: 0;
  width: 128rpx;
  height: 128rpx;
  padding: 0;
  margin: 0;
  opacity: 0;
  background: transparent;
  border: none;
  line-height: 0;
  z-index: 1;
}

.avatar-hit::after {
  border: none;
}

.name-tap {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  max-width: 100%;
}

.name-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tap-hint {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.45);
}

.store-chip {
  display: inline-flex;
  align-items: center;
  margin-top: 16rpx;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  background: rgba(232, 184, 109, 0.2);
  max-width: 100%;
  box-sizing: border-box;
}

.chip-prefix {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.55);
  flex-shrink: 0;
}

.chip-name {
  font-size: 22rpx;
  color: #e8b86d;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.qr-strip {
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(232, 184, 109, 0.35);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.qr-strip-t {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.qr-strip-a {
  font-size: 24rpx;
  color: #e8b86d;
  font-weight: 600;
}

/* 白卡：仅手机号 */
.white-card {
  margin: 28rpx 28rpx 0;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 16rpx 56rpx rgba(26, 26, 46, 0.08);
  border: 1rpx solid rgba(26, 26, 46, 0.04);
  overflow: hidden;
}

.phone-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 26rpx 32rpx;
}

.row-k {
  width: 112rpx;
  font-size: 26rpx;
  color: #6b7280;
  flex-shrink: 0;
}

.row-v {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a2e;
  text-align: right;
}

.link-btn {
  margin: 0;
  padding: 0 8rpx;
  font-size: 26rpx;
  color: #c9922a;
  font-weight: 600;
  background: transparent;
  line-height: 1.5;
  flex-shrink: 0;
}

.link-btn::after {
  border: none;
}

/* 居中弹窗 */
.nick-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 200;
  background: rgba(26, 26, 46, 0.48);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
  box-sizing: border-box;
}

.nick-dialog {
  width: 100%;
  max-width: 560rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 36rpx 32rpx 32rpx;
  box-shadow: 0 32rpx 96rpx rgba(26, 26, 46, 0.22);
  box-sizing: border-box;
}

.dialog-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  text-align: center;
  margin-bottom: 28rpx;
}

.dialog-label {
  display: block;
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 16rpx;
}

.dialog-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 20rpx;
  background: #f9fafb;
  font-size: 30rpx;
  color: #1a1a2e;
  box-sizing: border-box;
}

.dialog-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #9ca3af;
  text-align: center;
  line-height: 1.45;
}

.dialog-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.dialog-cancel,
.dialog-ok {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.dialog-cancel {
  border: 1rpx solid #e5e7eb;
  color: #6b7280;
}

.dialog-ok {
  background: linear-gradient(135deg, #e8b86d, #c9922a);
  color: #1a1a2e;
  font-weight: 600;
}
