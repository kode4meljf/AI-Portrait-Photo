.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx 24rpx calc(100rpx + env(safe-area-inset-bottom));
}

.intro {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 24rpx;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
}

.item {
  aspect-ratio: 1;
  border-radius: 16rpx;
  overflow: hidden;
  background: #e4e4e7;
}

.item image {
  width: 100%;
  height: 100%;
}

.placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #aaa;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
  color: #aaa;
}
