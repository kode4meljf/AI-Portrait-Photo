.page {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.scroll-area {
  flex: 1;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 24rpx 0;
}

.intro {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 24rpx;
}

.grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.item {
  border-radius: 16rpx;
  overflow: hidden;
  background: #fff;
}

.photo-wrap {
  aspect-ratio: 3 / 4;
  background: #eef0f4;
  overflow: hidden;
}

.photo-img {
  width: 100%;
  height: 100%;
  display: block;
}

.photo-name {
  display: block;
  padding: 8rpx 8rpx 10rpx;
  font-size: 20rpx;
  color: #374151;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.status,
.empty,
.foot {
  text-align: center;
  padding: 48rpx 0;
  font-size: 26rpx;
  color: #aaa;
}

.status--error {
  color: #e57373;
}

.empty {
  padding: 120rpx 0;
}

.foot {
  padding: 24rpx 0 8rpx;
  font-size: 24rpx;
}

.scroll-pad {
  height: calc(100rpx + env(safe-area-inset-bottom));
}
