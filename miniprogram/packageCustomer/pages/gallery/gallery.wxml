<view class="page">
  <view class="intro">门店为您生成的写真成片</view>
  <view class="grid">
    <view
      wx:for="{{batches}}"
      wx:key="_id"
      class="item"
      bindtap="previewBatch"
      data-url="{{item.coverUrl || item.thumbUrl}}"
    >
      <image wx:if="{{item.coverUrl || item.thumbUrl}}" src="{{item.coverUrl || item.thumbUrl}}" mode="aspectFill" />
      <view wx:else class="placeholder">成片</view>
    </view>
  </view>
  <view wx:if="{{!batches.length}}" class="empty">暂无相册内容</view>
</view>
<customer-nav current="gallery" />
