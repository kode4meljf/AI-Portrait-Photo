.page {
  min-height: 100vh;
  background: #f7f8fa;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.scroll-area {
  flex: 1;
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
}

.summary {
  margin: 24rpx 32rpx 8rpx;
  padding: 36rpx 32rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #2d3a5c 100%);
  color: #fff;
}

.summary-label {
  display: block;
  font-size: 26rpx;
  opacity: 0.75;
}

.summary-num {
  display: block;
  font-size: 64rpx;
  font-weight: 800;
  line-height: 1.15;
  margin: 8rpx 0 4rpx;
}

.summary-sub {
  display: block;
  font-size: 24rpx;
  opacity: 0.7;
}

.summary-chips {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.summary-chip {
  flex: 1;
  text-align: center;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 20rpx;
  padding: 16rpx 8rpx;
}

.chip-num {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.2;
}

.chip-txt {
  display: block;
  font-size: 22rpx;
  opacity: 0.85;
  margin-top: 4rpx;
}

.list-body {
  padding: 16rpx 32rpx 32rpx;
}

.order-card {
  background: #fff;
  border-radius: 36rpx;
  padding: 24rpx;
  display: flex;
  gap: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #e8eaef;
}

.order-card--hover {
  opacity: 0.94;
}

.order-photo-wrap {
  width: 176rpx;
  flex-shrink: 0;
  position: relative;
}

.order-photo {
  width: 176rpx;
  height: 220rpx;
  border-radius: 24rpx;
  background: #f4f4f5;
  border: 6rpx solid #c9a962;
  box-sizing: border-box;
  box-shadow: inset 0 0 0 6rpx #fff;
  display: block;
}

.order-photo-label {
  position: absolute;
  left: 50%;
  bottom: 12rpx;
  transform: translateX(-50%);
  font-size: 18rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.38);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  white-space: nowrap;
}

.order-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.order-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.order-head-text {
  flex: 1;
  min-width: 0;
}

.order-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  line-height: 1.35;
}

.order-style {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.order-status {
  flex-shrink: 0;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 40rpx;
  font-weight: 600;
  line-height: 1.2;
}

.order-status.pending {
  background: #fef3c7;
  color: #b45309;
}

.order-status.producing {
  background: #dbeafe;
  color: #1d4ed8;
}

.order-status.shipped {
  background: #e0e7ff;
  color: #4338ca;
}

.order-status.done {
  background: #f1f5f9;
  color: #64748b;
}

.order-meta {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #9ca3af;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-progress {
  margin-top: auto;
  padding-top: 20rpx;
}

.progress-steps {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.progress-step-label {
  font-size: 18rpx;
  color: #d1d5db;
  flex: 1;
  text-align: center;
}

.progress-step-label:first-child {
  text-align: left;
}

.progress-step-label:last-child {
  text-align: right;
}

.progress-bar {
  height: 8rpx;
  background: #f1f5f9;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: #4e7cf6;
  border-radius: 4rpx;
}

.state-empty {
  text-align: center;
  padding: 120rpx 40rpx;
  font-size: 28rpx;
  color: #9ca3af;
  line-height: 1.6;
}

.refresh-bar {
  text-align: center;
  font-size: 22rpx;
  color: #6b7280;
  padding: 12rpx;
  background: #eef0f4;
}

/* 骨架屏 */
@keyframes sk-shimmer {
  0% { background-position: 100% 0; }
  100% { background-position: -100% 0; }
}

.sk-line,
.sk-thumb,
.sk-chip,
.sk-bar {
  background: linear-gradient(90deg, #eceef2 25%, #f8f9fb 50%, #eceef2 75%);
  background-size: 200% 100%;
  animation: sk-shimmer 1.2s ease-in-out infinite;
  border-radius: 12rpx;
}

.sk-summary {
  margin: 24rpx 32rpx 8rpx;
  padding: 36rpx 32rpx;
  border-radius: 36rpx;
  background: #e8eaef;
}

.sk-line--short { width: 40%; height: 28rpx; margin-bottom: 16rpx; }
.sk-line--num { width: 28%; height: 64rpx; margin-bottom: 12rpx; }
.sk-line--mid { width: 55%; height: 28rpx; margin-bottom: 24rpx; }

.sk-chips {
  display: flex;
  gap: 16rpx;
}

.sk-chip {
  flex: 1;
  height: 88rpx;
  border-radius: 20rpx;
}

.sk-card {
  background: #fff;
  border-radius: 36rpx;
  padding: 24rpx;
  display: flex;
  gap: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #e8eaef;
}

.sk-thumb {
  width: 176rpx;
  height: 220rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.sk-body {
  flex: 1;
  min-width: 0;
  padding-top: 8rpx;
}

.sk-line--title { width: 70%; height: 36rpx; margin-bottom: 16rpx; }
.sk-line--sub { width: 50%; height: 28rpx; margin-bottom: 16rpx; }
.sk-line--meta { width: 85%; height: 24rpx; margin-bottom: 24rpx; }

.sk-bar {
  width: 100%;
  height: 8rpx;
  border-radius: 4rpx;
}
