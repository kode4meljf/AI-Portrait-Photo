.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx 24rpx calc(140rpx + env(safe-area-inset-bottom));
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.status {
  font-size: 24rpx;
  color: #2563eb;
  flex-shrink: 0;
}

.sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
  color: #aaa;
}
