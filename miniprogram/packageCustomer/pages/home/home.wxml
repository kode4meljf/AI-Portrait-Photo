<view class="page">
  <view class="store-tag">所属门店 · {{storeName}}</view>

  <view class="code-card">
    <text class="code-title">我的顾客码</text>
    <text class="code-hint">到店打卡前请先同步微信昵称；向店员出示顾客码或打卡二维码</text>
    <view class="nick-sync-row">
      <text class="nick-label">微信昵称</text>
      <input
        class="nick-input"
        type="nickname"
        placeholder="点击同步当前微信昵称"
        value="{{wxNickName}}"
        bindblur="onSyncWxNick"
      />
    </view>
    <view class="code-box">
      <text class="code-id">{{customerId}}</text>
    </view>
    <view class="copy-btn" bindtap="onCopyId">复制顾客码</view>
    <view class="copy-btn copy-btn--secondary" bindtap="onCopyCheckinPayload">复制完整打卡码</view>
  </view>

  <view class="menu-card" bindtap="goShowcase">
    <view class="menu-icon">✦</view>
    <view class="menu-text">
      <text class="menu-title">AI 写真展</text>
      <text class="menu-sub">浏览门店风格样板</text>
    </view>
    <text class="arrow">›</text>
  </view>
</view>

<customer-nav current="home" />
