<view class="page">
  <view class="hero">
    <text class="greet">你好，{{displayName || '顾客'}}</text>
    <text class="store-line" wx:if="{{storeName}}">{{storeName}}</text>
    <view class="stats">
      <view class="stat">
        <text class="stat-n">{{totalCheckins}}</text>
        <text class="stat-l">累计打卡</text>
      </view>
      <view class="stat">
        <text class="stat-n">{{equityAlbum}}</text>
        <text class="stat-l">相册权益</text>
      </view>
      <view class="stat">
        <text class="stat-n">{{equityFrame}}</text>
        <text class="stat-l">摆台权益</text>
      </view>
    </view>
  </view>

  <view class="qr-section">
    <view class="qr-card">
      <view wx:if="{{checkinQrReady && checkinQrUrl}}" class="qr-wrap">
        <image
          class="qr-img"
          src="{{checkinQrUrl}}"
          mode="aspectFit"
          show-menu-by-longpress="{{true}}"
        />
      </view>
      <view wx:else class="qr-placeholder">
        <text class="qr-placeholder-text">?</text>
      </view>
      <text class="qr-label">到店出示 · 扫码打卡</text>
      <text wx:if="{{checkinQrReady && checkinQrUrl}}" class="qr-tip">长按二维码可保存到相册</text>
      <text wx:if="{{!checkinQrReady}}" class="code-warn">未检测到有效手机号，无法生成打卡码，请联系门店</text>
    </view>
  </view>

  <view class="showcase-section">
    <view class="section-head">
      <text class="section-title">风格样品</text>
      <text class="section-more" bindtap="goShowcase">查看全部 ›</text>
    </view>
    <view wx:if="{{previewTemplates.length}}" class="samples">
      <view
        wx:for="{{previewTemplates}}"
        wx:key="id"
        class="sample-item"
        bindtap="onPreviewSample"
        data-index="{{index}}"
      >
        <image
          class="sample-img"
          src="{{item.sampleDisplayUrl || item.sampleFileId}}"
          mode="aspectFill"
        />
        <text class="sample-name">{{item.name}}</text>
      </view>
    </view>
    <view wx:else class="samples-empty">暂无风格展示</view>
  </view>
</view>

<customer-nav current="home" />
