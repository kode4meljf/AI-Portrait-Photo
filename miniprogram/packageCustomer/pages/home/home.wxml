<view class="page">
  <view class="hero">
    <text class="greet">你好，{{displayName || '顾客'}}</text>
    <text class="store-line" wx:if="{{storeName}}">{{storeName}}</text>
    <view class="stats">
      <view class="stat">
        <text class="stat-n">{{totalCheckins}}</text>
        <text class="stat-l">累计打卡</text>
      </view>
      <view class="stat">
        <text class="stat-n">{{equityAlbum}}</text>
        <text class="stat-l">相册权益</text>
      </view>
      <view class="stat">
        <text class="stat-n">{{equityFrame}}</text>
        <text class="stat-l">摆台权益</text>
      </view>
    </view>
  </view>

  <view class="qr-section">
    <view class="qr-card">
      <view wx:if="{{checkinQrFileId}}" class="qr-wrap">
        <image
          class="qr-img"
          src="{{checkinQrFileId}}"
          mode="aspectFit"
          show-menu-by-longpress="{{true}}"
        />
      </view>
      <view wx:else class="qr-placeholder">
        <text class="qr-placeholder-text">?</text>
      </view>
      <text wx:if="{{checkinQrFileId}}" class="qr-tip">长按二维码可保存到相册</text>
      <text class="qr-label">到店出示 · 扫码打卡</text>
      <text wx:if="{{!checkinQrFileId}}" class="code-warn">{{codeWarn}}</text>
    </view>
  </view>

  <style-showcase-home
    class="home-showcase"
    templates="{{previewTemplates}}"
    title="风格样品"
    more-text="查看全部 ›"
    bind:more="goShowcase"
    bind:preview="onPreviewSample"
  />
</view>

<customer-nav current="home" />
