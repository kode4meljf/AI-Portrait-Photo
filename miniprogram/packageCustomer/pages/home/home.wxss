.page {
  min-height: 100vh;
  background: #eef0f4;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* 顶区 */
.hero {
  padding: 24rpx 36rpx 44rpx;
  background: linear-gradient(145deg, #1a1a2e 0%, #16213e 52%, #0f3460 100%);
  border-radius: 0 0 40rpx 40rpx;
  box-sizing: border-box;
}

.greet {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 0.02em;
}

.store-line {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.62);
}

.stats {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.stat {
  flex: 1;
  padding: 20rpx 12rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  text-align: center;
  box-sizing: border-box;
}

.stat-n {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #f0cc72;
  line-height: 1.2;
}

.stat-l {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.55);
}

/* 中部 QR */
.qr-section {
  padding: 24rpx 32rpx 16rpx;
}

.qr-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx 32rpx 36rpx;
  text-align: center;
  box-shadow: 0 12rpx 40rpx rgba(26, 26, 46, 0.08);
  border: 1rpx solid rgba(26, 26, 46, 0.04);
  box-sizing: border-box;
}

.qr-wrap,
.qr-placeholder {
  width: 280rpx;
  height: 280rpx;
  margin: 0 auto 16rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.qr-img {
  width: 100%;
  height: 100%;
  display: block;
}

.qr-placeholder {
  background: #f3f4f6;
  border: 2rpx dashed #d1d5db;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qr-placeholder-text {
  font-size: 64rpx;
  color: #d1d5db;
  font-weight: 300;
}

.qr-label {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.qr-tip {
  display: block;
  margin: 0 auto 20rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
  color: #9a8b7a;
  line-height: 1.45;
}

.code-warn {
  display: block;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #e85d75;
  line-height: 1.5;
}

/* 风格样品：双列网格 + 分页（组件 style-showcase-home） */
.home-showcase {
  display: block;
  padding: 8rpx 32rpx 32rpx;
}
