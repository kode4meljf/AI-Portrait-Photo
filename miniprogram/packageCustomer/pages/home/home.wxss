.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 32rpx 32rpx calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.store-tag {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 24rpx;
}

.code-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.05);
}

.code-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.code-hint {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

.code-box {
  margin: 32rpx 0 24rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #fff5f9, #f3f0ff);
  border-radius: 20rpx;
  text-align: center;
}

.code-id {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  letter-spacing: 2rpx;
  word-break: break-all;
}

.nick-sync-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  background: #fafafa;
  border-radius: 16rpx;
}

.nick-label {
  font-size: 26rpx;
  color: #71717a;
  flex-shrink: 0;
}

.nick-input {
  flex: 1;
  font-size: 28rpx;
  color: #52525b;
  text-align: right;
}

.copy-btn {
  text-align: center;
  font-size: 28rpx;
  color: #0f3460;
  font-weight: 600;
  padding: 16rpx;
}

.copy-btn--secondary {
  font-size: 24rpx;
  font-weight: 500;
  color: #888;
}

.menu-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.menu-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #ff69b4, #9b8cff);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.menu-text {
  flex: 1;
}

.menu-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.menu-sub {
  display: block;
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #999;
}

.arrow {
  color: #d4d4d8;
  font-size: 36rpx;
}
