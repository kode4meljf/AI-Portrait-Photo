{
  "pages": [
    "pages/launch/launch",
    "pages/launch/create-store",
    "pages/join/join",
    "pages/customer-register/register",
    "pages/index/index",
    "pages/gallery/gallery",
    "pages/order-list/order-list",
    "pages/profile/profile"
  ],
  "preloadRule": {
    "pages/profile/profile": {
      "network": "all",
      "packages": ["store"]
    }
  },
  "subPackages": [
    {
      "root": "packageStore",
      "name": "store",
      "pages": [
        "pages/profile/members/members",
        "pages/profile/customer-create/customer-create",
        "pages/profile/customer-list/customer-list",
        "pages/profile/customer-edit/customer-edit",
        "pages/profile/recharge/recharge",
        "pages/profile/unchecked-list/unchecked-list",
        "pages/profile/edit-store/edit-store",
        "pages/cloud/portrait-viewer/portrait-viewer",
        "pages/cloud/photo-edit/photo-edit",
        "pages/cloud/style-selector/style-selector",
        "pages/cloud/change-original/change-original",
        "pages/cloud/frame-selector/frame-selector",
        "pages/order/order-detail/order-detail",
        "pages/order/frame-template/frame-template",
        "pages/profile/customer-invite/customer-invite",
        "pages/help/index",
        "pages/help/about",
        "pages/help/feedback",
        "pages/help/agreement",
        "pages/help/privacy"
      ]
    },
    {
      "root": "packageCustomer",
      "name": "customer",
      "pages": [
        "pages/home/home",
        "pages/showcase/showcase",
        "pages/gallery/gallery",
        "pages/order-list/order-list",
        "pages/order-detail/order-detail",
        "pages/profile/profile",
        "pages/help/index",
        "pages/help/about",
        "pages/help/feedback",
        "pages/help/agreement",
        "pages/help/privacy"
      ]
    }
  ],
  "lazyCodeLoading": "requiredComponents",
  "window": {
    "navigationBarBackgroundColor": "#ffffff",
    "navigationBarTitleText": "AI写真馆",
    "navigationBarTextStyle": "black",
    "backgroundColor": "#f5f5f5"
  },
  "tabBar": {
    "custom": true,
    "color": "#999999",
    "selectedColor": "#ff69b4",
    "backgroundColor": "#ffffff",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页"
      },
      {
        "pagePath": "pages/gallery/gallery",
        "text": "云相册"
      },
      {
        "pagePath": "pages/order-list/order-list",
        "text": "订单"
      },
      {
        "pagePath": "pages/profile/profile",
        "text": "我的"
      }
    ]
  },
  "style": "v2",
  "sitemapLocation": "sitemap.json",
  "cloud": true,
  "__usePrivacyCheck__": true,
  "requiredPrivateInfos": [
    "chooseLocation"
  ]
}
