/* 我的页 · 右上「帮助」入口 */
.help-entry {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.92);
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  line-height: 1.2;
}

.help-entry:active {
  background: rgba(255, 255, 255, 0.18);
}

.help-entry-mark {
  font-size: 26rpx;
  opacity: 0.9;
  line-height: 1;
}

.help-entry.gold {
  color: #e8b86d;
  border-color: rgba(232, 184, 109, 0.35);
  background: rgba(232, 184, 109, 0.12);
}

.help-entry.gold:active {
  background: rgba(232, 184, 109, 0.2);
}
