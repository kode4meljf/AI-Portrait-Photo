/* 订单列表卡片封面：摆台 / 影集 */

.order-photo-wrap {
  width: 176rpx;
  height: 220rpx;
  flex-shrink: 0;
  position: relative;
}

.order-photo-label {
  position: absolute;
  left: 50%;
  bottom: 12rpx;
  transform: translateX(-50%);
  font-size: 18rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.38);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  white-space: nowrap;
  z-index: 2;
}

.order-thumb-album .order-photo-label {
  background: rgba(26, 26, 46, 0.52);
}

/* 摆台 */
.order-thumb-frame {
  width: 176rpx;
  height: 220rpx;
  border-radius: 16rpx;
  background: #f4f4f5;
  border: 6rpx solid #c9a962;
  box-sizing: border-box;
  box-shadow: inset 0 0 0 6rpx #fff;
  display: block;
}

/* 影集 */
.order-thumb-album {
  width: 176rpx;
  height: 220rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.album-book {
  width: 168rpx;
  height: 204rpx;
  display: flex;
  align-items: stretch;
  filter: drop-shadow(0 8rpx 20rpx rgba(26, 26, 46, 0.14));
}

.album-book-face {
  flex: 1;
  min-width: 0;
  height: 100%;
  display: flex;
  border-radius: 12rpx 0 0 12rpx;
  overflow: hidden;
  border: 2rpx solid rgba(201, 146, 42, 0.28);
  border-right: none;
  background: #fff;
  box-sizing: border-box;
}

.album-page-left {
  width: 36%;
  background: linear-gradient(180deg, #faf6ef 0%, #ebe4d8 100%);
  position: relative;
}

.album-page-left::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, rgba(0, 0, 0, 0.05) 0%, transparent 55%);
  pointer-events: none;
}

.album-spine {
  width: 6rpx;
  flex-shrink: 0;
  background: linear-gradient(
    90deg,
    rgba(0, 0, 0, 0.1) 0%,
    rgba(255, 255, 255, 0.22) 45%,
    rgba(0, 0, 0, 0.07) 100%
  );
}

.album-page-right {
  flex: 1;
  position: relative;
  overflow: hidden;
  background: #fff;
}

.album-page-photo {
  width: 100%;
  height: 100%;
  display: block;
}

.album-page-right::after {
  content: '';
  position: absolute;
  inset: 0;
  box-shadow: inset 6rpx 0 12rpx rgba(0, 0, 0, 0.03);
  pointer-events: none;
}

.album-thickness {
  width: 20rpx;
  flex-shrink: 0;
  position: relative;
  margin-top: 8rpx;
  margin-bottom: 8rpx;
  border-radius: 0 14rpx 14rpx 0;
  overflow: hidden;
  border: 2rpx solid rgba(201, 146, 42, 0.28);
  border-left: none;
  background: linear-gradient(180deg, #d8cfc0 0%, #c9bfae 50%, #d8cfc0 100%);
  box-shadow: inset 4rpx 0 8rpx rgba(255, 255, 255, 0.25);
  box-sizing: border-box;
}

.album-thickness::before {
  content: '';
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.18) 0,
    rgba(255, 255, 255, 0.18) 4rpx,
    rgba(0, 0, 0, 0.04) 4rpx,
    rgba(0, 0, 0, 0.04) 6rpx
  );
  pointer-events: none;
}

.album-thickness::after {
  content: '';
  position: absolute;
  top: 8%;
  bottom: 8%;
  right: 2rpx;
  width: 2rpx;
  background: rgba(255, 255, 255, 0.45);
  border-radius: 2rpx;
}

.album-sheet {
  position: absolute;
  top: 6%;
  bottom: 6%;
  width: 4rpx;
  border-radius: 0 2rpx 2rpx 0;
  background: linear-gradient(180deg, #faf6ef, #e8e0d2);
  box-shadow: 2rpx 0 2rpx rgba(0, 0, 0, 0.06);
}

.album-sheet.s1 {
  left: 2rpx;
  opacity: 0.95;
}

.album-sheet.s2 {
  left: 6rpx;
  opacity: 0.85;
  background: linear-gradient(180deg, #f3ece2, #ddd4c6);
}

.album-sheet.s3 {
  left: 10rpx;
  opacity: 0.75;
  background: linear-gradient(180deg, #ebe3d5, #d4cbc0);
}

.album-sheet.s4 {
  left: 14rpx;
  opacity: 0.65;
  background: linear-gradient(180deg, #e2d9cc, #c9bfae);
}
