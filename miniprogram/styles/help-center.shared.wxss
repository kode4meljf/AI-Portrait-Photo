/* 帮助中心 v3 · 对齐照片墙 settings 精调字号 */
.help-page {
  min-height: 100vh;
  background: #f8f8f8;
}

.help-page .page-body {
  padding: 8rpx 0 calc(120rpx + env(safe-area-inset-bottom));
}

.help-tip {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
  padding: 20rpx 32rpx 8rpx;
}

.section-title {
  font-size: 22rpx;
  color: #c4c4c4;
  padding: 20rpx 32rpx 12rpx;
  font-weight: 400;
  letter-spacing: 0.03em;
}

.settings-card {
  background: #fff;
  overflow: hidden;
}

.item {
  display: flex;
  align-items: center;
  padding: 12rpx 32rpx;
  min-height: 88rpx;
  position: relative;
}

.item:active {
  background: #f5f5f5;
}

.item::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 96rpx;
  right: 32rpx;
  height: 1rpx;
  background: #f2f2f2;
}

.item:last-child::after {
  display: none;
}

.item-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.item-icon image {
  width: 36rpx;
  height: 36rpx;
}

.item-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 400;
  line-height: 1.25;
}

.item-value {
  font-size: 24rpx;
  color: #999;
  margin-right: 8rpx;
  max-width: 240rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-arrow {
  font-size: 28rpx;
  color: #d8d8d8;
  font-weight: 300;
  line-height: 1;
}

.version-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 32rpx;
}

.version-text {
  font-size: 22rpx;
  color: #c4c4c4;
  letter-spacing: 0.02em;
}

/* 关于 */
.about-page {
  min-height: 100vh;
  background: #f8f8f8;
}

.about-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 0 44rpx;
  background: #fff;
}

.about-logo {
  width: 104rpx;
  height: 104rpx;
  border-radius: 22rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(145deg, #1a1a2e, #0f3460);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #e8b86d;
  letter-spacing: 0.05em;
}

.about-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.about-ver {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.about-body {
  padding: 20rpx 24rpx;
}

.about-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
}

.about-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.65;
}

.about-kv {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f2f2f2;
  font-size: 26rpx;
  color: #333;
}

.about-kv:last-child {
  border-bottom: none;
}

.about-kv-val {
  color: #999;
  max-width: 360rpx;
  text-align: right;
}

.about-kv-tap:active {
  opacity: 0.7;
}

/* 意见反馈 */
.feedback-page {
  min-height: 100vh;
  background: #f8f8f8;
  padding: 24rpx;
  box-sizing: border-box;
}

.feedback-tip {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
  margin-bottom: 20rpx;
  padding: 0 4rpx;
}

.feedback-form {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx 32rpx;
}

.feedback-textarea {
  width: 100%;
  height: 216rpx;
  padding: 20rpx 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
  box-sizing: border-box;
  line-height: 1.55;
}

.feedback-input {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 24rpx;
  margin-top: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
  box-sizing: border-box;
}

.feedback-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #c4c4c4;
  margin-top: 8rpx;
}

.submit-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  margin-top: 64rpx;
  background: #1b1b1b;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 40rpx;
  text-align: center;
  border: none;
  padding: 0;
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  opacity: 0.85;
}

/* 协议 / 隐私 */
.doc-page {
  min-height: 100vh;
  background: #f8f8f8;
}

.doc-page .page-body {
  padding: 24rpx;
}

.doc-content {
  background: #fff;
  border-radius: 16rpx;
  padding: 36rpx 32rpx;
}

.doc-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 28rpx;
}

.doc-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.75;
  white-space: pre-wrap;
}
