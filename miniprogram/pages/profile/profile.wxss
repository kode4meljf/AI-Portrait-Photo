/* packageProfile/pages/profile/profile.wxss */
@import "../../styles/tab-bar.shared.wxss";

@import "../../styles/help-entry.shared.wxss";

.profile-container {
  background-color: #f3f4f6;
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding-bottom: calc(96rpx + env(safe-area-inset-bottom));
}

.scroll-area {
  flex: 1;
  overflow-y: auto;
}

/* 门店头部 */
.store-header {
  background: linear-gradient(145deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 88rpx 40rpx 112rpx;
  position: relative;
  overflow: hidden;
}

.store-header::before {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 320rpx;
  height: 320rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 50%;
  pointer-events: none;
}

.store-top {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 24rpx;
}

.store-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 28rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.store-avatar-img {
  width: 100%;
  height: 100%;
}

.store-avatar-emoji {
  width: 104rpx;
  height: 104rpx;
  background: linear-gradient(135deg, #e8b86d, #c9922a);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  flex-shrink: 0;
}

.store-info {
  flex: 1;
  min-width: 0;
}

.store-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.store-contact {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.55);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.store-contact .dot {
  width: 8rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.35);
  border-radius: 50%;
  flex-shrink: 0;
}

.store-address {
  background: rgba(255, 255, 255, 0.07);
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.45;
}

.addr-icon {
  font-size: 26rpx;
  flex-shrink: 0;
}

/* 会员权益卡 */
.balance-card {
  margin: -56rpx 32rpx 0;
  background: #fff;
  border-radius: 36rpx;
  padding: 36rpx 32rpx 32rpx;
  box-shadow: 0 20rpx 72rpx rgba(26, 26, 46, 0.12);
  position: relative;
  z-index: 10;
  border: 2rpx solid rgba(232, 184, 109, 0.25);
  overflow: hidden;
}

.balance-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 32rpx;
  right: 32rpx;
  height: 6rpx;
  border-radius: 0 0 8rpx 8rpx;
  background: linear-gradient(90deg, #e8b86d, #c9922a);
}

.balance-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32rpx;
  padding-top: 8rpx;
}

.balance-left .label {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 12rpx;
}

.balance-left .amount-row {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 0 8rpx;
  line-height: 1;
}

.balance-left .amount-prefix,
.balance-left .amount-suffix {
  font-size: 28rpx;
  font-weight: 400;
  color: #9ca3af;
}

.balance-left .amount-num {
  font-size: 72rpx;
  font-weight: 700;
  color: #1a1a2e;
  line-height: 1;
}

.level-badge {
  background: linear-gradient(135deg, #e8b86d, #c9922a);
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #fff;
  white-space: nowrap;
  flex-shrink: 0;
}

.quota-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.quota-item {
  flex: 1;
  background: #f8f9fb;
  border-radius: 24rpx;
  padding: 24rpx;
}

.q-label {
  font-size: 22rpx;
  color: #9ca3af;
  margin-bottom: 12rpx;
}

.q-val {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.q-val text {
  font-size: 22rpx;
  font-weight: 400;
  color: #9ca3af;
}

.progress-bar {
  height: 8rpx;
  background: #e5e7eb;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 4rpx;
  background: linear-gradient(90deg, #e8b86d, #c9922a);
}

.progress-fill-green {
  background: linear-gradient(90deg, #34d399, #10b981);
}

.recharge-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #e8b86d;
}

.recharge-btn:active {
  opacity: 0.88;
}

/* 门店工作台 */
.workspace {
  margin: 24rpx 32rpx 0;
  background: #fff;
  border-radius: 28rpx;
  padding: 24rpx 28rpx 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  position: relative;
  z-index: 2;
}

.ws-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.ws-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
}

.ws-hint {
  font-size: 22rpx;
  color: #9ca3af;
}

.ws-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8rpx;
}

.ws-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 4rpx;
  border-radius: 20rpx;
}

.ws-item-active {
  background: #f3f4f6;
}

.ws-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(26, 26, 46, 0.06);
}

.ws-icon::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  border: 2rpx solid rgba(255, 255, 255, 0.65);
  pointer-events: none;
}

.ws-icon.blue {
  background: linear-gradient(145deg, #eef4ff 0%, #d6e6ff 100%);
}

.ws-icon.purple {
  background: linear-gradient(145deg, #f5f0ff 0%, #e8dcff 100%);
}

.ws-icon.orange {
  background: linear-gradient(145deg, #fff7ed 0%, #ffe4c7 100%);
}

.ws-icon.green {
  background: linear-gradient(145deg, #ecfdf3 0%, #d1fae5 100%);
}

.ws-icon.teal {
  background: linear-gradient(145deg, #ecfeff 0%, #cffafe 100%);
}

.ws-icon-emoji {
  font-size: 36rpx;
  line-height: 1;
  position: relative;
  z-index: 1;
}

.ws-icon-img {
  width: 48rpx;
  height: 48rpx;
  position: relative;
  z-index: 1;
}

.ws-label {
  font-size: 20rpx;
  color: #6b7280;
  text-align: center;
  line-height: 1.2;
}

/* 数据看板 */
.section-header {
  padding: 32rpx 32rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.s-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.s-title::before {
  content: '';
  width: 6rpx;
  height: 26rpx;
  background: linear-gradient(180deg, #e8b86d, #c9922a);
  border-radius: 3rpx;
}

.s-more {
  font-size: 24rpx;
  color: #9ca3af;
}

.order-summary {
  margin: 0 32rpx;
  background: #fff;
  border-radius: 36rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 8rpx;
}

.summary-amount {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.amt-label {
  font-size: 24rpx;
  color: #9ca3af;
}

.amt-val {
  font-size: 56rpx;
  font-weight: 700;
  color: #1a1a2e;
  line-height: 1.1;
}

.category-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.cat-item {
  background: #f9fafb;
  border-radius: 20rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.cat-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.cat-icon.blue { background: #e8f0fe; }
.cat-icon.purple { background: #f3e8ff; }
.cat-icon.orange { background: #fff3e0; }
.cat-icon.green { background: #e8f5e9; }

.cat-info .cat-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  line-height: 1.2;
}

.cat-info .cat-name {
  font-size: 20rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

/* 打卡活跃 */
.checkin-card {
  margin: 0 32rpx 24rpx;
  background: #fff;
  border-radius: 36rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.checkin-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.checkin-item {
  flex: 1;
  border-radius: 24rpx;
  padding: 24rpx;
}

.checkin-item.yesterday {
  background: #f8fafc;
}

.checkin-item.today {
  background: #ecfdf5;
}

.ci-label {
  font-size: 22rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.ci-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a2e;
  line-height: 1;
}

.uncheckin-tip {
  background: #fffbeb;
  border: 2rpx solid #fde68a;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tip-left {
  font-size: 22rpx;
  color: #92400e;
}

.tip-left .bold {
  font-weight: 700;
}

.tip-right {
  font-size: 22rpx;
  color: #92400e;
  flex-shrink: 0;
}
