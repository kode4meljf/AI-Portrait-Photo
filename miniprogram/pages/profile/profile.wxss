/* packageProfile/pages/profile/profile.wxss */
@import "../../styles/tab-bar.shared.wxss";

@import "../../styles/help-entry.shared.wxss";

.profile-container {
  background-color: #f3f4f6;
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding-bottom: calc(96rpx + env(safe-area-inset-bottom));
}

.profile-container--locked {
  overflow: hidden;
  touch-action: none;
}

.scroll-area {
  flex: 1;
  overflow-y: auto;
}

/* 门店头部 · 方案 C 横版大牌面 */
.store-header {
  background: #0f1729;
  padding: 32rpx 32rpx 100rpx;
  position: relative;
  overflow: hidden;
}

.store-header-watermark {
  position: absolute;
  top: 16rpx;
  left: 24rpx;
  font-size: 104rpx;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.03);
  letter-spacing: 0.15em;
  line-height: 1;
  white-space: nowrap;
  pointer-events: none;
}

.store-header-inner {
  position: relative;
  z-index: 1;
}

.store-head-row {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  margin-bottom: 20rpx;
}

.store-main-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  margin-bottom: 24rpx;
  padding: 0 32rpx;
}

.store-footer-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 32rpx;
}

.store-divider {
  width: 160rpx;
  height: 4rpx;
  border-radius: 4rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(
    90deg,
    rgba(232, 184, 109, 0) 0%,
    rgba(232, 184, 109, 0.55) 35%,
    rgba(201, 146, 42, 0.75) 50%,
    rgba(232, 184, 109, 0.55) 65%,
    rgba(232, 184, 109, 0) 100%
  );
}

.store-address {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  gap: 8rpx;
  line-height: 1.55;
  max-width: 620rpx;
}

.store-address--plain {
  background: none;
  border-radius: 0;
  padding: 0;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
}

.addr-text {
  flex: 0 1 auto;
  text-align: center;
}

.addr-icon {
  font-size: 22rpx;
  flex-shrink: 0;
  line-height: 1.55;
}

.store-info {
  flex: 0 1 auto;
  min-width: 0;
  max-width: 460rpx;
}

.store-avatar {
  flex-shrink: 0;
  overflow: hidden;
}

.store-avatar--round {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  box-shadow:
    0 0 0 6rpx rgba(232, 184, 109, 0.35),
    0 16rpx 48rpx rgba(0, 0, 0, 0.3);
}

.store-avatar-img {
  width: 100%;
  height: 100%;
}

.store-avatar-emoji {
  width: 144rpx;
  height: 144rpx;
  background: linear-gradient(135deg, #e8b86d, #c9922a);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
}

.store-name--hero {
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1.15;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.store-contact {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.store-contact .dot {
  width: 8rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.35);
  border-radius: 50%;
  flex-shrink: 0;
}

/* 会员权益卡 */
.balance-card {
  margin: -56rpx 32rpx 0;
  background: #fff;
  border-radius: 36rpx;
  padding: 36rpx 32rpx 32rpx;
  box-shadow: 0 20rpx 72rpx rgba(26, 26, 46, 0.12);
  position: relative;
  z-index: 10;
  border: 2rpx solid rgba(232, 184, 109, 0.25);
  overflow: hidden;
}

.balance-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 32rpx;
  right: 32rpx;
  height: 6rpx;
  border-radius: 0 0 8rpx 8rpx;
  background: linear-gradient(90deg, #e8b86d, #c9922a);
}

.balance-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32rpx;
  padding-top: 8rpx;
}

.balance-left .label {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 12rpx;
}

.balance-left .amount-row {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 0 8rpx;
  line-height: 1;
}

.balance-left .amount-prefix,
.balance-left .amount-suffix {
  font-size: 28rpx;
  font-weight: 400;
  color: #9ca3af;
}

.balance-left .amount-num {
  font-weight: 700;
  color: #1a1a2e;
  line-height: 1;
}

.amount-num--lg {
  font-size: 72rpx;
}

.amount-num--md {
  font-size: 56rpx;
}

.amount-num--sm {
  font-size: 44rpx;
}

.level-badge {
  background: linear-gradient(135deg, #e8b86d, #c9922a);
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #fff;
  white-space: nowrap;
  flex-shrink: 0;
  box-shadow: 0 8rpx 24rpx rgba(201, 146, 42, 0.42), 0 2rpx 8rpx rgba(26, 26, 46, 0.12);
}

.level-badge--press {
  opacity: 0.92;
  transform: scale(0.97);
}

/* 约可兑换 · 方案 A 内缩 */
.use-panel {
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  padding: 20rpx 16rpx 24rpx;
  background: #f8f9fb;
}

.use-panel--inset-a {
  margin-left: -16rpx;
  margin-right: -16rpx;
}

.use-hd {
  font-size: 22rpx;
  font-weight: 400;
  color: #9ca3af;
  margin-bottom: 8rpx;
  padding: 0 8rpx 12rpx;
  border-bottom: 2rpx solid rgba(26, 26, 46, 0.025);
}

.use-row {
  display: flex;
  align-items: stretch;
  min-height: 120rpx;
}

.use-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 20rpx;
  padding: 16rpx 20rpx;
  min-height: 120rpx;
  box-sizing: border-box;
}

.use-item + .use-item {
  border-left: 2rpx solid rgba(26, 26, 46, 0.025);
}

.use-ico {
  font-size: 44rpx;
  line-height: 1;
  flex-shrink: 0;
  opacity: 0.92;
}

.use-body {
  text-align: left;
  min-width: 0;
  flex: 1;
}

.use-nm {
  font-size: 24rpx;
  color: #6b7280;
  font-weight: 500;
  line-height: 1.3;
  margin-bottom: 8rpx;
}

.use-cnt {
  font-size: 40rpx;
  font-weight: 700;
  color: #c9922a;
  line-height: 1.1;
}

.use-unit {
  font-size: 24rpx;
  font-weight: 600;
  color: #b8860b;
}

.recharge-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #e8b86d;
}

.recharge-btn:active {
  opacity: 0.88;
}

/* 门店工作台 */
.workspace {
  margin: 24rpx 32rpx 0;
  background: #fff;
  border-radius: 28rpx;
  padding: 24rpx 28rpx 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  position: relative;
  z-index: 2;
}

.ws-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.ws-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
}

.ws-hint {
  font-size: 22rpx;
  color: #9ca3af;
}

.ws-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8rpx;
}

.ws-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 4rpx;
  border-radius: 20rpx;
}

.ws-item-active {
  background: #f3f4f6;
}

.ws-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(26, 26, 46, 0.06);
}

.ws-icon::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  border: 2rpx solid rgba(255, 255, 255, 0.65);
  pointer-events: none;
}

.ws-icon.blue {
  background: linear-gradient(145deg, #eef4ff 0%, #d6e6ff 100%);
}

.ws-icon.purple {
  background: linear-gradient(145deg, #f5f0ff 0%, #e8dcff 100%);
}

.ws-icon.orange {
  background: linear-gradient(145deg, #fff7ed 0%, #ffe4c7 100%);
}

.ws-icon.green {
  background: linear-gradient(145deg, #ecfdf3 0%, #d1fae5 100%);
}

.ws-icon.teal {
  background: linear-gradient(145deg, #ecfeff 0%, #cffafe 100%);
}

.ws-icon-emoji {
  font-size: 36rpx;
  line-height: 1;
  position: relative;
  z-index: 1;
}

.ws-icon-img {
  width: 48rpx;
  height: 48rpx;
  position: relative;
  z-index: 1;
}

.ws-label {
  font-size: 20rpx;
  color: #6b7280;
  text-align: center;
  line-height: 1.2;
}

/* 数据看板 */
.section-header {
  padding: 32rpx 32rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.s-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.s-title::before {
  content: '';
  width: 6rpx;
  height: 26rpx;
  background: linear-gradient(180deg, #e8b86d, #c9922a);
  border-radius: 3rpx;
}

.s-more {
  font-size: 24rpx;
  color: #9ca3af;
}

.s-more--active {
  opacity: 0.55;
}

.order-summary {
  margin: 0 32rpx;
  background: #fff;
  border-radius: 36rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 8rpx;
}

.order-summary--active {
  opacity: 0.96;
  transform: scale(0.995);
}

.summary-amount {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.amt-label {
  font-size: 24rpx;
  color: #9ca3af;
}

.amt-val {
  font-size: 56rpx;
  font-weight: 700;
  color: #1a1a2e;
  line-height: 1.1;
}

.amt-val-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.amt-unit {
  font-size: 28rpx;
  font-weight: 500;
  color: #9ca3af;
}

.category-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.cat-item {
  background: #f9fafb;
  border-radius: 20rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.cat-item--active {
  background: #f3f4f6;
}

.cat-item--soon .cat-num,
.cat-item--soon .cat-name {
  color: #9ca3af;
}

.cat-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.cat-icon.blue { background: #e8f0fe; }
.cat-icon.purple { background: #f3e8ff; }
.cat-icon.orange { background: #fff3e0; }
.cat-icon.green { background: #e8f5e9; }

.cat-info .cat-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  line-height: 1.2;
}

.cat-info .cat-name {
  font-size: 20rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

/* 打卡活跃 */
.checkin-card {
  margin: 0 32rpx 24rpx;
  background: #fff;
  border-radius: 36rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.checkin-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.checkin-item {
  flex: 1;
  border-radius: 24rpx;
  padding: 24rpx;
}

.checkin-item.yesterday {
  background: #f8fafc;
}

.checkin-item.today {
  background: #ecfdf5;
}

.ci-label {
  font-size: 22rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.ci-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a2e;
  line-height: 1;
}

.ci-hint {
  font-size: 20rpx;
  color: #9ca3af;
  margin-top: 8rpx;
}

.uncheckin-tip {
  background: #fffbeb;
  border: 2rpx solid #fde68a;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tip-left {
  font-size: 22rpx;
  color: #92400e;
}

.tip-left .bold {
  font-weight: 700;
}

.tip-right {
  font-size: 22rpx;
  color: #92400e;
  flex-shrink: 0;
}

.price-mask {
  position: fixed;
  inset: 0;
  z-index: 300;
  background: rgba(0, 0, 0, 0.52);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 40rpx;
  box-sizing: border-box;
}

.price-modal {
  width: 100%;
  max-width: 620rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 36rpx 32rpx 28rpx;
  box-shadow: 0 24rpx 64rpx rgba(0, 0, 0, 0.2);
}

.price-modal-hd {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
  text-align: center;
  margin-bottom: 12rpx;
}

.price-modal-note {
  font-size: 22rpx;
  color: #9ca3af;
  text-align: center;
  line-height: 1.5;
  margin-bottom: 28rpx;
}

.price-list {
  border-radius: 20rpx;
  overflow: hidden;
  border: 2rpx solid #f0f0f0;
  margin-bottom: 28rpx;
}

.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 2rpx solid #f5f5f5;
  background: #fff;
}

.price-row:last-child {
  border-bottom: none;
}

.price-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
}

.price-pts {
  font-size: 30rpx;
  font-weight: 700;
  color: #c9922a;
}

.price-modal-btn {
  height: 84rpx;
  border-radius: 42rpx;
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  color: #e8b86d;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.price-modal-btn:active {
  opacity: 0.9;
}

/* 底部帮助与反馈 */
.footer-help {
  margin: 32rpx 32rpx 0;
  padding: 28rpx 0;
  border-top: 1rpx solid #e5e7eb;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.footer-help-text {
  font-size: 26rpx;
  color: #9ca3af;
  line-height: 1.2;
}

.footer-help-arrow {
  font-size: 26rpx;
  color: #d1d5db;
  line-height: 1;
}

.footer-help--active {
  opacity: 0.72;
}
