.container {
  background: #f5f5f5;
  min-height: 100vh;
  padding: 30rpx;
}

.date-header {
  background: #fff;
  padding: 30rpx;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  margin-bottom: 30rpx;
}

.customer-item {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #eee;
}

.info {
  flex: 1;
}

.name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
}

.phone {
  font-size: 24rpx;
  color: #999;
}

.checkin-count {
  font-size: 24rpx;
  color: #ff69b4;
}

.empty-tip, .loading-tip {
  text-align: center;
  padding: 60rpx;
  color: #999;
}