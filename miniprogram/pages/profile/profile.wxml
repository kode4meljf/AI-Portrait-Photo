<!--packageProfile/pages/profile/profile.wxml-->
<page-meta page-style="{{priceModalPageStyle}}" />
<view class="profile-container {{showPriceModal ? 'profile-container--locked' : ''}}">
  <scroll-view
    class="scroll-area"
    scroll-y="{{!showPriceModal}}"
    enhanced
    show-scrollbar="{{false}}"
    refresher-enabled="{{!showPriceModal}}"
    bindrefresherrefresh="onPullDownRefresh"
    refresher-triggered="{{refreshing}}"
  >

    <!-- 门店信息头部 · 方案 C 横版大牌面 -->
    <view class="store-header">
      <view class="store-header-inner">
        <view class="store-head-row" wx:if="{{isOwner}}">
          <view class="help-entry gold" bindtap="onEditStore" hover-class="none">
            <text class="help-entry-mark">✎</text>
            <text>编辑资料</text>
          </view>
        </view>
        <view class="store-main-row">
          <view wx:if="{{storeInfo.avatarUrl}}" class="store-avatar store-avatar--round" bindtap="previewStoreAvatar">
            <image class="store-avatar-img" src="{{storeInfo.avatarUrl}}" mode="aspectFill"></image>
          </view>
          <view wx:else class="store-avatar store-avatar--round store-avatar-emoji">🏪</view>
          <view class="store-info">
            <view class="store-name store-name--hero">{{storeInfo.name || 'AI写真馆'}}</view>
            <view class="store-contact">
              <text>{{storeInfo.contactName || '管理员'}}</text>
              <text class="dot"></text>
              <text>{{storeInfo.contactPhone || '未设置'}}</text>
            </view>
          </view>
        </view>
        <view class="store-footer-block">
          <view class="store-divider"></view>
          <view class="store-address store-address--plain">
            <text class="addr-icon">📍</text>
            <text class="addr-text">{{storeInfo.address || '暂无地址'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 1. 会员权益卡（主卡） -->
    <view class="balance-card">
      <view class="balance-top">
        <view class="balance-left">
          <view class="label">门店可用积分</view>
          <view class="amount-row" bindtap="onBalanceTap">
            <text class="amount-prefix">剩余</text>
            <text class="amount-num amount-num--{{balanceDisplay.size}}">{{balanceDisplay.text}}</text>
            <text class="amount-suffix">积分</text>
          </view>
        </view>
        <view class="level-badge" bindtap="onOpenPriceList" hover-class="level-badge--press" hover-stay-time="80">
          <text>{{storeInfo.level || '普通会员'}}</text>
        </view>
      </view>

      <view class="use-panel use-panel--inset-a">
        <view class="use-hd">约可兑换</view>
        <view class="use-row">
          <view class="use-item">
            <text class="use-ico">📸</text>
            <view class="use-body">
              <view class="use-nm">9 张写真</view>
              <view class="use-cnt">{{useGrid.shoot9Text}}<text class="use-unit"> 次</text></view>
            </view>
          </view>
          <view class="use-item">
            <text class="use-ico">🖼</text>
            <view class="use-body">
              <view class="use-nm">摆台相框</view>
              <view class="use-cnt">{{useGrid.frameText}}<text class="use-unit"> 个</text></view>
            </view>
          </view>
        </view>
      </view>

      <view class="recharge-btn" bindtap="onRecharge">
        <text>充值套餐 · 升级会员</text>
      </view>
    </view>

    <!-- 2. 门店工作台 -->
    <view class="workspace">
      <view class="ws-head">
        <text class="ws-title">门店工作台</text>
        <text class="ws-hint">常用管理</text>
      </view>
      <view class="ws-grid">
        <view class="ws-item" hover-class="ws-item-active" bindtap="onManageMembers">
          <view class="ws-icon orange">
            <image class="ws-icon-img" src="/assets/icons/ws-staff.svg" mode="aspectFit"></image>
          </view>
          <text class="ws-label">员工管理</text>
        </view>
        <view class="ws-item" hover-class="ws-item-active" bindtap="onViewAllCustomers">
          <view class="ws-icon green">
            <image class="ws-icon-img" src="/assets/icons/ws-customer-list.svg" mode="aspectFit"></image>
          </view>
          <text class="ws-label">客户列表</text>
        </view>
        <view class="ws-item" hover-class="ws-item-active" bindtap="onCreateCustomer">
          <view class="ws-icon purple">
            <image class="ws-icon-img" src="/assets/icons/ws-customer-add.svg" mode="aspectFit"></image>
          </view>
          <text class="ws-label">代客建档</text>
        </view>
        <view class="ws-item" hover-class="ws-item-active" bindtap="onCustomerInvite">
          <view class="ws-icon teal">
            <text class="ws-icon-emoji">🔗</text>
          </view>
          <text class="ws-label">邀请客户</text>
        </view>
      </view>
    </view>

    <!-- 3. 订单数据看板 -->
    <view class="section-header">
      <view class="s-title">订单数据看板</view>
      <view class="s-more" bindtap="onViewAllOrders" hover-class="s-more--active" hover-stay-time="80">查看全部 ›</view>
    </view>

    <view
      class="order-summary"
      bindtap="onViewAllOrders"
      hover-class="order-summary--active"
      hover-stay-time="80"
    >
      <view class="summary-amount">
        <text class="amt-label">本月累计订单</text>
        <view class="amt-val-row">
          <text class="amt-val">{{orderStats.monthOrderCount || 0}}</text>
          <text class="amt-unit">单</text>
        </view>
      </view>
      <view class="category-grid">
        <view
          class="cat-item"
          catchtap="onOrderCategoryTap"
          hover-class="cat-item--active"
          hover-stay-time="80"
          data-cat="frame"
        >
          <view class="cat-icon blue">🖼️</view>
          <view class="cat-info">
            <view class="cat-num">{{orderStats.categoryCount.frame || 0}}</view>
            <view class="cat-name">写真摆台</view>
          </view>
        </view>
        <view
          class="cat-item"
          catchtap="onOrderCategoryTap"
          hover-class="cat-item--active"
          hover-stay-time="80"
          data-cat="album"
        >
          <view class="cat-icon purple">📔</view>
          <view class="cat-info">
            <view class="cat-num">{{orderStats.categoryCount.album || 0}}</view>
            <view class="cat-name">写真集</view>
          </view>
        </view>
        <view
          class="cat-item cat-item--soon"
          catchtap="onOrderCategoryTap"
          hover-class="cat-item--active"
          hover-stay-time="80"
          data-cat="video"
        >
          <view class="cat-icon orange">🎬</view>
          <view class="cat-info">
            <view class="cat-num">0</view>
            <view class="cat-name">旅拍视频</view>
          </view>
        </view>
        <view
          class="cat-item cat-item--soon"
          catchtap="onOrderCategoryTap"
          hover-class="cat-item--active"
          hover-stay-time="80"
          data-cat="memoir"
        >
          <view class="cat-icon green">📖</view>
          <view class="cat-info">
            <view class="cat-num">0</view>
            <view class="cat-name">回忆录</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 4. 客户打卡活跃 -->
    <view class="section-header">
      <view class="s-title">客户打卡活跃</view>
      <view class="s-more" bindtap="onViewAllCustomers">详情 ›</view>
    </view>

    <view class="checkin-card">
      <view class="checkin-row">
        <view class="checkin-item yesterday" bindtap="onViewUncheckedYesterday">
          <view class="ci-label">昨日打卡</view>
          <view class="ci-num">{{checkinStats.yesterdayCount || 0}}</view>
          <view class="ci-hint">点击查看名单</view>
        </view>
        <view class="checkin-item today" bindtap="onViewCheckedToday">
          <view class="ci-label">今日打卡</view>
          <view class="ci-num">{{checkinStats.todayCount || 0}}</view>
          <view class="ci-hint">点击查看名单</view>
        </view>
      </view>
      <view class="uncheckin-tip" bindtap="onViewUncheckedToday">
        <view class="tip-left">
          <text>今日 <text class="bold">{{checkinStats.todayUnchecked || 0}}</text> 人尚未打卡</text>
        </view>
        <view class="tip-right">查看名单</view>
      </view>
    </view>

    <view class="footer-help" bindtap="onOpenHelp" hover-class="footer-help--active" hover-stay-time="80">
      <text class="footer-help-text">帮助与反馈</text>
      <text class="footer-help-arrow">›</text>
    </view>

    <view style="height: 40rpx;"></view>
  </scroll-view>
</view>

<view wx:if="{{showPriceModal}}" class="price-mask" catchtouchmove="preventMove" bindtap="onClosePriceList">
  <view class="price-modal" catchtap="onPriceModalTap">
    <view class="price-modal-hd">积分价目</view>
    <view class="price-modal-note">充值套餐含赠送积分，以下统一扣费</view>
    <view class="price-list">
      <view wx:for="{{priceList}}" wx:key="name" class="price-row">
        <text class="price-name">{{item.icon}} {{item.name}}</text>
        <text class="price-pts">{{item.pointsText}} 积分</text>
      </view>
    </view>
    <view class="price-modal-btn" bindtap="onClosePriceList">知道了</view>
  </view>
</view>

<privacy-popup />
