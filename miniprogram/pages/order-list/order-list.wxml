<!--packageOrder/pages/order-list/order-list.wxml-->
<view class="order-container">
  <!-- 可滚动内容区 -->
  <scroll-view class="scroll-area" scroll-y enhanced show-scrollbar="{{false}}" refresher-enabled="{{allowRefresh}}" bindrefresherrefresh="onScrollRefresh" refresher-triggered="{{refreshing}}">

    <!-- 统计概览（动态数据） -->
    <view class="stats-overview">
      <view class="stats-label">本月累计订单</view>
      <view class="stats-amount">
        <text>{{monthOrderCount}}</text>
        <text class="yuan">单</text>
      </view>
      <view class="stats-trend" wx:if="{{monthCompare}}">
        <text>{{monthCompare}}</text>
      </view>

      <view class="category-grid">
        <view class="cat-cell">
          <view class="cat-icon">🖼️</view>
          <view class="cat-num">{{categoryCount.frame}}</view>
          <view class="cat-name">写真摆台</view>
        </view>
        <view class="cat-cell">
          <view class="cat-icon">📔</view>
          <view class="cat-num">{{categoryCount.album}}</view>
          <view class="cat-name">写真集</view>
        </view>
        <view class="cat-cell">
          <view class="cat-icon">📷</view>
          <view class="cat-num">{{categoryCount.photo}}</view>
          <view class="cat-name">精修照片</view>
        </view>
        <view class="cat-cell">
          <view class="cat-icon">🎁</view>
          <view class="cat-num">{{categoryCount.other}}</view>
          <view class="cat-name">其他商品</view>
        </view>
      </view>
    </view>

    <!-- 订单Tab -->
    <view class="order-tabs">
      <view wx:for="{{tabs}}" wx:key="status" class="tab-item {{currentTab === item.status ? 'active' : ''}}" data-status="{{item.status}}" bindtap="switchTab">
        <text class="tab-label">{{item.name}}</text>
        <text class="tab-count">{{item.count}}</text>
      </view>
    </view>

    <!-- 订单列表（按月份分组） -->
    <view class="order-list" wx:if="{{orderGroups.length > 0}}">
      <block wx:for="{{orderGroups}}" wx:key="month">
        <!-- 月份分隔 + 月度汇总 -->
        <view class="month-divider">
          <text class="month-label">{{item.month}}</text>
          <view class="month-line"></view>
        </view>
        <view class="month-summary">
          <text class="ms-label">{{item.month}}累计订单</text>
          <view style="text-align:right">
            <text class="ms-amount">{{item.totalCount}} 单</text>
            <!-- 可选同比，暂不显示 -->
          </view>
        </view>

        <!-- 该月份下的订单卡片（方案 A：成片主导，点击卡片进详情） -->
        <view
          wx:for="{{item.orders}}"
          wx:for-item="order"
          wx:key="_id"
          class="order-card"
          bindtap="onOrderDetail"
          data-order="{{order}}"
          hover-class="order-card--hover"
          hover-stay-time="80"
        >
          <view class="order-photo-wrap">
            <image class="order-photo" src="{{order.photoThumb}}" mode="aspectFill" />
            <text class="order-photo-label">摆台预览</text>
          </view>
          <view class="order-main">
            <view class="order-top">
              <view class="order-head-text">
                <text class="order-no">{{order.orderNo}}</text>
                <text class="order-title">{{order.frameName || '写真摆台'}}</text>
              </view>
              <view class="order-status {{order.statusClass}}">{{order.statusText}}</view>
            </view>
            <view class="order-meta">
              <text wx:if="{{order.styleName}}" class="order-meta-line">风格 {{order.styleName}}</text>
              <text class="order-meta-line">客户 {{order.displayCustomerName}} · {{order.createTimeStr}}</text>
            </view>
            <view
              wx:if="{{order.showConfirmProduction || order.showViewLogistics || order.showConfirmReceipt}}"
              class="order-actions"
              catchtap="stopActionBubble"
            >
              <view
                wx:if="{{order.showConfirmProduction}}"
                class="action-btn primary"
                data-order="{{order}}"
                catchtap="onConfirmProduction"
              >确认制作</view>
              <view
                wx:if="{{order.showViewLogistics}}"
                class="action-btn secondary"
                data-order="{{order}}"
                catchtap="onViewLogistics"
              >查看物流</view>
              <view
                wx:if="{{order.showConfirmReceipt}}"
                class="action-btn secondary"
                data-order="{{order}}"
                catchtap="onConfirmReceipt"
              >确认签收</view>
            </view>
          </view>
        </view>
      </block>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!loading && orderGroups.length === 0}}" class="empty-tip">
      <text>暂无订单</text>
    </view>

    <!-- 加载更多 -->
    <view wx:if="{{loading}}" class="loading-tip">加载中...</view>
    <view wx:if="{{!hasMore && orderGroups.length > 0}}" class="no-more">没有更多了</view>
  </scroll-view>
</view>

<privacy-popup />