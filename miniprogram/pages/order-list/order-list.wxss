/* packageOrder/pages/order-list/order-list.wxss */
@import "../../styles/tab-bar.shared.wxss";

.order-container {
  background-color: #f5f5f5;
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding-bottom: calc(96rpx + env(safe-area-inset-bottom));
}

.scroll-area {
  flex: 1;
  height: 0;
  min-height: 0;
  box-sizing: border-box;
}

/* 统计概览 */
.stats-overview {
  background: linear-gradient(135deg, #1a1a2e, #16213e 50%, #0f3460 100%);
  padding: 40rpx 40rpx 56rpx;
  position: relative;
  overflow: hidden;
}
.stats-overview::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 50%;
}
.stats-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.55);
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}
.stats-amount {
  font-size: 72rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}
.stats-amount .yuan {
  font-size: 32rpx;
  color: rgba(255,255,255,0.6);
}
.stats-trend {
  font-size: 24rpx;
  color: #4ade80;
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 40rpx;
}
.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}
.cat-cell {
  background: rgba(255,255,255,0.08);
  border-radius: 20rpx;
  padding: 20rpx 12rpx;
  text-align: center;
}
.cat-cell .cat-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}
.cat-cell .cat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}
.cat-cell .cat-name {
  font-size: 20rpx;
  color: rgba(255,255,255,0.5);
  margin-top: 6rpx;
}

/* 订单Tab */
.order-tabs {
  background: #fff;
  padding: 24rpx 16rpx 0;
  display: flex;
  gap: 0;
  justify-content: space-between;
  border-bottom: 2rpx solid #f0f0f0;
}
.tab-item {
  flex: 1;
  min-width: 0;
  text-align: center;
  font-size: 26rpx;
  color: #999;
  padding: 16rpx 8rpx;
  position: relative;
  transition: color 0.2s, font-weight 0.2s, border-color 0.2s;
  border-bottom: 4rpx solid transparent;
  margin-bottom: -2rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  line-height: 1.2;
}
.tab-label {
  white-space: nowrap;
  word-break: keep-all;
}
.tab-item.active {
  font-size: 26rpx;
  color: #111;
  font-weight: 700;
  border-bottom-color: #1a1a2e;
}
.tab-item .tab-count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 32rpx;
  height: 32rpx;
  background: #f0f0f0;
  border-radius: 16rpx;
  font-size: 18rpx;
  color: #666;
  padding: 0 8rpx;
  margin-top: 6rpx;
}
.tab-item.active .tab-count {
  background: #1a1a2e;
  color: #fff;
}

@media (max-width: 360px) {
  .stats-overview {
    padding: 30rpx 28rpx 42rpx;
  }
  .stats-amount {
    font-size: 60rpx;
  }
  .stats-amount .yuan {
    font-size: 28rpx;
  }
  .stats-label,
  .stats-trend {
    font-size: 22rpx;
  }
  .category-grid {
    gap: 12rpx;
  }
  .cat-cell {
    border-radius: 16rpx;
    padding: 16rpx 8rpx;
  }
  .cat-cell .cat-icon {
    font-size: 34rpx;
  }
  .cat-cell .cat-num {
    font-size: 30rpx;
  }
  .cat-cell .cat-name {
    font-size: 18rpx;
  }
  .order-tabs {
    padding: 18rpx 10rpx 0;
  }
  .tab-item {
    font-size: 24rpx;
    padding: 12rpx 6rpx;
  }
  .tab-item.active {
    font-size: 24rpx;
  }
  .tab-item .tab-count {
    min-width: 28rpx;
    height: 28rpx;
    font-size: 16rpx;
    margin-top: 4rpx;
  }
  .order-list {
    padding: 18rpx 20rpx 36rpx;
    gap: 18rpx;
  }
  .order-card {
    border-radius: 24rpx;
  }
  .order-card {
    padding: 20rpx;
    gap: 20rpx;
  }
  .order-photo-wrap,
  .order-photo {
    width: 150rpx;
  }
  .order-photo {
    height: 188rpx;
  }
  .order-title {
    font-size: 28rpx;
  }
  .order-meta {
    font-size: 22rpx;
  }
}

/* 订单列表区域 */
.order-list {
  padding: 24rpx 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 月份分隔 */
.month-divider {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 0 8rpx;
}
.month-label {
  font-size: 24rpx;
  color: #aaa;
  font-weight: 600;
  white-space: nowrap;
}
.month-line {
  flex: 1;
  height: 2rpx;
  background: #e8e8e8;
}

/* 月度汇总 */
.month-summary {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  margin-bottom: 8rpx;
}
.ms-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a2e;
}
.ms-amount {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
}

/* 订单卡片 · 方案 A 成片主导 */
.order-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  gap: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.order-card--hover {
  opacity: 0.92;
}

.order-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.order-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.order-head-text {
  flex: 1;
  min-width: 0;
}

.order-no {
  display: block;
  font-size: 22rpx;
  color: #a1a1aa;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-no--copy:active {
  opacity: 0.65;
}

.order-title {
  display: block;
  margin-top: 6rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  line-height: 1.35;
}

.order-status {
  flex-shrink: 0;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 40rpx;
  font-weight: 500;
  line-height: 1.2;
}

.order-status.pending {
  background: #fff8f0;
  color: #e67e22;
}

.order-status.producing {
  background: #eff6ff;
  color: #2563eb;
}

.order-status.shipped {
  background: #f0fdf4;
  color: #22c55e;
}

.order-status.done {
  background: #f5f5f5;
  color: #888;
}

.order-meta {
  flex: 1;
  font-size: 24rpx;
  color: #52525b;
  line-height: 1.5;
}

.order-meta-line {
  display: block;
}

.order-meta-line + .order-meta-line {
  margin-top: 4rpx;
}

.order-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 14rpx 20rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  line-height: 1.2;
  box-sizing: border-box;
}

.action-btn.primary {
  background: #1a1a2e;
  color: #fff;
}

.action-btn.secondary {
  background: #f5f5f5;
  color: #52525b;
}

/* 空状态等 */
.empty-tip, .loading-tip, .no-more {
  text-align: center;
  padding: 120rpx;
  color: #999;
  font-size: 28rpx;
}