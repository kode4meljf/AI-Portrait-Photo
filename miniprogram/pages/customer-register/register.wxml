<view class="page page--invalid" wx:if="{{!loading && tokenInvalid}}">
  <view class="page-body">
    <view class="hero">
      <text class="hero-kicker">客户注册</text>
      <text class="hero-title">链接已失效</text>
      <text class="hero-sub">页面刷新后邀请信息会丢失，无法继续填写</text>
    </view>
    <view class="invalid-card" bindtap="onBlockedTap">
      <text class="invalid-icon">⌁</text>
      <text class="invalid-title">请重新扫描注册码</text>
      <text class="invalid-desc">使用门店提供的小程序码或邀请链接进入本页后再注册</text>
      <view class="invalid-btn" hover-class="invalid-btn--press">我知道了</view>
    </view>
  </view>
</view>

<view class="page" wx:elif="{{!loading}}">
  <view class="page-body">
    <view class="hero">
      <text class="hero-kicker">客户注册</text>
      <text class="hero-title">加入门店</text>
      <text class="hero-sub">授权手机号即可完成注册，用于到店打卡</text>
      <view
        wx:if="{{storeName}}"
        class="store-chip"
        hover-class="store-chip--press"
        hover-stay-time="80"
        bindtap="onStoreChipTap"
      >
        <text class="store-chip-icon">✦</text>
        <text class="store-chip-text">{{storeName}}</text>
        <text class="store-chip-arrow">›</text>
      </view>
    </view>

    <view class="form-card">
      <view class="avatar-row">
        <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" />
          <view wx:else class="avatar-placeholder">
            <text class="avatar-plus">+</text>
          </view>
        </button>
        <text class="avatar-hint">头像选填</text>
      </view>

      <view class="form-fields">
        <view class="field">
          <text class="label">昵称</text>
          <input
            class="input"
            type="nickname"
            placeholder="选填，点击可使用微信昵称"
            placeholder-class="input-ph"
            value="{{wxNickName}}"
            bindinput="onNicknameInput"
          />
        </view>

        <view class="field field--phone">
          <text class="label">手机号<text class="required">*</text></text>
          <button
            class="phone-btn {{phoneReady ? 'phone-btn--done' : ''}}"
            open-type="getPhoneNumber"
            bindgetphonenumber="onGetPhoneNumber"
          >
            {{phoneReady ? '已授权手机号' : '授权手机号'}}
          </button>
        </view>
      </view>

      <view class="card-submit-wrap">
        <button
          class="submit-btn {{submitting || !phoneReady ? 'submit-btn--disabled' : ''}}"
          disabled="{{submitting}}"
          bindtap="onSubmit"
        >
          {{submitting ? '提交中…' : '完成注册'}}
        </button>
      </view>
    </view>

    <view class="page-body-spacer"></view>
  </view>
</view>

<view wx:else class="loading-wrap">
  <text class="loading-tip">加载中…</text>
</view>

<view
  wx:if="{{storeInfoVisible}}"
  class="store-info-mask"
  bindtap="closeStoreInfo"
  catchtouchmove="preventTouchMove"
>
  <view class="store-info-dialog" catchtap="preventBubble">
    <text class="store-info-title">门店信息</text>
    <text class="store-info-sub">请确认是否为你要注册的门店</text>

    <view class="store-info-card">
      <view class="store-info-row store-info-row--main">
        <text class="store-info-k">店名</text>
        <text class="store-info-v store-info-v--name">{{storePreview.storeName}}</text>
      </view>
      <view class="store-info-row">
        <text class="store-info-k">联系人</text>
        <text class="store-info-v">{{storePreview.contactName}}</text>
      </view>
      <view class="store-info-row store-info-row--addr">
        <text class="store-info-k">地址</text>
        <text class="store-info-v store-info-v--addr">{{storePreview.address}}</text>
      </view>
    </view>

    <button
      class="store-info-close"
      hover-class="store-info-close--press"
      hover-stay-time="80"
      bindtap="closeStoreInfo"
    >知道了</button>
  </view>
</view>
