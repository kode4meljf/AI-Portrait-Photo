.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff5f9 0%, #f5f5f5 40%);
  padding: 48rpx 40rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.loading-tip {
  text-align: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
}

.hero {
  margin-bottom: 40rpx;
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.hero-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #888;
  line-height: 1.5;
}

.card {
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.06);
}

.avatar-row {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.avatar-img,
.avatar-placeholder {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  background: linear-gradient(135deg, #fce4ec, #f8bbd9);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #e91e8c;
}

.avatar-hint {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #aaa;
}

.field-hint {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #a1a1aa;
  line-height: 1.45;
}

.field {
  margin-bottom: 28rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.required {
  color: #e91e8c;
}

.input {
  height: 88rpx;
  padding: 0 24rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.phone-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0;
  margin: 0;
}

.phone-btn::after {
  border: none;
}

.phone-btn--done {
  background: #ecfdf5;
  color: #047857;
  border: 2rpx solid #a7f3d0;
}

.submit-btn {
  margin-top: 48rpx;
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #ff69b4, #e91e8c);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  padding: 0;
}

.submit-btn::after {
  border: none;
}

.submit-btn--disabled {
  opacity: 0.45;
}
