/* pages/launch/launch.wxss — 方案2 暖杏纸感（尺寸对齐 launch-light-options.html v2） */
/*
 * 设计稿基准：phone 300px，phone-inner padding 48/20/24px
 * 卡片：padding 14×16px，圆角 14px，间距 10px，图标 40×40px
 * 小程序换算：mockup 1px ≈ 2rpx（375 宽屏）
 */

.launch-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff9f5 0%, #faf6f0 100%);
}

.launch-safe {
  min-height: 100vh;
  /* 设计稿左右 20px → 40rpx，保证卡片横向占比与稿一致 */
  padding: 24rpx 40rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.brand {
  text-align: center;
  margin-bottom: 56rpx;
}

.logo-ring {
  /* 设计稿 logo 72px */
  width: 144rpx;
  height: 144rpx;
  margin: 0 auto 28rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border: 2rpx solid #f0e6d8;
  box-shadow: 0 16rpx 48rpx rgba(201, 146, 42, 0.12);
}

.logo-img {
  width: 104rpx;
  height: 104rpx;
}

.brand-cn {
  font-size: 44rpx;
  font-weight: 700;
  color: #3d3429;
  letter-spacing: 0.08em;
}

.brand-tag {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #9a8b7a;
  line-height: 1.5;
}

.role-section {
  flex: 1;
  width: 100%;
}

.section-label {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 28rpx;
  font-size: 22rpx;
  color: #c4a882;
  letter-spacing: 0.2em;
}

.label-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, #e8dcc8, transparent);
}

/* 横向通栏、扁比例：14px 上下 + 16px 左右 */
.entry-card {
  display: flex;
  align-items: center;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 20rpx;
  padding: 28rpx 32rpx;
  border-radius: 28rpx;
  background: #fff;
  border: 2rpx solid #f0e8dc;
}

.entry-card--active {
  background: #fffcf9;
  border-color: #e8b86d;
  box-shadow: 0 8rpx 32rpx rgba(201, 146, 42, 0.1);
}

/* 设计稿 card-icon 40×40，圆角 12px */
.entry-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  background: #faf6f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.entry-icon--muted {
  background: #faf6f0;
}

/* 设计稿 card-body 左右 padding 12px */
.entry-body {
  flex: 1;
  min-width: 0;
  padding: 0 24rpx;
}

/* 设计稿 title 15px / sub 11px，单行不换行 */
.entry-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  line-height: 1.25;
  white-space: nowrap;
}

.entry-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #9a8b7a;
  line-height: 1.25;
  white-space: nowrap;
}

.entry-arrow {
  font-size: 40rpx;
  color: #c4a882;
  font-weight: 300;
  line-height: 1;
  flex-shrink: 0;
}

/* 设计稿 customer padding 12×14px */
.customer-strip {
  display: flex;
  align-items: center;
  width: 100%;
  box-sizing: border-box;
  margin-top: 8rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.8);
  border: 1rpx solid #f0e6d8;
}

.customer-strip:active {
  opacity: 0.9;
}

.customer-icon {
  font-size: 28rpx;
  color: #c9922a;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.customer-text {
  flex: 1;
  min-width: 0;
}

.customer-title {
  display: block;
  font-size: 26rpx;
  color: #3d3429;
  font-weight: 500;
  white-space: nowrap;
}

.customer-sub {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #9a8b7a;
  white-space: nowrap;
}

.customer-link {
  font-size: 24rpx;
  color: #c9922a;
  flex-shrink: 0;
}

.state-block {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 80rpx 24rpx;
}

.loader-ring {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 4rpx solid #f0e6d8;
  border-top-color: #c9922a;
  animation: spin 0.9s linear infinite;
  margin-bottom: 32rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.state-text {
  font-size: 28rpx;
  color: #9a8b7a;
}

.pending-badge {
  padding: 8rpx 28rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #c9922a;
  background: rgba(232, 184, 109, 0.15);
  border: 1rpx solid #e8b86d;
  margin-bottom: 32rpx;
}

.pending-badge--rejected {
  color: #b45309;
  background: rgba(254, 226, 226, 0.9);
  border-color: #fecaca;
}

.pending-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #3d3429;
  margin-bottom: 20rpx;
}

.pending-desc {
  font-size: 28rpx;
  color: #9a8b7a;
  line-height: 1.65;
  max-width: 560rpx;
  margin-bottom: 48rpx;
  text-align: center;
}

.state-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  width: 100%;
  max-width: 560rpx;
}

.state-actions .btn-gold {
  width: 100%;
}

.btn-ghost {
  width: 100%;
  min-width: 320rpx;
  height: 80rpx;
  padding: 0;
  margin: 0;
  border: none;
  border-radius: 40rpx;
  background: transparent;
  color: #9a8b7a;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.btn-ghost::after {
  border: none;
}

.btn-gold {
  min-width: 320rpx;
  height: 88rpx;
  padding: 0;
  margin: 0;
  border: none;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #e8b86d, #c9922a);
  color: #3d3429;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
  box-shadow: 0 12rpx 40rpx rgba(201, 146, 42, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.btn-gold::after {
  border: none;
}

@media (max-width: 360px) {
  .launch-safe {
    padding-left: 32rpx;
    padding-right: 32rpx;
  }

  .brand-cn {
    font-size: 40rpx;
  }

  .entry-title {
    font-size: 28rpx;
  }

  .entry-sub {
    font-size: 20rpx;
  }
}
