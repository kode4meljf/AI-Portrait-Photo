/* pages/launch/create-store.wxss — 方案2 暖杏纸感；页面级滚动（真机兼容） */
.create-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #fff9f5 0%, #faf6f0 100%);
}

.create-page-body {
  width: 100%;
}

.page-foot {
  height: 1rpx;
}

.section-card {
  background: #fff;
  margin: 24rpx 30rpx 0;
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid #f0e8dc;
}

.section-header {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #f0e8dc;
}

.section-header-no-border {
  border-bottom: none;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #3d3429;
}

.required {
  color: #e91e8c;
  margin-left: 4rpx;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  min-height: 96rpx;
  box-sizing: border-box;
}

.info-label {
  font-size: 28rpx;
  color: #9a8b7a;
  width: 180rpx;
  flex-shrink: 0;
}

.info-input {
  flex: 1;
  width: 100%;
  min-width: 0;
  font-size: 30rpx;
  color: #3d3429;
  text-align: right;
  line-height: 1.4;
}

.info-divider {
  height: 1rpx;
  background: #f0e8dc;
  margin: 0 32rpx;
}

.address-section-card {
  padding-bottom: 8rpx;
}

.address-panel {
  margin: 0 16rpx 16rpx;
  min-height: 120rpx;
  border-radius: 16rpx;
  background: #fff;
  border: 2rpx solid #e8b86d;
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  gap: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(201, 146, 42, 0.08);
}

.address-panel:active {
  opacity: 0.85;
  background: #fffcf9;
}

.address-side-label {
  width: 80rpx;
  font-size: 28rpx;
  color: #9a8b7a;
  flex-shrink: 0;
}

.address-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 6rpx;
}

.address-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #3d3429;
  line-height: 1.35;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.address-title.placeholder {
  color: #c4a882;
  font-weight: 400;
}

.address-sub {
  font-size: 24rpx;
  color: #9a8b7a;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.address-arrow {
  font-size: 44rpx;
  color: #c4a882;
  line-height: 1;
  transform: rotate(180deg);
  flex-shrink: 0;
}

.info-row-address {
  align-items: center;
}

.address-field {
  flex: 1;
  min-width: 0;
}

.info-input-address {
  width: 100%;
  text-align: left;
  box-sizing: border-box;
}

.btn-wrap {
  padding: 40rpx 30rpx 0;
}

.submit {
  width: 100%;
  height: 96rpx;
  padding: 0;
  margin: 0;
  border: none;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #f0cc72 0%, #e8b86d 42%, #c9922a 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 0.06em;
  line-height: 1;
  box-shadow:
    0 4rpx 12rpx rgba(201, 146, 42, 0.22),
    0 12rpx 32rpx rgba(201, 146, 42, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  transition: transform 0.12s ease, opacity 0.12s ease, box-shadow 0.12s ease;
}

.submit::after {
  border: none;
}

/* 按压态：hover-class 由基础库在按下时挂载 */
.submit--active {
  opacity: 0.92;
  transform: scale(0.985);
  box-shadow:
    0 2rpx 8rpx rgba(201, 146, 42, 0.2),
    0 6rpx 20rpx rgba(201, 146, 42, 0.14);
}

.submit[loading],
.submit[disabled] {
  opacity: 0.65;
  color: rgba(255, 255, 255, 0.92);
  transform: none;
}
