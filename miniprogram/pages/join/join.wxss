/* 对齐 launch 暖杏纸感 + V2 金渐变主按钮 */
.join-page {
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  padding: 24rpx 40rpx calc(40rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #fff9f5 0%, #faf6f0 100%);
}

.join-hero {
  text-align: center;
  padding: 16rpx 0 40rpx;
}

.join-hero-icon {
  width: 112rpx;
  height: 112rpx;
  margin: 0 auto 24rpx;
  border-radius: 32rpx;
  background: #fff;
  border: 2rpx solid #f0e6d8;
  box-shadow: 0 16rpx 48rpx rgba(201, 146, 42, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

.join-hero-img {
  width: 56rpx;
  height: 56rpx;
}

.join-hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #3d3429;
  letter-spacing: 0.04em;
}

.join-hero-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #9a8b7a;
  line-height: 1.5;
}

.join-card {
  background: #fff;
  border-radius: 28rpx;
  border: 1rpx solid #f0e8dc;
  padding: 32rpx 28rpx 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(61, 52, 41, 0.04);
}

.field {
  margin-bottom: 24rpx;
}

.join-card .btn-secondary {
  margin-top: 28rpx;
}

.required {
  color: #e91e8c;
  margin-left: 4rpx;
}

.field-hint {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #c4a882;
  line-height: 1.45;
}

.phone-field .phone-btn {
  width: 100%;
  height: 88rpx;
  margin: 0;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background: #fff;
  border: 2rpx solid #e8dcc8;
  font-size: 28rpx;
  color: #c9922a;
  font-weight: 500;
  line-height: 1.2;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.phone-field .phone-btn::after {
  border: none;
}

.phone-btn--done {
  color: #3d3429;
  border-color: #e8b86d;
  background: #fffcf9;
}

.phone-btn--press {
  opacity: 0.88;
  background: #fffcf9;
}

.phone-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  padding: 18rpx 24rpx;
  border-radius: 12rpx;
  background: #fffcf9;
  border: 1rpx solid #f0e6d8;
}

.phone-display-label {
  font-size: 26rpx;
  color: #9a8b7a;
}

.phone-display-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #3d3429;
  letter-spacing: 0.04em;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #9a8b7a;
  margin-bottom: 12rpx;
}

/* 方案 B：扫码图标在输入框内部右侧 */
.input-shell {
  position: relative;
  width: 100%;
  height: 88rpx;
  border-radius: 16rpx;
  background: #faf6f0;
  border: 1rpx solid #f0e8dc;
  overflow: hidden;
  box-sizing: border-box;
}

.input-shell__field {
  width: 100%;
  height: 88rpx;
  padding: 0 96rpx 0 24rpx;
  box-sizing: border-box;
  border: none;
  background: transparent;
  font-size: 30rpx;
  color: #3d3429;
}

.input-shell__scan {
  position: absolute;
  right: 8rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
}

.input-shell__scan--press {
  background: rgba(201, 146, 42, 0.08);
}

.input-shell__scan-icon {
  width: 36rpx;
  height: 36rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: #faf6f0;
  border: 1rpx solid #f0e8dc;
  font-size: 30rpx;
  color: #3d3429;
}

.input-placeholder {
  color: #c4b5a5;
  font-size: 28rpx;
}

.join-hint {
  margin-top: 32rpx;
  text-align: center;
  font-size: 24rpx;
  color: #c4a882;
  line-height: 1.5;
}

/* 门店预览遮罩 */
.preview-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1000;
  background: rgba(61, 52, 41, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 40rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.preview-dialog {
  width: 100%;
  max-width: 640rpx;
  background: #fff;
  border-radius: 28rpx;
  border: 1rpx solid #f0e8dc;
  padding: 40rpx 32rpx 32rpx;
  box-shadow: 0 24rpx 64rpx rgba(61, 52, 41, 0.18);
  box-sizing: border-box;
}

.preview-dialog-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #3d3429;
  text-align: center;
}

.preview-dialog-sub {
  display: block;
  margin-top: 12rpx;
  margin-bottom: 28rpx;
  font-size: 26rpx;
  color: #9a8b7a;
  text-align: center;
  line-height: 1.45;
}

.preview-info-card {
  background: #fffcf9;
  border: 1rpx solid #f0e6d8;
  border-radius: 20rpx;
  padding: 8rpx 24rpx;
  margin-bottom: 20rpx;
}

.preview-row {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5efe6;
}

.preview-row:last-child {
  border-bottom: none;
}

.preview-row-main {
  padding-top: 24rpx;
  padding-bottom: 24rpx;
}

.preview-k {
  flex-shrink: 0;
  width: 140rpx;
  font-size: 26rpx;
  color: #9a8b7a;
  line-height: 1.4;
}

.preview-v {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: #3d3429;
  line-height: 1.45;
  word-break: break-all;
}

.preview-v-name {
  font-size: 32rpx;
  font-weight: 600;
}

.preview-v-addr {
  font-size: 26rpx;
  color: #6b5f52;
}

.preview-applicant {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding: 18rpx 24rpx;
  border-radius: 16rpx;
  background: #faf6f0;
  border: 1rpx solid #f0e6d8;
}

.preview-applicant-line {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.preview-applicant-k {
  flex-shrink: 0;
  width: 120rpx;
  font-size: 26rpx;
  color: #9a8b7a;
}

.preview-applicant-v {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #3d3429;
}

.preview-expire {
  display: block;
  margin-bottom: 28rpx;
  font-size: 22rpx;
  color: #c4a882;
  text-align: center;
  line-height: 1.4;
}

.preview-btn-primary {
  margin-bottom: 16rpx;
}

.btn-ghost {
  height: 88rpx;
  border-radius: 44rpx;
  background: transparent;
  color: #9a8b7a;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-ghost--press {
  opacity: 0.75;
  background: #faf6f0;
}

.btn {
  width: 100%;
  margin: 0;
  padding: 0;
  border: none;
  font-weight: 600;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn::after {
  border: none;
}

.btn-secondary {
  height: 88rpx;
  border-radius: 44rpx;
  background: #fff;
  color: #c9922a;
  font-size: 30rpx;
  border: 2rpx solid #e8dcc8;
  box-shadow: 0 2rpx 8rpx rgba(201, 146, 42, 0.06);
}

.btn-secondary--press {
  opacity: 0.88;
  transform: scale(0.985);
  background: #fffcf9;
}

.btn-primary {
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  color: #fff;
  letter-spacing: 0.06em;
  background: linear-gradient(135deg, #f0cc72 0%, #e8b86d 42%, #c9922a 100%);
  box-shadow:
    0 4rpx 12rpx rgba(201, 146, 42, 0.22),
    0 12rpx 32rpx rgba(201, 146, 42, 0.18);
}

.btn-primary--press {
  opacity: 0.92;
  transform: scale(0.985);
  box-shadow:
    0 2rpx 8rpx rgba(201, 146, 42, 0.2),
    0 6rpx 20rpx rgba(201, 146, 42, 0.14);
}

.btn-primary[disabled] {
  opacity: 0.65;
  color: rgba(255, 255, 255, 0.92);
}
