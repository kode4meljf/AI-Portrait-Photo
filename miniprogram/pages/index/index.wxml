<!--pages/index/index.wxml-->
<page-meta page-style="{{pickerVisible ? 'overflow: hidden;' : ''}}" />
<view class="phone-container">
  <scroll-view
    class="scroll-area"
    scroll-y="{{!pickerVisible}}"
    show-scrollbar="{{false}}"
    lower-threshold="120"
    bindscrolltolower="onShowcaseScrollLower"
  >
    <view class="scroll-inner">
      <view class="home-header">
        <view class="header-row">
          <view wx:if="{{storeInfo.avatarUrl}}" class="store-avatar store-avatar--image">
            <image class="store-avatar-img" src="{{storeInfo.avatarUrl}}" mode="aspectFill" />
          </view>
          <view wx:else class="store-avatar store-avatar--emoji">🏪</view>
          <view>
            <view class="store-name">{{storeInfo.name || '光影时代写真馆'}}</view>
            <view class="store-sub">欢迎使用 AI 写真服务</view>
          </view>
        </view>
        <view class="quick-stats">
          <view class="stat-chip">今日到店 <text class="val">{{todayVisitCount}}</text> 人</view>
          <view class="stat-chip">剩余积分 <text class="val">{{storeInfo.balance || 0}}</text></view>
        </view>
      </view>

      <!-- 拍摄区 -->
      <view class="shoot-section">
        <view class="shoot-card">
          <view class="shoot-hero-wrap">
            <image
              class="shoot-hero-img"
              src="/assets/icons/shoot-hero.svg"
              mode="aspectFit"
            />
          </view>
          <view class="shoot-title">立即拍摄写真</view>
          <view class="shoot-sub">拍摄正面照，AI 生成 3 / 9 张风格写真</view>
          <view class="shoot-actions">
            <button class="btn-shoot" bindtap="chooseMedia">▶ 开始拍摄</button>
            <view wx:if="{{hasLinkedCustomer}}" class="linked-customer-row">
              <text class="linked-status">✓ 已关联：{{linkedCustomerName}}</text>
              <view class="linked-actions">
                <view class="btn-change" bindtap="onLinkCustomer">更换</view>
                <text class="link-unlink" catchtap="onUnlinkCustomer">取消关联</text>
              </view>
            </view>
            <button wx:else class="btn-link-customer" bindtap="onLinkCustomer">
              <image class="btn-link-icon" src="/assets/icons/ws-customer-add.svg" mode="aspectFit" />
              <text>关联客户（可选）</text>
            </button>
          </view>
          <view class="shoot-tip-hint" wx:if="{{!hasLinkedCustomer}}">
            未关联也可拍摄选风格；生成写真前需选择客户
          </view>
        </view>
      </view>

      <!-- 打卡主卡片 -->
      <view class="checkin-hero">
        <view class="section-tag">今日服务</view>
        <view class="checkin-hero-title">客户到店打卡</view>

        <view class="checkin-hint">扫描客户小程序打卡码，自动关联客户并记录到店</view>
        <button class="btn-scan" bindtap="onCheckinTap">
          {{checkinResult ? '📷 继续打卡' : '📷 扫码打卡'}}
        </button>
        <view class="link-row">
          <text class="link-item" bindtap="onCustomerInvite">邀请客户</text>
          <text class="link-item" bindtap="onCreateCustomer">代客建档</text>
        </view>
        <view wx:if="{{checkinResult}}" class="checkin-result-card">
          <image
            class="customer-avatar"
            src="{{checkinResult.avatarUrl || '/assets/icons/album-placeholder.png'}}"
            mode="aspectFill"
            bindtap="previewAvatar"
          />
          <view class="customer-detail">
            <text class="customer-name">{{checkinResult.displayName || '匿名用户'}}<text class="customer-gender">{{checkinResult.genderLabel}}</text></text>
            <text class="customer-meta">{{checkinResult.phoneMasked}} · {{checkinResult.timeText}}</text>
            <view class="checkin-badge">✅ 今日已打卡 · 总计 {{checkinResult.totalCheckins || 0}} 次</view>
          </view>
        </view>
      </view>

      <style-showcase-home
        class="index-showcase"
        templates="{{templates}}"
        title="风格样板展示"
        loading="{{templatesLoading}}"
        loading-more="{{templatesLoadingMore}}"
        has-more="{{templatesHasMore}}"
        bind:preview="onPreviewTemplate"
      />
    </view>
  </scroll-view>

  <customer-picker
    visible="{{pickerVisible}}"
    selectedId="{{pickerSelectedId}}"
    bind:select="onPickerSelect"
    bind:close="onPickerClose"
    bind:customerUpdated="onPickerCustomerUpdated"
  />
</view>

<privacy-popup />
