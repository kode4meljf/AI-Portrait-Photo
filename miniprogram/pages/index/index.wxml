<!--pages/index/index.wxml-->
<page-meta page-style="{{pickerVisible ? 'overflow: hidden;' : ''}}" />
<view class="phone-container">
  <scroll-view class="scroll-area" scroll-y="{{!pickerVisible}}" show-scrollbar="{{false}}">
    <view class="scroll-inner">
      <view class="home-header">
        <view class="header-row">
          <view class="store-avatar">🏪</view>
          <view>
            <view class="store-name">{{storeInfo.name || '光影时代写真馆'}}</view>
            <view class="store-sub">欢迎使用 AI 写真服务</view>
          </view>
        </view>
        <view class="quick-stats">
          <view class="stat-chip">今日到店 <text class="val">{{todayVisitCount}}</text> 人</view>
          <view class="stat-chip">剩余额度 <text class="val">{{storeInfo.balance || 0}}</text> 次</view>
        </view>
      </view>

      <!-- 打卡主卡片 -->
      <view class="checkin-hero">
        <view class="section-tag">今日服务</view>
        <view class="checkin-hero-title">客户到店打卡</view>

        <block wx:if="{{!checkinResult}}">
          <view class="checkin-hint">扫描客户小程序打卡码，自动关联客户并记录到店</view>
          <button class="btn-scan" bindtap="onCheckinTap">📷 扫码打卡</button>
          <view class="link-row link-row--single">
            <text class="link-item" bindtap="onCreateCustomer">代客建档</text>
          </view>
        </block>

        <block wx:else>
          <view class="checkin-result-card">
            <image
              class="customer-avatar"
              src="{{checkinResult.avatarUrl || '/assets/icons/album-placeholder.png'}}"
              mode="aspectFill"
              bindtap="previewAvatar"
            />
            <view class="customer-detail">
              <text class="customer-name">{{checkinResult.displayName || '匿名用户'}}</text>
              <text class="customer-meta">{{checkinResult.phone || '未绑定手机'}} · {{checkinResult.timeText}}</text>
              <view class="checkin-badge">✅ 今日已打卡 · 累计 {{checkinResult.totalCheckins || 0}} 次</view>
            </view>
          </view>
          <view class="link-row">
            <text class="link-item" bindtap="onCreateCustomer">代客建档</text>
            <text class="link-item" bindtap="onContinueCheckin">继续打卡</text>
          </view>
        </block>
      </view>

      <!-- 拍摄区 -->
      <view class="shoot-section">
        <view class="shoot-card">
          <view class="shoot-hero-wrap">
            <image
              class="shoot-hero-img"
              src="/assets/icons/shoot-hero.svg"
              mode="aspectFit"
            />
          </view>
          <view class="shoot-title">立即拍摄写真</view>
          <view class="shoot-sub" wx:if="{{!hasLinkedCustomer}}">
            拍摄正面照，AI 生成 3 / 9 张风格写真
          </view>

          <view wx:if="{{hasLinkedCustomer}}" class="linked-customer-card">
            <image
              wx:if="{{linkedCustomerAvatar}}"
              class="linked-avatar"
              src="{{linkedCustomerAvatar}}"
              mode="aspectFill"
            />
            <view wx:else class="linked-avatar linked-avatar--placeholder">
              <text>{{linkedCustomerInitial}}</text>
            </view>
            <view class="linked-info">
              <text class="linked-label">拍摄客户</text>
              <text class="linked-name">{{linkedCustomerName}}</text>
            </view>
            <view class="linked-actions">
              <text class="link-change" bindtap="onLinkCustomer">更换</text>
              <text class="link-unlink" catchtap="onUnlinkCustomer">取消关联</text>
            </view>
          </view>

          <view class="shoot-actions">
            <button class="btn-shoot" bindtap="chooseMedia">▶ 开始拍摄</button>
            <button
              wx:if="{{!hasLinkedCustomer}}"
              class="btn-link-customer"
              bindtap="onLinkCustomer"
            >
              <image class="btn-link-icon" src="/assets/icons/ws-customer-add.svg" mode="aspectFit" />
              <text>关联客户（可选）</text>
            </button>
          </view>
          <view class="shoot-tip-hint" wx:if="{{!hasLinkedCustomer}}">
            未关联也可拍摄选风格；生成写真前需选择客户
          </view>
          <view class="shoot-tip-hint shoot-tip-hint--linked" wx:else>
            成片将保存至该客户相册
          </view>
        </view>
      </view>

      <view class="showcase-section">
        <view class="section-header" style="padding: 0 0 10rpx;">
          <view class="s-title">风格样板展示</view>
          <view class="s-more" bindtap="onMoreTemplates">更多 ›</view>
        </view>
        <view class="showcase-grid">
          <block wx:for="{{templates}}" wx:key="id">
            <view class="showcase-item" bindtap="previewTemplate" data-index="{{index}}">
              <image src="{{item.sampleDisplayUrl || item.sampleFileId}}" mode="aspectFill"></image>
              <view class="showcase-label">{{item.name}}</view>
            </view>
          </block>
        </view>
      </view>
    </view>
  </scroll-view>

  <customer-picker
    visible="{{pickerVisible}}"
    selectedId="{{pickerSelectedId}}"
    bind:select="onPickerSelect"
    bind:close="onPickerClose"
    bind:customerUpdated="onPickerCustomerUpdated"
  />
</view>
