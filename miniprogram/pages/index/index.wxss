/* pages/index/index.wxss */
@import "../../styles/tab-bar.shared.wxss";

page {
  height: 100%;
  box-sizing: border-box;
  background-color: #f5f5f5;
}

.phone-container {
  background-color: #f5f5f5;
  height: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding-bottom: calc(96rpx + env(safe-area-inset-bottom));
}

.scroll-area {
  flex: 1;
  height: 0;
  min-height: 0;
  width: 100%;
  box-sizing: border-box;
  background-color: #f5f5f5;
}

.scroll-inner {
  background-color: #f5f5f5;
  box-sizing: border-box;
  min-height: 100%;
  padding-bottom: 24rpx;
}

/* 头部 */
.home-header {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 32rpx 40rpx 48rpx;
  position: relative;
  overflow: hidden;
}
.home-header::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 50%;
}
.home-header::after {
  content: '';
  position: absolute;
  bottom: -20rpx;
  left: -20rpx;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255,255,255,0.03);
  border-radius: 50%;
}

.header-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 28rpx;
}
.store-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #e8b86d, #c9922a);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 6rpx 20rpx rgba(232,184,109,0.35);
}
.store-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}
.store-sub {
  font-size: 22rpx;
  color: rgba(255,255,255,0.55);
  margin-top: 4rpx;
}

.quick-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  position: relative;
  z-index: 1;
}
.stat-chip {
  background: rgba(255,255,255,0.1);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 40rpx;
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}
.stat-chip .val {
  color: #e8b86d;
  font-weight: 700;
}

/* 打卡主卡片（与顶栏统计分开，避免负 margin 压住「今日到店/剩余额度」） */
.checkin-hero {
  margin: 24rpx 32rpx 0;
  background: #fff;
  border-radius: 40rpx;
  padding: 40rpx;
  box-shadow: 0 16rpx 64rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 2;
}
.section-tag {
  font-size: 22rpx;
  color: #ff69b4;
  font-weight: 600;
  margin-bottom: 16rpx;
}
.checkin-hero-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 12rpx;
}
.checkin-hint {
  font-size: 26rpx;
  color: #888;
  line-height: 1.5;
  margin-bottom: 32rpx;
}
.btn-scan {
  width: 100%;
  height: 96rpx;
  border: none;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  padding: 0;
  line-height: 96rpx;
}
.btn-scan::after {
  border: none;
}
.link-row {
  display: flex;
  justify-content: center;
  gap: 40rpx;
}
.link-row--single {
  gap: 0;
}
.link-item {
  font-size: 26rpx;
  color: #0f3460;
  font-weight: 500;
}
.checkin-result-card {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  background: #f8fafc;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #e8eef4;
}
.customer-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fce4ec, #f8bbd9);
  flex-shrink: 0;
}
.customer-detail {
  flex: 1;
  min-width: 0;
}
.customer-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
}
.customer-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #888;
}
.checkin-badge {
  display: inline-block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #059669;
  background: #ecfdf5;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

/* 拍摄区 */
.shoot-section {
  padding: 32rpx 32rpx 0;
}
.shoot-card {
  background: #fff;
  border-radius: 40rpx;
  padding: 48rpx 40rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.06);
  text-align: center;
}
.shoot-hero-wrap {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.shoot-hero-wrap::after {
  content: '';
  position: absolute;
  inset: 8rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 50% 40%, rgba(255, 105, 180, 0.12), transparent 70%);
  pointer-events: none;
}
.shoot-hero-img {
  width: 200rpx;
  height: 200rpx;
  display: block;
}
.shoot-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 12rpx;
}
.shoot-sub {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
  margin-bottom: 32rpx;
}
.shoot-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.btn-shoot {
  width: 100%;
  height: 96rpx;
  border: none;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #ff69b4, #e91e8c);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  padding: 0;
  line-height: 96rpx;
}
.btn-shoot::after {
  border: none;
}
.btn-link-customer {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  border: 3rpx solid #e8e4f0;
  background: linear-gradient(180deg, #fff 0%, #faf8fc 100%);
  color: #4a4560;
  font-size: 28rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}
.btn-link-customer::after {
  border: none;
}
.btn-link-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}
.linked-customer-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  width: 100%;
  flex-wrap: wrap;
}
.linked-status {
  max-width: 360rpx;
  font-size: 26rpx;
  color: #047857;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.linked-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}
.btn-change {
  flex-shrink: 0;
  padding: 10rpx 28rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #52525b;
  background: #fff;
  border: 2rpx solid #e4e4e7;
  border-radius: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  line-height: 1.2;
}
.btn-change:active {
  opacity: 0.85;
  background: #f8fafc;
}
.link-unlink {
  font-size: 24rpx;
  color: #94a3b8;
  font-weight: 500;
  line-height: 1.2;
  padding: 8rpx 4rpx;
}
.link-unlink:active {
  color: #64748b;
}
.shoot-tip-hint {
  margin-top: 24rpx;
  font-size: 22rpx;
  color: #aaa;
  line-height: 1.4;
}

/* 最近服务 */
.section-header {
  padding: 40rpx 40rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.s-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.s-title::before {
  content: '';
  width: 6rpx;
  height: 30rpx;
  background: linear-gradient(180deg, #e8b86d, #c9922a);
  border-radius: 3rpx;
}
.s-more {
  font-size: 24rpx;
  color: #999;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

/* 样板展示：方案 C（组件 style-showcase-home） */
.index-showcase {
  display: block;
  padding: 20rpx 40rpx 40rpx;
}

@media (max-width: 360px) {
  .home-header {
    padding: 24rpx 28rpx 30rpx;
  }
  .checkin-hero {
    margin: 20rpx 24rpx 0;
    padding: 32rpx;
    border-radius: 32rpx;
  }
  .shoot-section {
    padding: 24rpx 24rpx 0;
  }
  .shoot-card {
    border-radius: 28rpx;
    padding: 34rpx 28rpx 30rpx;
  }
  .shoot-hero-wrap,
  .shoot-hero-img {
    width: 168rpx;
    height: 168rpx;
  }
  .shoot-title {
    font-size: 30rpx;
  }
  .shoot-sub,
  .shoot-tip-hint,
  .store-sub,
  .checkin-hint {
    font-size: 22rpx;
  }
  .btn-shoot,
  .btn-scan {
    height: 86rpx;
    line-height: 86rpx;
    font-size: 28rpx;
  }
  .checkin-result-card {
    padding: 16rpx;
  }
  .customer-avatar {
    width: 88rpx;
    height: 88rpx;
  }
  .customer-name {
    font-size: 28rpx;
  }
  .customer-meta,
  .checkin-badge,
  .linked-status,
  .btn-change,
  .link-unlink,
  .s-more,
  .showcase-label {
    font-size: 20rpx;
  }
  .section-header {
    padding: 30rpx 28rpx 16rpx;
  }
  .showcase-section {
    padding: 14rpx 28rpx 28rpx;
  }
}

