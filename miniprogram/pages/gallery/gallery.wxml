<!--pages/gallery/gallery.wxml-->
<view class="gallery-container">
  <view class="gallery-top">
    <view class="filter-pill" hover-class="filter-pill-active" bindtap="onFilterRowTap">
      <view class="pill-av {{singleCustomerMode ? '' : 'store'}}">{{filterCustomerInitial}}</view>
      <text class="pill-name">{{singleCustomerMode ? filterCustomerName : '全店客户'}}</text>
      <view class="btn-action">更换</view>
    </view>
    <view class="seg-tabs">
      <view
        class="seg-tab {{activeTabIndex === 0 ? 'on' : ''}}"
        bindtap="switchTab"
        data-index="0"
      >按时间</view>
      <view
        class="seg-tab {{activeTabIndex === 1 ? 'on' : ''}}"
        bindtap="switchTab"
        data-index="1"
      >按收藏</view>
    </view>
    <view wx:if="{{autoRefreshing}}" class="auto-hint">生成中，自动更新中…</view>
    <view wx:elif="{{autoRefreshStopped}}" class="auto-hint muted">已停止自动更新，可下拉刷新</view>
  </view>

  <swiper class="content-swiper" current="{{activeTabIndex}}" bindchange="onSwiperChange" duration="300">
    <swiper-item>
      <scroll-view
        class="scroll-area"
        scroll-y
        enhanced
        show-scrollbar="{{false}}"
        refresher-enabled="{{true}}"
        bindrefresherrefresh="onRefresh"
        refresher-triggered="{{timeRefreshing}}"
        bindscrolltolower="onScrollLower"
        lower-threshold="100"
      >
        <view wx:if="{{timeGroups.length === 0 && !timeLoading}}" class="empty-tip">暂无照片</view>
        <block wx:for="{{timeGroups}}" wx:key="month">
          <view class="month-group">
            <view class="month-title">{{item.month}}</view>
          </view>
          <view class="batch-list">
            <block wx:for="{{item.batches}}" wx:for-item="batch" wx:key="_id">
              <template is="batchCard" data="{{batch: batch, singleCustomerMode: singleCustomerMode}}" />
            </block>
          </view>
        </block>
        <view wx:if="{{timeLoading}}" class="loading-tip">加载中...</view>
        <view wx:if="{{!timeHasMore && timeGroups.length > 0}}" class="no-more">没有更多了</view>
      </scroll-view>
    </swiper-item>

    <swiper-item>
      <scroll-view
        class="scroll-area"
        scroll-y
        enhanced
        show-scrollbar="{{false}}"
        refresher-enabled="{{true}}"
        bindrefresherrefresh="onRefresh"
        refresher-triggered="{{favRefreshing}}"
        bindscrolltolower="onScrollLower"
        lower-threshold="100"
      >
        <view wx:if="{{favGroups.length === 0 && !favLoading}}" class="empty-tip">暂无收藏照片</view>
        <block wx:for="{{favGroups}}" wx:key="month">
          <view class="month-group">
            <view class="month-title">{{item.month}}</view>
          </view>
          <view class="batch-list">
            <block wx:for="{{item.batches}}" wx:for-item="batch" wx:key="_id">
              <template is="batchCard" data="{{batch: batch, singleCustomerMode: singleCustomerMode}}" />
            </block>
          </view>
        </block>
        <view wx:if="{{favLoading}}" class="loading-tip">加载中...</view>
        <view wx:if="{{!favHasMore && favGroups.length > 0}}" class="no-more">没有更多了</view>
      </scroll-view>
    </swiper-item>
  </swiper>

  <customer-picker
    visible="{{pickerVisible}}"
    selectedId="{{pickerSelectedId}}"
    includeStoreOption="{{true}}"
    storeOptionLabel="全店客户"
    applyGlobalSelection="{{false}}"
    bind:select="onPickerSelect"
    bind:close="onPickerClose"
  />
</view>

<template name="batchCard">
  <view class="batch-card" bindtap="onBatchTap" data-batch="{{batch}}">
    <view class="card-top {{singleCustomerMode ? 'compact' : ''}}">
      <view
        wx:if="{{!singleCustomerMode}}"
        class="card-avatar"
        style="background: {{batch.avatarColor}}"
      >{{batch.customerInitial}}</view>
      <view class="card-meta">
        <view class="card-row1">
          <text wx:if="{{!singleCustomerMode}}" class="card-customer">{{batch.customerName}}</text>
          <text class="card-time {{singleCustomerMode ? 'prominent' : ''}}">{{batch.timeLabel}}</text>
        </view>
        <view class="card-row2">{{batch.summaryText}}</view>
      </view>
      <view class="status-tag {{batch.status}}">
        <text wx:if="{{batch.status === 'completed'}}">已完成</text>
        <text wx:elif="{{batch.status === 'generating'}}">{{batch.progressPercent}}%</text>
        <text wx:elif="{{batch.status === 'partial'}}">部分失败</text>
        <text wx:else>待生成</text>
      </view>
      <view class="card-more" catchtap="onBatchMenu" data-batch="{{batch}}">···</view>
    </view>
    <view class="card-preview">
      <view class="cover-wrap">
        <image
          wx:if="{{batch.coverUrl}}"
          class="cover-img"
          src="{{batch.coverUrl}}"
          mode="aspectFill"
        />
        <view wx:else class="cover-empty">暂无预览</view>
        <view wx:if="{{batch.status === 'generating'}}" class="cover-mask">
          <view class="progress-ring">
            <text class="progress-num">{{batch.progressPercent}}%</text>
            <text class="progress-label">生成中</text>
          </view>
        </view>
      </view>
      <view class="thumb-side">
        <view
          wx:for="{{batch.thumbUrls}}"
          wx:for-item="url"
          wx:for-index="ti"
          wx:key="ti"
          wx:if="{{ti < 3}}"
          class="thumb-cell"
        >
          <image class="thumb-img" src="{{url}}" mode="aspectFill" />
        </view>
        <view wx:if="{{batch.extraCount > 0}}" class="thumb-cell more">+{{batch.extraCount}}</view>
      </view>
    </view>
  </view>
</template>
