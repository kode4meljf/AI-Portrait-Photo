/* pages/gallery/gallery.wxss · V5 一体药丸 */
.gallery-container {
  background: #f3f4f6;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 顶栏固定，列表在下方 swiper 内滚动 */
.gallery-top {
  flex-shrink: 0;
  padding: 16rpx 32rpx 12rpx;
  background: #f3f4f6;
}

.filter-pill {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 999rpx;
  padding: 8rpx 8rpx 8rpx 12rpx;
  border: 2rpx solid rgba(26, 26, 46, 0.06);
  box-shadow: 0 4rpx 20rpx rgba(26, 26, 46, 0.08);
  box-sizing: border-box;
}

.filter-pill-active {
  opacity: 0.92;
}

.pill-av {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #7c8ef5, #9b6fd4);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.pill-av.store {
  background: linear-gradient(145deg, #e8ecf2, #dfe4ec);
  color: #6b7280;
  font-size: 26rpx;
}

.pill-name {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  padding: 0 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.btn-action {
  flex-shrink: 0;
  background: #1a1a2e;
  color: #fff;
  font-size: 26rpx;
  font-weight: 500;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  line-height: 1;
}

.seg-tabs {
  display: flex;
  margin-top: 20rpx;
  padding: 8rpx;
  background: #fff;
  border-radius: 28rpx;
  border: 2rpx solid rgba(26, 26, 46, 0.05);
  box-shadow: 0 2rpx 12rpx rgba(26, 26, 46, 0.05);
  gap: 8rpx;
  box-sizing: border-box;
}

.seg-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 26rpx;
  font-weight: 500;
  color: #9ca3af;
  border-radius: 20rpx;
}

.seg-tab.on {
  background: #f3f4f6;
  color: #1a1a2e;
  font-weight: 600;
}

.toolbar-clear {
  margin-top: 16rpx;
  text-align: center;
  font-size: 26rpx;
  color: #6b7280;
  padding: 8rpx 0;
}

.toolbar-clear-active {
  opacity: 0.55;
}

.auto-hint {
  margin-top: 16rpx;
  padding: 16rpx 24rpx;
  font-size: 22rpx;
  color: #ea580c;
  background: #fff7ed;
  border-radius: 12rpx;
  text-align: center;
}

.auto-hint.muted {
  color: #9ca3af;
  background: rgba(255, 255, 255, 0.9);
}

.content-swiper {
  flex: 1;
  height: 0;
}

.content-swiper swiper-item {
  height: 100%;
}

.scroll-area {
  height: 100%;
  padding: 8rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.month-group {
  margin-top: 24rpx;
  margin-bottom: 12rpx;
}

.month-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #6b7280;
  padding-left: 16rpx;
  position: relative;
}

.month-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #d1d5db;
}

.batch-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.batch-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 24rpx;
  box-sizing: border-box;
  box-shadow:
    0 4rpx 24rpx rgba(26, 26, 46, 0.08),
    0 2rpx 8rpx rgba(26, 26, 46, 0.04);
}

.card-top {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.card-top.compact .card-meta {
  flex: 1 1 200rpx;
}

.card-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.card-meta {
  flex: 1 1 140rpx;
  min-width: 0;
}

.card-row1 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.card-customer {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.card-time {
  font-size: 24rpx;
  color: #9ca3af;
  flex-shrink: 0;
}

.card-time.prominent {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.card-row2 {
  font-size: 22rpx;
  color: #6b7280;
  line-height: 1.4;
}

.status-tag {
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 14rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
  align-self: flex-start;
}

.status-tag.completed {
  background: #ecfdf5;
  color: #059669;
}

.status-tag.generating {
  background: #fff7ed;
  color: #ea580c;
}

.status-tag.pending {
  background: #f3f4f6;
  color: #6b7280;
}

.status-tag.partial {
  background: #fef2f2;
  color: #dc2626;
}

.card-more {
  font-size: 28rpx;
  color: #9ca3af;
  padding: 0 8rpx;
  flex-shrink: 0;
  align-self: flex-start;
}

.card-preview {
  display: flex;
  gap: 12rpx;
  height: 200rpx;
}

.cover-wrap {
  flex: 1.35;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
  background: #eef0f4;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-empty {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #9ca3af;
}

.cover-mask {
  position: absolute;
  inset: 0;
  background: rgba(26, 26, 46, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
}

.progress-ring {
  text-align: center;
  color: #fff;
}

.progress-num {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.1;
}

.progress-label {
  display: block;
  font-size: 20rpx;
  opacity: 0.9;
  margin-top: 4rpx;
}

.thumb-side {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.thumb-cell {
  flex: 1;
  border-radius: 12rpx;
  overflow: hidden;
  background: #eef0f4;
}

.thumb-cell.more {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #6b7280;
  background: #f3f4f6;
}

.thumb-img {
  width: 100%;
  height: 100%;
}

.empty-tip,
.loading-tip,
.no-more {
  text-align: center;
  padding: 80rpx 32rpx;
  color: #9ca3af;
  font-size: 28rpx;
}
