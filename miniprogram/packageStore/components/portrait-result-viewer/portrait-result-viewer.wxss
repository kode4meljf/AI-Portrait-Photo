.page-shell {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
}

.result-nav {
  flex-shrink: 0;
  background: #f6f7f9;
  box-sizing: border-box;
}

.result-nav-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 16rpx 0 8rpx;
  box-sizing: border-box;
}

.nav-back {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
}

.nav-back--active {
  opacity: 0.55;
}

.nav-back-chevron {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid rgba(0, 0, 0, 0.88);
  border-bottom: 4rpx solid rgba(0, 0, 0, 0.88);
  transform: rotate(45deg);
  margin-left: 8rpx;
}

.result-nav-title {
  flex: 1;
  min-width: 0;
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a2e;
  text-align: center;
  padding: 0 72rpx;
  box-sizing: border-box;
}

.result-page {
  flex: 1;
  min-height: 0;
  background: #f6f7f9;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.page-body {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  padding: 0;
  box-sizing: border-box;
  overflow: hidden;
}

.content-scroll {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
}

.image-zone {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  padding: 8rpx 0 0;
}

.hero-stage {
  flex-shrink: 0;
  width: 100%;
  display: flex;
  flex-direction: column;
}

.hero-frame {
  width: 100%;
  border-radius: 0;
  background: #e9edf3;
  box-shadow: none;
  position: relative;
  overflow: hidden;
}

.result-swiper {
  width: 100%;
}

.result-swiper swiper-item {
  height: 100%;
}

.swiper-item-inner {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: 0;
  position: relative;
}

.result-image {
  width: 100%;
  height: 100%;
  display: block;
}

.frame-overlay {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 4;
}

.hero-chrome {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 16rpx;
  max-width: calc(100% - 40rpx);
  pointer-events: none;
  z-index: 6;
}

.pill-count {
  padding: 8rpx 20rpx;
  border-radius: 40rpx;
  background: rgba(0, 0, 0, 0.52);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.2;
  backdrop-filter: blur(8px);
}

.pill-dl {
  padding: 8rpx 22rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.94);
  color: #1a1a2e;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.2;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  pointer-events: auto;
}

.pill-fav {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 18rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.94);
  color: #1a1a2e;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.2;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  pointer-events: auto;
}

.pill-fav-star {
  font-size: 26rpx;
  line-height: 1;
  color: #9ca3af;
}

.pill-fav.is-on {
  background: rgba(255, 251, 235, 0.96);
  color: #b45309;
  box-shadow: 0 4rpx 16rpx rgba(245, 158, 11, 0.18);
}

.pill-fav.is-on .pill-fav-star {
  color: #f59e0b;
}

.pill-fav--active,
.pill-dl--active {
  opacity: 0.82;
}

.origin-float {
  position: absolute;
  right: 20rpx;
  bottom: 56rpx;
  width: 144rpx;
  border-radius: 16rpx;
  overflow: hidden;
  border: 4rpx solid #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.22);
  pointer-events: auto;
  transition: opacity 0.2s ease, transform 0.2s ease;
}

.origin-float.is-hidden {
  opacity: 0;
  pointer-events: none;
  transform: scale(0.92);
}

.origin-float--press {
  opacity: 0.88;
  transform: scale(0.96);
}

.origin-float image {
  width: 100%;
  height: 144rpx;
  display: block;
}

.origin-float .mini-label {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 8rpx 6rpx;
  font-size: 20rpx;
  color: #fff;
  text-align: center;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.55));
}

.swipe-toast {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  max-width: 88%;
  padding: 20rpx 28rpx;
  border-radius: 20rpx;
  background: rgba(0, 0, 0, 0.72);
  color: #fff;
  font-size: 24rpx;
  line-height: 1.45;
  text-align: center;
}

.swiper-item-inner.is-failed,
.swiper-item-inner.is-generating {
  background: #e8e8e8;
}

.swiper-item-inner.is-retrying {
  background: #ececec;
}

.fail-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.72);
  z-index: 2;
  padding: 40rpx;
  box-sizing: border-box;
  pointer-events: none;
}

.fail-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #c0392b;
  margin-bottom: 12rpx;
}

.fail-hint {
  font-size: 24rpx;
  color: #888;
}

.retry-fab {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 6;
  pointer-events: auto;
}

.retry-fab--active {
  opacity: 0.82;
  transform: scale(0.96);
}

.retry-fab-icon {
  width: 42rpx;
  height: 42rpx;
  border: 4rpx solid #c49a3d;
  border-right-color: transparent;
  border-radius: 50%;
  animation: retry-spin 4s linear infinite;
}

@keyframes retry-spin {
  to {
    transform: rotate(360deg);
  }
}

.retrying-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.78);
  z-index: 3;
}

.retrying-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid #c49a3d;
  border-top-color: transparent;
  border-radius: 50%;
  animation: retry-spin 0.9s linear infinite;
  margin-bottom: 16rpx;
}

.retrying-text {
  font-size: 26rpx;
  color: #666;
}

.style-tray {
  flex-shrink: 0;
  margin-top: -48rpx;
  padding: 0;
  position: relative;
  z-index: 4;
  box-sizing: border-box;
}

.tray-panel {
  background: #eceef2;
  border-radius: 20rpx 20rpx 0 0;
  padding: 32rpx 28rpx 24rpx;
  box-shadow: 0 -6rpx 28rpx rgba(15, 23, 42, 0.07);
  box-sizing: border-box;
}

.tray-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.tray-title-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 0 8rpx;
}

.tray-title {
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
  line-height: 1.3;
}

.tray-ai-note {
  font-size: 20rpx;
  font-weight: 400;
  color: #a08030;
  line-height: 1.3;
}

.origin-toggle {
  flex-shrink: 0;
  font-size: 26rpx;
  color: #1a1a2e;
  font-weight: 500;
  line-height: 1.3;
  padding: 2rpx 0;
  background: transparent;
}

.origin-toggle.is-on {
  color: #c49a3d;
  font-weight: 600;
}

.origin-toggle--press {
  opacity: 0.45;
}

.stand-tip-row {
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.stand-tip {
  display: block;
  font-size: 22rpx;
  color: #6f6f6f;
  line-height: 1.45;
}

.thumb-scroll {
  width: 100%;
  white-space: nowrap;
}

.thumb-row {
  display: inline-flex;
  gap: 14rpx;
  padding-bottom: 10rpx;
}

.thumb-item {
  width: 150rpx;
  border-radius: 14rpx;
  overflow: hidden;
  background: #fff;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.thumb-item.active {
  border-color: #111827;
}

.thumb-item.is-processing {
  opacity: 0.55;
}

.thumb-item.is-failed .thumb-image {
  filter: grayscale(0.45);
}

.thumb-image-wrap {
  position: relative;
  width: 100%;
  background: #edf1f6;
}

.thumb-image {
  width: 100%;
  height: 188rpx;
  display: block;
}

.thumb-name {
  display: block;
  padding: 8rpx 8rpx 10rpx;
  font-size: 20rpx;
  color: #374151;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.state-dot {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  border: 2rpx solid #fff;
  box-sizing: border-box;
}

.state-dot.ing {
  background: #e8a045;
}

.state-dot.fail {
  background: #e74c3c;
}

.footer {
  flex-shrink: 0;
  padding: 20rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #ececec;
}

.action-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.btn {
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 0;
  margin: 0;
  line-height: 88rpx;
}

.btn-outline {
  background: #fff;
  color: #1a1a2e;
  border: 3rpx solid #d8d8d8;
}

.btn-primary {
  border: none;
  background: linear-gradient(135deg, #f4cf63, #e8b86d);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(232, 184, 109, 0.45);
}

.btn-primary.is-disabled {
  opacity: 0.38;
}

.btn::after {
  border: none;
}

.loading-body {
  flex: 1;
  height: 100%;
  min-height: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx calc(64rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  text-align: center;
}

.loading-main {
  width: 100%;
  max-width: 560rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transform: translateY(48rpx);
}

.spinner {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 8rpx solid #e0e0e0;
  border-top-color: #e8b86d;
  animation: spin 0.9s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f1f1f;
  margin-bottom: 16rpx;
}

.loading-hint {
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1.5;
}

.loading-hint--leave {
  display: block;
  margin-bottom: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.loading-hint-row {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 4rpx;
}

.loading-gallery-link {
  display: inline-flex;
  align-items: center;
  min-height: 56rpx;
  padding: 0 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #c49a3d;
  line-height: 1.5;
}

.loading-gallery-link--press {
  opacity: 0.55;
}

.loading-preview {
  margin-top: 28rpx;
  width: 300rpx;
  height: 380rpx;
  max-height: 38vh;
  border-radius: 24rpx;
  overflow: hidden;
  background: #e4e4e4;
  opacity: 0.55;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-preview--press {
  opacity: 0.72;
  transform: scale(0.98);
}

.loading-preview image {
  width: 100%;
  height: 100%;
}

.preview-layer {
  position: fixed;
  inset: 0;
  z-index: 2000;
  background: #000;
  display: flex;
  flex-direction: column;
}

.preview-image-area {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.preview-image-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 2;
  transform-origin: 0 0;
  will-change: transform;
}

.preview-image-wrapper.animating {
  transition: transform 300ms ease-out;
}

.preview-swiper {
  width: 100%;
  height: 100%;
}

.preview-slide {
  width: 100%;
  height: 100%;
  position: relative;
  box-sizing: border-box;
  overflow: hidden;
}

.preview-slide-img {
  width: 100%;
  height: 100%;
  display: block;
}

.preview-touch-catcher {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 5;
}

.preview-progress-bar {
  position: absolute;
  left: 0;
  right: 0;
  display: flex;
  gap: 4px;
  padding: 0 24rpx;
  pointer-events: none;
  z-index: 10;
  box-sizing: border-box;
  height: 3px;
}

.preview-progress-segment {
  flex: 1;
  height: 3px;
  border-radius: 1.5px;
}

.preview-progress-segment.done {
  background: rgba(255, 255, 255, 0.85);
}

.preview-progress-segment.todo {
  background: rgba(255, 255, 255, 0.15);
}

.preview-bottom-bar {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  height: calc(84rpx + env(safe-area-inset-bottom));
  background: #000;
}

.preview-actions {
  position: relative;
  width: 100%;
  height: 100%;
  opacity: 0;
  transition: opacity 0.2s ease;
}

.preview-actions.fade-in {
  opacity: 1;
}

.preview-action-item {
  position: absolute;
  top: 40%;
  transform: translateY(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
}

.preview-close-btn {
  left: 64rpx;
}

.preview-download-btn {
  right: 64rpx;
}

.preview-action-icon {
  font-size: 48rpx;
  line-height: 1;
  color: #fff;
  text-align: center;
}
