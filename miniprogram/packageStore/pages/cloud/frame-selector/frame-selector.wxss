.frame-page {
  min-height: 100vh;
  background: #fff;
  padding: 24rpx 32rpx 0;
  box-sizing: border-box;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 28rpx;
}

.frames-hint {
  margin: -12rpx 0 20rpx;
  font-size: 24rpx;
  color: #9ca3af;
  line-height: 1.45;
}

.frames-scroll {
  width: 100%;
  white-space: nowrap;
}

.frames-row {
  display: inline-flex;
  gap: 24rpx;
  padding-bottom: 8rpx;
}

.frame-card {
  flex-shrink: 0;
  width: 216rpx;
  border-radius: 20rpx;
  overflow: hidden;
  border: 4rpx solid transparent;
  box-sizing: border-box;
  background: #f9fafb;
}

.frame-card.selected {
  border-color: #e53935;
}

.frame-thumb {
  width: 216rpx;
  height: 264rpx;
  display: block;
  background: #eee;
}

.frame-name {
  display: block;
  padding: 12rpx 8rpx 16rpx;
  font-size: 22rpx;
  color: #6b7280;
  text-align: center;
}

.frames-wrap {
  position: relative;
}

.preview-link {
  display: block;
  margin-top: 12rpx;
  text-align: right;
  font-size: 24rpx;
  color: #2563eb;
  line-height: 1.4;
}

.preview-link:active {
  opacity: 0.7;
}

/* 预览遮罩 */
.preview-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1000;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: flex-end;
}

.preview-sheet {
  width: 100%;
  max-height: 88vh;
  background: #f3f4f6;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.preview-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 16rpx;
  background: #fff;
  border-bottom: 2rpx solid #f0f0f0;
}

.preview-sheet-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
}

.preview-close {
  width: 56rpx;
  height: 56rpx;
  line-height: 52rpx;
  text-align: center;
  font-size: 44rpx;
  color: #9ca3af;
}

.preview-scroll {
  flex: 1;
  max-height: calc(88vh - 100rpx);
  padding: 24rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.preview-stage-wrap {
  position: relative;
  padding: 24rpx 8rpx 40rpx;
  display: flex;
  justify-content: center;
}

.preview-stage-shadow {
  position: absolute;
  left: 50%;
  bottom: 8rpx;
  width: 72%;
  height: 32rpx;
  transform: translateX(-50%);
  background: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.16) 0%, transparent 72%);
}

.preview-frame-shell {
  position: relative;
  width: 520rpx;
  max-width: 100%;
  box-sizing: border-box;
  box-shadow: 0 20rpx 40rpx rgba(17, 24, 39, 0.14);
}

.preview-frame-mat {
  position: relative;
  overflow: hidden;
  background: #fff;
}

.preview-frame-photo {
  display: block;
  width: 100%;
  height: 560rpx;
  opacity: 0;
  transition: opacity 0.25s ease;
}

.preview-frame-photo.loaded {
  opacity: 1;
}

.preview-photo-loading {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #9ca3af;
  background: #e5e7eb;
}

/* F01 原木色：浅木、偏暖黄 */
.preview-frame-1 {
  padding: 30rpx;
  background: linear-gradient(160deg, #e8cfa8 0%, #d4b483 42%, #c4a06a 100%);
  border-radius: 6rpx;
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.35),
    inset 0 -2rpx 4rpx rgba(120, 86, 40, 0.25);
}

.preview-frame-1 .preview-frame-mat {
  padding: 22rpx;
  background: #faf8f4;
  box-shadow: inset 0 0 0 2rpx rgba(180, 150, 100, 0.18);
}

/* F02 黑胡桃色：深灰褐木 */
.preview-frame-2 {
  padding: 30rpx;
  background: linear-gradient(165deg, #6a5f56 0%, #4f4740 48%, #3d3832 100%);
  border-radius: 6rpx;
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.12),
    inset 0 -2rpx 4rpx rgba(0, 0, 0, 0.35);
}

.preview-frame-2 .preview-frame-mat {
  padding: 22rpx;
  background: #f7f5f2;
  box-shadow: inset 0 0 0 2rpx rgba(60, 54, 48, 0.2);
}

/* F03 红木色：深红褐木 */
.preview-frame-3 {
  padding: 30rpx;
  background: linear-gradient(160deg, #8b4a3c 0%, #6b3428 45%, #5a2a20 100%);
  border-radius: 6rpx;
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.15),
    inset 0 -2rpx 4rpx rgba(40, 12, 8, 0.4);
}

.preview-frame-3 .preview-frame-mat {
  padding: 22rpx;
  background: #faf7f4;
  box-shadow: inset 0 0 0 2rpx rgba(100, 40, 30, 0.22);
}

/* F04 胡桃木色：中深暖褐 */
.preview-frame-4 {
  padding: 30rpx;
  background: linear-gradient(160deg, #a8845c 0%, #8b6a42 46%, #755635 100%);
  border-radius: 6rpx;
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.22),
    inset 0 -2rpx 4rpx rgba(70, 45, 20, 0.3);
}

.preview-frame-4 .preview-frame-mat {
  padding: 22rpx;
  background: #faf8f5;
  box-shadow: inset 0 0 0 2rpx rgba(110, 80, 45, 0.2);
}

.preview-meta {
  text-align: center;
  margin-bottom: 24rpx;
  font-size: 26rpx;
  color: #6b7280;
}

.preview-meta-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.preview-meta-extra {
  margin-left: 8rpx;
}

.preview-disclaimer {
  padding: 24rpx 28rpx;
  background: #fffbeb;
  border: 2rpx solid #fde68a;
  border-radius: 20rpx;
}

.preview-disclaimer-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #b45309;
  margin-bottom: 12rpx;
}

.preview-disclaimer-text {
  font-size: 24rpx;
  line-height: 1.65;
  color: #92400e;
}

.store-block {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 28rpx;
  border: 2rpx solid #eee;
  border-radius: 24rpx;
  background: #fafafa;
}

.store-pin {
  font-size: 32rpx;
  line-height: 1.2;
  flex-shrink: 0;
}

.store-body {
  flex: 1;
  min-width: 0;
}

.store-label {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 12rpx;
}

.store-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 12rpx;
}

.store-addr {
  display: block;
  font-size: 28rpx;
  color: #374151;
  line-height: 1.45;
  margin-bottom: 12rpx;
}

.store-contact {
  display: block;
  font-size: 26rpx;
  color: #9ca3af;
}

.store-hint {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #a1a1aa;
  line-height: 1.45;
}

.store-arrow {
  font-size: 36rpx;
  color: #d1d5db;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.footer-spacer {
  height: 160rpx;
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 2rpx solid #f0f0f0;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background: #2d2d2d;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  border: none;
}

.submit-btn::after {
  border: none;
}

.submit-btn-hover {
  opacity: 0.92;
}

.submit-btn[disabled] {
  opacity: 0.6;
}

.submit-btn .points-cost--md {
  font-size: 32rpx;
}

