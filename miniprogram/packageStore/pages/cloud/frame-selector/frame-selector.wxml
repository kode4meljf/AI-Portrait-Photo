<view class="frame-page">
  <view class="section frames-section">
    <view class="section-title">样式选择</view>
    <view wx:if="{{framesError}}" class="frames-hint">{{framesError}}</view>
    <view class="frames-wrap">
      <scroll-view class="frames-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="frames-row">
          <view
            wx:for="{{frames}}"
            wx:key="id"
            class="frame-card {{selectedFrameId === item.id ? 'selected' : ''}}"
            data-id="{{item.id}}"
            bindtap="onSelectFrame"
          >
            <image class="frame-thumb" src="{{item.coverDisplayUrl || item.coverFileId}}" mode="aspectFill" />
            <text class="frame-name">{{item.name}}</text>
          </view>
        </view>
      </scroll-view>
      <text class="preview-link" bindtap="onOpenPreview">摆台效果预览</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">门店信息</view>
    <view class="store-block" bindtap="onTapStore">
      <text class="store-pin">📍</text>
      <view class="store-body">
        <text class="store-label">配送至本门店</text>
        <text class="store-name">{{storeInfo.name}}</text>
        <text class="store-addr">{{storeInfo.address}}</text>
        <text class="store-contact">{{storeInfo.contactName}} {{storeInfo.contactPhone}}</text>
        <text class="store-hint">{{isOwner ? '相框制作完成后寄送至门店，无需填写客户收件地址' : '门店资料仅店长可修改'}}</text>
      </view>
      <text wx:if="{{isOwner}}" class="store-arrow">›</text>
    </view>
  </view>

  <view class="footer-spacer"></view>
</view>

<view class="footer">
  <button
    class="submit-btn"
    bindtap="onSubmit"
    disabled="{{submitting}}"
    hover-class="submit-btn-hover"
  >
    <points-cost label="一键相框" value="{{frameCost}}" theme="on-dark" size="md" />
  </button>
</view>

<view
  wx:if="{{showPreview}}"
  class="preview-mask"
  catchtouchmove="preventMove"
  bindtap="onClosePreview"
>
  <view class="preview-sheet" catchtap="preventMove">
    <view class="preview-header">
      <text class="preview-sheet-title">摆台效果预览</text>
      <text class="preview-close" bindtap="onClosePreview">×</text>
    </view>
    <scroll-view class="preview-scroll" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="preview-stage-wrap">
        <view class="preview-stage-shadow"></view>
        <view class="preview-frame-shell preview-frame-{{previewFrameTheme}}">
          <view class="preview-frame-mat">
            <image
              class="preview-frame-photo {{previewImageReady ? 'loaded' : ''}}"
              src="{{photoUrl}}"
              mode="aspectFill"
              bindload="onPreviewPhotoLoad"
              binderror="onPreviewPhotoError"
            />
            <view wx:if="{{!previewImageReady}}" class="preview-photo-loading">加载中…</view>
          </view>
        </view>
      </view>
      <view class="preview-meta">
        <text class="preview-meta-name">{{previewFrameName}}</text>
        <text wx:if="{{previewFrameSize}}" class="preview-meta-extra">{{previewFrameSize}}</text>
        <text wx:if="{{styleName}}" class="preview-meta-extra">· {{styleName}}</text>
      </view>
      <view class="preview-disclaimer">
        <view class="preview-disclaimer-title">温馨提示</view>
        <text class="preview-disclaimer-text">预览效果仅供参考，摆台成品以实物为准。因拍摄光线、材质工艺及显示设备差异，颜色与细节可能与实物存在轻微差别。</text>
      </view>
    </scroll-view>
  </view>
</view>
