.change-page {
  min-height: 100vh;
  background: #f3f3f3;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.content {
  flex: 1;
  padding: 12rpx 24rpx 0;
  box-sizing: border-box;
}

/* 预览区宽高比 7:8（宽:高） */
.upload-area {
  width: 100%;
  height: 0;
  padding-bottom: 114.286%;
  border-radius: 20rpx;
  background: #d9d9d9;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  overflow: hidden;
  position: relative;
  box-sizing: border-box;
}

.upload-preview {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.upload-empty {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.preview-change-tip {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 28rpx 24rpx 20rpx;
  box-sizing: border-box;
  text-align: center;
  pointer-events: none;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.5) 100%);
}

.preview-change-tip text {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 500;
  line-height: 1.3;
}

.upload-plus {
  font-size: 72rpx;
  line-height: 1;
  color: #b7b7b7;
  margin-bottom: 8rpx;
}

.upload-hint {
  font-size: 28rpx;
  color: #b1b1b1;
  font-weight: 500;
  line-height: 1.35;
  padding: 0 32rpx;
  text-align: center;
}

.upload-tip {
  margin: 16rpx 0 12rpx;
  font-size: 22rpx;
  color: #6f6f6f;
  line-height: 1.5;
  font-weight: 400;
}

.section-title {
  margin: 32rpx 0 14rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #1f1f1f;
  letter-spacing: 0;
}

.samples {
  display: flex;
  flex-direction: row;
  gap: 10rpx;
  padding: 0;
  flex-wrap: nowrap;
  justify-content: space-between;
}

.sample {
  width: 0;
  flex: 1;
  min-width: 0;
}

.sample-img-wrap {
  width: 100%;
  padding-bottom: 100%;
  height: 0;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  background: #cccccc;
}

.sample-img {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.badge {
  position: absolute;
  right: 8rpx;
  top: 8rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  font-size: 18rpx;
  line-height: 28rpx;
  text-align: center;
  color: #ffffff;
  font-weight: 700;
}

.badge.ok {
  background: #59c8d4;
}

.badge.bad {
  background: #ff6464;
}

.caption {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #666666;
  text-align: center;
  line-height: 1.25;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.footer {
  margin-top: auto;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}

.save-btn {
  height: 72rpx;
  border-radius: 36rpx;
  background: #f4cf63;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.06);
}
