<view class="change-page">
  <view class="content">
    <view class="upload-area" bindtap="onTapUpload">
      <block wx:if="{{displayUrl}}">
        <image class="upload-preview" src="{{displayUrl}}" mode="aspectFill"></image>
        <view class="preview-change-tip">
          <text>轻点图片更换原图</text>
        </view>
      </block>
      <view wx:else class="upload-empty">
        <text class="upload-plus">+</text>
        <text class="upload-hint">点击选择清晰的形象</text>
      </view>
    </view>

    <view class="upload-tip">* 请上传单人清晰、微笑、五官端正的人脸照，越美生成过越好</view>

    <view class="section-title">照片样例</view>

    <view class="samples">
      <view wx:for="{{sampleList}}" wx:key="id" class="sample">
        <view class="sample-img-wrap">
          <image class="sample-img" src="{{item.url}}" mode="aspectFill"></image>
          <view class="badge {{item.good ? 'ok' : 'bad'}}">{{item.good ? '✓' : '×'}}</view>
        </view>
        <view class="caption">{{item.caption}}</view>
      </view>
    </view>
  </view>

  <view class="footer">
    <view class="save-btn" bindtap="onSave">保存</view>
  </view>
</view>
