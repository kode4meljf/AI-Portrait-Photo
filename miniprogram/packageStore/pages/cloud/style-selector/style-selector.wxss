@import "../../../../styles/customer-gender.shared.wxss";

.style-page {
  min-height: 100vh;
  background: #f6f7f9;
  padding: 16rpx 0 calc(16rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.style-body {
  padding: 0 24rpx;
  box-sizing: border-box;
}

.preview-swiper {
  width: 100%;
  height: 760rpx;
}

.preview-card {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  overflow: hidden;
  background: #e9edf3;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.styles-hint {
  height: 760rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #888;
}

.styles-hint--error {
  color: #c2410c;
  padding: 0 32rpx;
  text-align: center;
  line-height: 1.5;
}

.list-header {
  margin-top: 18rpx;
  margin-bottom: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-height: 52rpx;
}

.list-title {
  font-size: 24rpx;
  color: #4b5563;
  flex-shrink: 0;
}

.list-title-num {
  font-weight: 600;
  color: #374151;
}

.filter-source {
  display: inline-flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
  font-size: 22rpx;
  color: #9ca3af;
  flex: 1;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.filter-source-em {
  color: #6b7280;
  font-weight: 500;
  flex-shrink: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
}

.filter-ctrl {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.filter-ctrl-label {
  font-size: 22rpx;
  color: #9ca3af;
  white-space: nowrap;
}

.thumb-scroll {
  width: 100%;
  white-space: nowrap;
}

.thumb-row {
  display: inline-flex;
  gap: 14rpx;
  padding-bottom: 10rpx;
}

.thumb-item {
  width: 150rpx;
  border-radius: 14rpx;
  overflow: hidden;
  background: #fff;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.thumb-item.active {
  border-color: #111827;
}

.thumb-image {
  width: 100%;
  height: 188rpx;
  display: block;
}

.thumb-name {
  display: block;
  padding: 8rpx 8rpx 10rpx;
  font-size: 20rpx;
  color: #374151;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.bottom-bar {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: nowrap;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.origin-box {
  height: 96rpx;
  border-radius: 28rpx;
  background: #fff;
  display: inline-flex;
  align-items: center;
  justify-content: flex-start;
  padding: 0 24rpx;
  gap: 8rpx;
  box-sizing: border-box;
  flex-shrink: 0;
}

.origin-thumb {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  background: #edf1f6;
}

.swap-icon {
  font-size: 28rpx;
  color: #9ca3af;
}

.origin-text {
  font-size: 24rpx;
  color: #374151;
}

.count-switch {
  height: 72rpx;
  padding: 6rpx 6rpx 6rpx 8rpx;
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: center;
  justify-content: flex-end;
  gap: 6rpx;
  box-sizing: border-box;
  flex-shrink: 0;
  margin-left: auto;
}

.count-label {
  font-size: 26rpx;
  color: #374151;
  white-space: nowrap;
  flex-shrink: 0;
  margin-right: 12rpx;
}

.count-btn-group {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx;
  background: #fff;
  border-radius: 36rpx;
  box-sizing: border-box;
  flex-shrink: 0;
}

.count-btn {
  min-width: 76rpx;
  height: 60rpx;
  border-radius: 32rpx;
  background: transparent;
  font-size: 24rpx;
  color: #6b7280;
  display: flex;
  align-items: center;
  justify-content: center;
}

.count-btn.active {
  background: #111827;
  color: #fff;
}

.submit-wrap {
  width: 100%;
  margin-top: 56rpx;
  padding: 0 80rpx;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  height: 92rpx;
  border-radius: 48rpx;
  background: #111827;
  color: #fff;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  box-shadow: 0 6rpx 20rpx rgba(17, 24, 39, 0.18);
}

.submit-btn-hover {
  transform: scale(0.985);
  background: #1f2937;
  opacity: 0.94;
  box-shadow: 0 4rpx 14rpx rgba(17, 24, 39, 0.14);
}

.submit-btn--disabled {
  opacity: 0.45;
  box-shadow: none;
  background: #9ca3af;
  color: #f3f4f6;
}
