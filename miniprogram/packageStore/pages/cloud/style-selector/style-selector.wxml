<view class="style-page">
  <view class="style-body">
  <view wx:if="{{loadingStyles}}" class="styles-hint">正在加载风格…</view>
  <view wx:elif="{{stylesError}}" class="styles-hint styles-hint--error">{{stylesError}}</view>
  <swiper wx:else class="preview-swiper" current="{{currentIndex}}" bindchange="onSwiperChange" duration="260">
    <swiper-item wx:for="{{styles}}" wx:key="id">
      <view class="preview-card">
        <image class="preview-image" src="{{item.sampleDisplayUrl || item.sampleFileId}}" mode="aspectFill"></image>
      </view>
    </swiper-item>
  </swiper>

  <view wx:if="{{stylePool.length || loadingStyles}}" class="list-header">
    <view class="list-title"><text class="list-title-num">{{styles.length}}</text>种风格列表</view>
    <view wx:if="{{hasLinkedCustomer}}" class="filter-source">
      <text class="filter-source-prefix">按</text>
      <text class="filter-source-em">{{filterCompactName}} · {{filterGenderLabel}}</text>
      <text class="filter-source-suffix">筛选</text>
    </view>
    <view wx:elif="{{showGenderToggle}}" class="filter-ctrl">
      <text class="filter-ctrl-label">适用</text>
      <view class="gender-filter">
        <view
          class="gender-filter-btn {{manualGender === 'male' ? 'active' : ''}}"
          data-gender="male"
          bindtap="onGenderFilterTap"
        >男</view>
        <view
          class="gender-filter-btn {{manualGender === 'female' ? 'active' : ''}}"
          data-gender="female"
          bindtap="onGenderFilterTap"
        >女</view>
      </view>
    </view>
  </view>
  <scroll-view wx:if="{{styles.length}}" class="thumb-scroll" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="thumb-row">
      <view
        wx:for="{{styles}}"
        wx:key="id"
        class="thumb-item {{index === currentIndex ? 'active' : ''}}"
        data-index="{{index}}"
        bindtap="onThumbTap"
      >
        <image class="thumb-image" src="{{item.sampleDisplayUrl || item.sampleFileId}}" mode="aspectFill"></image>
        <text class="thumb-name">{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <view class="bottom-bar">
    <view class="origin-box" bindtap="onChangeOriginal">
      <image class="origin-thumb" src="{{originalUrl}}" mode="aspectFill"></image>
      <text class="swap-icon">⇄</text>
      <text class="origin-text">更换原图</text>
    </view>

    <view class="count-switch">
      <text class="count-label">数量选择</text>
      <view class="count-btn-group">
        <view class="count-btn {{count === 3 ? 'active' : ''}}" data-count="3" bindtap="switchCount">3</view>
        <view
          class="count-btn {{count === 9 ? 'active' : ''}} {{stylePool.length > 0 && stylePool.length < 9 ? 'count-btn--disabled' : ''}}"
          data-count="9"
          bindtap="switchCount"
        >9</view>
      </view>
    </view>
    <view wx:if="{{countHint}}" class="count-hint">{{countHint}}</view>
  </view>
  </view>

  <view class="submit-wrap">
    <view
      class="submit-btn {{canSubmit ? '' : 'submit-btn--disabled'}}"
      hover-class="{{canSubmit ? 'submit-btn-hover' : ''}}"
      hover-stay-time="80"
      bindtap="onStartGenerate"
    >
      <points-cost
        wx:if="{{submitShowCost}}"
        label="立即生成"
        value="{{submitCost}}"
        theme="on-dark"
      />
      <text wx:else>{{submitPlainText}}</text>
    </view>
  </view>
</view>
