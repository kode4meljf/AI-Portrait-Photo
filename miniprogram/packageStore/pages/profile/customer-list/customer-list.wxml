<view class="page">
  <block wx:if="{{!editPanelVisible}}">
    <view class="search-bar-wrap">
      <view class="search-bar">
        <text class="search-icon">🔍</text>
        <input
          class="search-input"
          placeholder="搜索客户姓名或手机号"
          value="{{searchKeyword}}"
          bindinput="onSearchInput"
          bindconfirm="onSearchInput"
        />
        <text wx:if="{{searchKeyword}}" class="clear-icon" bindtap="onClearSearch">×</text>
      </view>
    </view>

    <!-- 整页滚动：真机上 scroll-view + flex 高度易塌成 0，改用页面级滚动 -->
    <view class="list-body {{customers.length === 0 ? 'list-body--empty' : ''}}">
      <view wx:if="{{loading && customers.length === 0}}" class="page-loading-wrap">
        <text class="page-loading-text">加载中...</text>
      </view>

      <view wx:elif="{{customers.length === 0}}" class="empty-wrap">
        <text class="empty-tip-text">{{searchKeyword ? '未找到匹配的客户' : (loadError || '暂无客户')}}</text>
        <text wx:if="{{!storeReady}}" class="empty-hint">请先登录门店账号</text>
      </view>

      <view
        wx:for="{{customers}}"
        wx:key="_id"
        class="customer-item {{selectMode && item._id === highlightId ? 'selected' : ''}}"
        bindtap="onCustomerTap"
        data-customer="{{item}}"
      >
        <view wx:if="{{item.avatarUrl}}" class="customer-avatar customer-avatar--image">
          <image class="customer-avatar-img" src="{{item.avatarUrl}}" mode="aspectFill" />
        </view>
        <view wx:else class="customer-avatar customer-avatar--initial" style="background-color: {{item.avatarTint}};">
          <text class="avatar-initial-text">{{item.avatarInitial}}</text>
        </view>
        <view class="customer-info">
          <text class="customer-name">{{item.displayName}}<text class="customer-gender">{{item.genderLabel}}</text></text>
          <text class="customer-phone">{{item.phone || '未绑定手机'}}</text>
        </view>
        <view class="customer-right">
          <view class="right-status-col">
            <text wx:if="{{item.todayCheckedIn}}" class="right-tag">今日已打卡</text>
            <text class="right-checkins">累计打卡 <text class="right-checkins-num">{{item.totalCheckins || 0}}</text> 次</text>
          </view>
          <view
            class="edit-hit"
            catchtap="onEditCustomer"
            data-id="{{item._id}}"
            hover-class="edit-hit--active"
            hover-stay-time="80"
          >
            <image class="edit-hit-icon" src="/assets/icons/edit-pencil.svg" mode="aspectFit" />
          </view>
        </view>
      </view>

      <view wx:if="{{loading && customers.length > 0}}" class="list-loading-tip">加载中...</view>
      <view wx:if="{{!hasMore && customers.length > 0}}" class="list-no-more">没有更多了</view>
    </view>

    <view class="stats-bar stats-bar--fixed">
      <text>累计客户 {{totalCustomers}} 人 / 共打卡 {{totalCheckins}} 次</text>
    </view>
  </block>

  <customer-edit-panel
    wx:else
    embed="page"
    customer-id="{{editingId}}"
    bind:back="onEditBack"
    bind:saved="onEditSaved"
    bind:deleted="onEditDeleted"
  />
</view>
