<view class="container">
  <view class="search-bar">
    <input class="search-input" placeholder="搜索昵称或手机号" bindinput="onSearchInput" value="{{searchKeyword}}"/>
  </view>

  <view wx:if="{{customers.length === 0 && !loading}}" class="empty-wrap">
    <text class="empty-tip">暂无客户</text>
    <button class="seed-btn" bindtap="onSeedMockCustomers">插入 4 条模拟客户</button>
  </view>
  <view class="customer-list">
    <view wx:for="{{customers}}" wx:key="_id" class="customer-card" bindtap="onCustomerTap" data-customer="{{item}}">
      <image class="avatar" src="{{item.avatarUrl || '/assets/icons/album-placeholder.png'}}" mode="aspectFill"></image>
      <view class="info">
        <text class="name">{{item.nickName || '匿名用户'}}</text>
        <text class="phone">{{item.phone || '未绑定手机'}}</text>
      </view>
      <view class="stats">
        <text>打卡 {{item.totalCheckins || 0}} 天</text>
        <text>相册余 {{item.equityAlbum || 0}}</text>
      </view>
    </view>
  </view>
  <view wx:if="{{loading}}" class="loading-tip">加载中...</view>
  <view wx:if="{{!hasMore && customers.length > 0}}" class="no-more">没有更多了</view>
</view>