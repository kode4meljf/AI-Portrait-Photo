/* packageProfile/pages/edit-store/edit-store.wxss */
.page-container {
  background: #f5f5f5;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.scroll-area {
  flex: 1;
  overflow-y: auto;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 32rpx;
}
.avatar-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}
.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e8b86d, #c9922a);
  box-shadow: 0 12rpx 32rpx rgba(232,184,109,0.35);
}
.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.95);
  box-sizing: border-box;
}
.avatar-edit-badge {
  position: absolute;
  right: 0;
  top: 0;
  width: 48rpx;
  height: 48rpx;
  background: #e8b86d;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(232,184,109,0.5);
}
.avatar-tip {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999;
}

/* 卡片 */
.section-card {
  background: #fff;
  margin: 0 30rpx 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}
.section-header-no-border {
  border-bottom: none;
}
.info-row {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  min-height: 96rpx;
  box-sizing: border-box;
}
.info-label {
  font-size: 28rpx;
  color: #999;
  width: 160rpx;
  flex-shrink: 0;
}
.info-input {
  flex: 1;
  width: 100%;
  min-width: 0;
  font-size: 30rpx;
  color: #1a1a2e;
  text-align: right;
  line-height: 1.4;
}
.address-section-card {
  padding-bottom: 8rpx;
}
.address-panel {
  margin: 0 16rpx 8rpx;
  min-height: 120rpx;
  border-radius: 16rpx;
  background: #faf7f2;
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  gap: 16rpx;
}
.address-panel:active {
  opacity: 0.75;
}
.address-side-label {
  width: 80rpx;
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
  text-align: left;
}
.info-row-address {
  align-items: center;
}
.info-row-address .info-label {
  padding-top: 0;
}
.address-field {
  flex: 1;
  min-width: 0;
}
.address-picker {
  width: 100%;
  min-height: 88rpx;
  border: 1rpx solid #ececec;
  border-radius: 14rpx;
  padding: 16rpx 18rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}
.address-picker:active {
  opacity: 0.7;
}
.address-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 6rpx;
}
.address-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1a1a2e;
  line-height: 1.35;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.address-sub {
  font-size: 24rpx;
  color: #999;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.address-arrow {
  font-size: 44rpx;
  color: #b8b8b8;
  line-height: 1;
  transform: rotate(180deg);
  transform-origin: center;
  flex-shrink: 0;
}
.info-input-address {
  width: 100%;
  text-align: left;
  align-self: stretch;
  box-sizing: border-box;
}
.info-divider {
  height: 1rpx;
  background: #f5f5f5;
  margin: 0 32rpx;
}

.name-hint-row {
  padding: 0 32rpx 20rpx;
}

.name-hint {
  display: block;
  font-size: 24rpx;
  line-height: 1.4;
  text-align: right;
}

.name-hint--checking {
  color: #999;
}

.name-hint--dup {
  color: #e91e8c;
}

.name-hint--ok {
  color: #5a9a6e;
}

/* 保存按钮 */
.btn-wrap {
  padding: 40rpx 30rpx 0;
}
.save-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #e8b86d, #c9922a);
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(232,184,109,0.4);
  border: none;
  letter-spacing: 2rpx;
}
.save-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}
.save-btn[disabled] {
  background: #d9d9d9;
  color: #ffffff;
  box-shadow: none;
}
.save-btn[disabled]:active {
  transform: none;
  opacity: 1;
}
