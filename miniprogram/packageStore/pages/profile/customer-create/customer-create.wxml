<view class="container">
  <block wx:if="{{!created}}">
    <view class="edit-profile">
      <view class="edit-avatar edit-avatar--initial" style="background-color: {{avatarTint}};">
        <text class="edit-avatar-initial">{{avatarInitial}}</text>
      </view>
      <text class="edit-avatar-hint">手机号必填。客户邀请注册后，可在顾客端生成打卡码</text>
    </view>

    <view class="edit-form">
      <view class="edit-field">
        <text class="edit-label">客户称呼</text>
        <input
          class="edit-input"
          placeholder-class="edit-placeholder"
          placeholder="店长备注，如：张姐、3号桌女士"
          value="{{form.nickName}}"
          bindinput="onInput"
          data-key="nickName"
        />
      </view>
      <view class="edit-field">
        <text class="edit-label">手机号 <text class="edit-required">*</text></text>
        <input
          class="edit-input"
          type="number"
          maxlength="11"
          placeholder-class="edit-placeholder"
          placeholder="请输入 11 位手机号"
          value="{{form.phone}}"
          bindinput="onInput"
          data-key="phone"
        />
      </view>
      <view class="edit-field edit-field--textarea">
        <text class="edit-label">备注</text>
        <textarea
          class="edit-textarea"
          placeholder-class="edit-placeholder"
          placeholder="选填，可记录客户偏好、拍摄要求等"
          value="{{form.remark}}"
          bindinput="onInput"
          data-key="remark"
          maxlength="200"
          auto-height
          show-confirm-bar="{{false}}"
        />
      </view>
    </view>

    <view class="save-bar">
      <view
        class="save-btn {{!canSave ? 'save-btn--disabled' : ''}} {{submitting ? 'save-btn--busy' : ''}}"
        hover-class="{{!canSave || submitting ? '' : 'save-btn-hover'}}"
        hover-stay-time="80"
        bindtap="onSubmit"
      >{{submitting ? '保存中…' : '保存'}}</view>
    </view>
  </block>

  <block wx:else>
    <view class="success-panel">
      <view class="success-icon-wrap">
        <text class="success-icon">✓</text>
      </view>
      <text class="success-title">客户已添加</text>
      <text class="success-sub">累计打卡 0 次。请邀请客户完成注册后，在顾客端出示打卡码到店</text>

      <view class="success-card">
        <view class="edit-avatar edit-avatar--initial success-avatar" style="background-color: {{avatarTint}};">
          <text class="edit-avatar-initial">{{avatarInitial}}</text>
        </view>
        <text class="success-name">{{form.nickName}}</text>
        <text wx:if="{{form.phone}}" class="success-phone">{{form.phone}}</text>
      </view>
    </view>

    <view class="save-bar save-bar--dual">
      <view
        class="outline-btn"
        hover-class="outline-btn-hover"
        hover-stay-time="80"
        bindtap="onAddAnother"
      >继续添加</view>
      <view
        class="save-btn"
        hover-class="save-btn-hover"
        hover-stay-time="80"
        bindtap="onDone"
      >完成</view>
    </view>
  </block>
</view>
