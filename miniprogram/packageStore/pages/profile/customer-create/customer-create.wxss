/* 与 customer-edit / 首页客户编辑弹层保持一致 · 线框极简 */
@import "../../../../styles/customer-gender.shared.wxss";

.container {
  min-height: 100vh;
  background: #fff;
  padding: 0 0 calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.edit-profile {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 48rpx 28rpx;
  box-sizing: border-box;
}

.edit-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  overflow: hidden;
  box-sizing: border-box;
  flex-shrink: 0;
}

.edit-avatar--initial {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #d4d4d8;
  background: #fafafa;
}

.edit-avatar-initial {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1;
}

.edit-required {
  color: #e85d75;
}

.edit-avatar-hint {
  width: 100%;
  margin-top: 12rpx;
  font-size: 20rpx;
  color: #a1a1aa;
  text-align: center;
  line-height: 1.4;
}

.edit-form {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 24rpx 48rpx 0;
}

.edit-field {
  width: 100%;
  padding: 24rpx;
  border: 1rpx solid #e4e4e7;
  border-radius: 16rpx;
  background: transparent;
  box-sizing: border-box;
}

.edit-label {
  display: block;
  width: 100%;
  font-size: 26rpx;
  font-weight: 400;
  color: #71717a;
  margin: 0 0 12rpx;
  padding: 0;
  line-height: 36rpx;
  box-sizing: border-box;
}

.edit-input {
  display: block;
  width: 100%;
  height: 44rpx;
  min-height: 44rpx;
  margin: 0;
  padding: 0;
  font-size: 30rpx;
  color: #18181b;
  line-height: 44rpx;
  box-sizing: border-box;
}

.edit-placeholder {
  color: #d4d4d8;
  font-size: 30rpx;
  line-height: 44rpx;
}

.edit-field--readonly {
  background: #fafafa;
}

.edit-readonly {
  display: block;
  font-size: 30rpx;
  color: #52525b;
  line-height: 44rpx;
}

.edit-field--textarea {
  padding-bottom: 20rpx;
}

.edit-textarea {
  display: block;
  width: 100%;
  min-height: 132rpx;
  margin: 0;
  padding: 0;
  font-size: 30rpx;
  color: #18181b;
  line-height: 1.5;
  box-sizing: border-box;
}

.save-bar {
  width: 100%;
  box-sizing: border-box;
  margin-top: 32rpx;
  padding: 0 48rpx;
}

.save-bar--dual {
  display: flex;
  gap: 20rpx;
}

.save-bar--dual .save-btn,
.save-bar--dual .outline-btn {
  flex: 1;
}

.save-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  margin: 0;
  height: 88rpx;
  min-height: 88rpx;
  padding: 0;
  line-height: 1;
  border-radius: 44rpx;
  background: #18181b;
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  box-sizing: border-box;
}

.save-btn-hover {
  background: #27272a;
}

.save-btn--disabled {
  background: #e5e7eb;
  color: #9ca3af;
  pointer-events: none;
}

.save-btn--disabled.save-btn-hover {
  background: #e5e7eb;
}

.save-btn--busy {
  opacity: 0.72;
}

.outline-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;
  border: 1rpx solid #e4e4e7;
  background: #fff;
  color: #18181b;
  font-size: 30rpx;
  font-weight: 500;
  box-sizing: border-box;
}

.outline-btn-hover {
  background: #f4f4f5;
}

/* 创建成功 */
.success-panel {
  padding: 48rpx 48rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.success-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #ecfdf5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.success-icon {
  font-size: 40rpx;
  font-weight: 700;
  color: #10b981;
  line-height: 1;
}

.success-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #18181b;
  line-height: 1.3;
}

.success-sub {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #71717a;
  text-align: center;
  line-height: 1.5;
  padding: 0 16rpx;
}

.success-card {
  width: 100%;
  margin-top: 40rpx;
  padding: 32rpx 28rpx;
  border: 1rpx solid #e4e4e7;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.success-avatar {
  margin-bottom: 16rpx;
}

.success-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #18181b;
}

.success-phone {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #71717a;
}
