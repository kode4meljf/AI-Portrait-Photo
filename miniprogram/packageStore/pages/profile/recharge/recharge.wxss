.container {
  background: #f5f5f5;
  min-height: 100vh;
  padding: 30rpx;
}

.balance-info {
  background: linear-gradient(135deg, #ff69b4, #ff8c69);
  border-radius: 32rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 40rpx;
  color: #fff;
}

.balance-info .label {
  font-size: 28rpx;
  opacity: 0.9;
  display: block;
}

.balance-info .value {
  font-size: 72rpx;
  font-weight: 700;
  display: block;
  margin-top: 10rpx;
}

.package-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  position: relative;
  transition: all 0.2s;
  border: 2rpx solid #f0f0f0;
}

.package-card.selected {
  border-color: #ff69b4;
  background: #fff0f5;
}

.package-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.name {
  font-size: 36rpx;
  font-weight: 600;
}

.tag {
  background: #ff9800;
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
}

.package-detail {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 20rpx;
}

.times {
  font-size: 28rpx;
  color: #666;
}

.price {
  font-size: 44rpx;
  font-weight: 700;
  color: #ff69b4;
}

.original-price {
  font-size: 26rpx;
  color: #ccc;
  text-decoration: line-through;
}

.summary {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
}

.summary text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.pay-btn {
  background: #ff69b4;
  color: #fff;
  border-radius: 60rpx;
  width: 280rpx;
  font-size: 28rpx;
  margin: 0;
}