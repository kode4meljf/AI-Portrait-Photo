.page {
  min-height: 100vh;
  background: #f3f4f6;
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
}

.balance-mini {
  background: linear-gradient(145deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  color: #fff;
  margin-bottom: 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 8rpx 24rpx rgba(26, 26, 46, 0.18);
}

.balance-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.balance-main {
  flex: 1;
  min-width: 0;
}

.price-entry {
  flex-shrink: 0;
  margin-top: 2rpx;
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #e8b86d;
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(232, 184, 109, 0.35);
  line-height: 1.2;
}

.price-entry:active {
  background: rgba(255, 255, 255, 0.16);
}

.balance-lbl {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.65);
}

.balance-num {
  display: block;
  font-weight: 800;
  margin-top: 4rpx;
  line-height: 1.15;
  color: #e8b86d;
}

.balance-num--lg {
  font-size: 56rpx;
}

.balance-num--md {
  font-size: 46rpx;
}

.balance-num--sm {
  font-size: 38rpx;
}

.load-error {
  margin-bottom: 24rpx;
  padding: 24rpx 28rpx;
  border-radius: 16rpx;
  background: #fff7ed;
  color: #b45309;
  font-size: 26rpx;
  line-height: 1.5;
}

.pkg-group {
  margin-bottom: 28rpx;
}

.group-hd {
  font-size: 22rpx;
  color: #6b7280;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
  line-height: 1.45;
}

.group-hd--annual {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding-left: 0;
  margin-top: 8rpx;
}

.group-hd-bar {
  width: 6rpx;
  height: 24rpx;
  border-radius: 3rpx;
  background: linear-gradient(180deg, #e8b86d, #c9922a);
  flex-shrink: 0;
}

.group-hd-text {
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.45;
}

.pkg {
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #e8eaef;
  position: relative;
}

.pkg.featured {
  border-color: rgba(201, 146, 42, 0.72);
  box-shadow: 0 4rpx 16rpx rgba(201, 146, 42, 0.06);
}

.pkg.on {
  border-color: #c9922a;
  background: #fffbf5;
  box-shadow: 0 4rpx 16rpx rgba(201, 146, 42, 0.12);
}

.pkg.featured.on {
  border-color: #c9922a;
  background: #fffbf5;
}

.pkg-badge {
  position: absolute;
  top: 0;
  right: 24rpx;
  font-size: 18rpx;
  padding: 4rpx 16rpx;
  border-radius: 0 0 12rpx 12rpx;
  font-weight: 600;
  color: #fff;
}

.pkg-badge.hot {
  background: linear-gradient(135deg, #e8b86d, #c9922a);
}

.pkg-badge.crown {
  background: linear-gradient(135deg, #16213e, #0f3460);
  color: #e8b86d;
}

.pkg-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.pkg-main {
  flex: 1;
  min-width: 0;
}

.pkg-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  line-height: 1.3;
}

.pkg-slogan {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 6rpx;
  line-height: 1.4;
}

.pkg-right {
  flex-shrink: 0;
  text-align: right;
}

.pkg-pts {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #c9922a;
  line-height: 1.1;
}

.pkg-pts-unit {
  font-size: 22rpx;
  font-weight: 500;
  color: #9ca3af;
}

.pkg-bonus {
  display: block;
  font-size: 20rpx;
  color: #b8860b;
  font-weight: 600;
  margin-top: 4rpx;
}

.pkg-eq {
  display: block;
  font-size: 20rpx;
  color: #9ca3af;
  margin-top: 16rpx;
  line-height: 1.4;
}

.legend {
  margin: 8rpx 4rpx 0;
  padding: 20rpx 24rpx;
  background: #fff8e6;
  border-radius: 16rpx;
  font-size: 20rpx;
  color: #886622;
  line-height: 1.55;
  border: 2rpx solid rgba(232, 184, 109, 0.25);
}

.footer-spacer {
  height: calc(160rpx + env(safe-area-inset-bottom));
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-top: 1rpx solid #eee;
  padding: 20rpx 28rpx calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.footer-left {
  flex: 1;
  min-width: 0;
}

.footer-pay-line {
  line-height: 1.2;
}

.footer-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
}

.footer-price {
  font-size: 44rpx;
  font-weight: 800;
  color: #1a1a2e;
}

.footer-sub {
  display: block;
  font-size: 20rpx;
  color: #9ca3af;
  margin-top: 6rpx;
  line-height: 1.35;
}

.footer-btn {
  flex-shrink: 0;
  margin: 0;
  min-width: 220rpx;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 36rpx;
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  color: #e8b86d;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 40rpx;
  border: none;
  box-shadow: 0 4rpx 14rpx rgba(26, 26, 46, 0.2);
}

.footer-btn[disabled] {
  background: #e5e7eb;
  color: #9ca3af;
  box-shadow: none;
}

.footer-btn::after {
  border: none;
}

.price-mask {
  position: fixed;
  inset: 0;
  z-index: 200;
  background: rgba(0, 0, 0, 0.52);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 40rpx;
  box-sizing: border-box;
}

.price-modal {
  width: 100%;
  max-width: 620rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 36rpx 32rpx 28rpx;
  box-shadow: 0 24rpx 64rpx rgba(0, 0, 0, 0.2);
}

.price-modal-hd {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
  text-align: center;
  margin-bottom: 12rpx;
}

.price-modal-note {
  font-size: 22rpx;
  color: #9ca3af;
  text-align: center;
  line-height: 1.5;
  margin-bottom: 28rpx;
}

.price-list {
  border-radius: 20rpx;
  overflow: hidden;
  border: 2rpx solid #f0f0f0;
  margin-bottom: 28rpx;
}

.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 2rpx solid #f5f5f5;
  background: #fff;
}

.price-row:last-child {
  border-bottom: none;
}

.price-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
}

.price-pts {
  font-size: 30rpx;
  font-weight: 700;
  color: #c9922a;
}

.price-modal-btn {
  height: 84rpx;
  border-radius: 42rpx;
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  color: #e8b86d;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.price-modal-btn:active {
  opacity: 0.9;
}
