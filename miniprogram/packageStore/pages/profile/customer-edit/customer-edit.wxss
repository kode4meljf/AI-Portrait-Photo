/* 方案 2 · 线框极简 */
.container {
  min-height: 100vh;
  background: #fff;
  padding: 0 0 calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.edit-profile {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 48rpx 28rpx;
  box-sizing: border-box;
}

.edit-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  overflow: hidden;
  box-sizing: border-box;
  flex-shrink: 0;
}

.edit-avatar--image {
  background: #f4f4f5;
  border: 2rpx solid #e4e4e7;
}

.edit-avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}

.edit-avatar--initial {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #d4d4d8;
  background: #fafafa;
}

.edit-avatar-initial {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1;
}

.edit-avatar-hint {
  width: 100%;
  margin-top: 12rpx;
  font-size: 20rpx;
  color: #a1a1aa;
  text-align: center;
  line-height: 1.4;
}

.edit-form {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 24rpx 48rpx 0;
}

.edit-field {
  width: 100%;
  padding: 24rpx;
  border: 1rpx solid #e4e4e7;
  border-radius: 16rpx;
  background: transparent;
  box-sizing: border-box;
}

.edit-label {
  display: block;
  width: 100%;
  font-size: 26rpx;
  font-weight: 400;
  color: #71717a;
  margin: 0 0 12rpx;
  padding: 0;
  line-height: 36rpx;
  box-sizing: border-box;
}

.edit-required {
  color: #e85d75;
}

.edit-field-hint {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9a8b7a;
  line-height: 1.45;
}

.edit-input {
  display: block;
  width: 100%;
  height: 44rpx;
  min-height: 44rpx;
  margin: 0;
  padding: 0;
  font-size: 30rpx;
  color: #18181b;
  line-height: 44rpx;
  box-sizing: border-box;
}

.edit-placeholder {
  color: #d4d4d8;
  font-size: 30rpx;
  line-height: 44rpx;
}

.edit-field--readonly {
  background: #fafafa;
}

.edit-readonly {
  display: block;
  font-size: 30rpx;
  color: #3f3f46;
  line-height: 44rpx;
}

.edit-field--textarea {
  padding-bottom: 20rpx;
}

.edit-textarea {
  display: block;
  width: 100%;
  min-height: 132rpx;
  margin: 0;
  padding: 0;
  font-size: 30rpx;
  color: #18181b;
  line-height: 1.5;
  box-sizing: border-box;
}

.save-bar {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  box-sizing: border-box;
  margin-top: 32rpx;
  padding: 0 48rpx calc(24rpx + env(safe-area-inset-bottom));
}

.delete-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  border: 2rpx solid #fecaca;
  background: #fff;
  color: #e91e8c;
  font-size: 30rpx;
  font-weight: 500;
  box-sizing: border-box;
}

.delete-btn-hover {
  background: #fff5f7;
}

.delete-btn--disabled {
  opacity: 0.5;
  pointer-events: none;
}

.save-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  margin: 0;
  height: 88rpx;
  min-height: 88rpx;
  padding: 0;
  line-height: 1;
  border-radius: 44rpx;
  background: #18181b;
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  box-sizing: border-box;
}

.save-btn-hover {
  background: #27272a;
}

.save-btn--disabled {
  background: #e5e7eb;
  color: #9ca3af;
  pointer-events: none;
}

.save-btn--disabled.save-btn-hover {
  background: #e5e7eb;
}
