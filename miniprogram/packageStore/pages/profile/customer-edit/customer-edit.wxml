<view class="container">
  <view class="edit-profile">
    <view wx:if="{{avatarUrl}}" class="edit-avatar edit-avatar--image">
      <image class="edit-avatar-img" src="{{avatarUrl}}" mode="aspectFill" />
    </view>
    <view wx:else class="edit-avatar edit-avatar--initial" style="background-color: {{avatarTint}};">
      <text class="edit-avatar-initial">{{avatarInitial}}</text>
    </view>
    <text class="edit-avatar-hint">头像来自客户码，客户打卡后自动更新</text>
  </view>

  <view class="edit-form">
    <view class="edit-field edit-field--readonly">
      <text class="edit-label">微信昵称</text>
      <text class="edit-readonly">{{wxNickName || '暂未同步，客户打卡后将自动更新'}}</text>
    </view>

    <view class="edit-field {{isFollowUp ? 'edit-field--readonly' : ''}}">
      <text class="edit-label">客户称呼</text>
      <text wx:if="{{isFollowUp}}" class="edit-readonly">{{form.nickName || '—'}}</text>
      <input
        wx:else
        class="edit-input"
        placeholder-class="edit-placeholder"
        placeholder="店长备注，方便识别客户"
        value="{{form.nickName}}"
        bindinput="onInput"
        data-key="nickName"
      />
    </view>

    <view
      wx:if="{{isFollowUp}}"
      class="edit-field edit-field--readonly edit-field--dial"
      bindtap="onDialPhone"
      hover-class="edit-field--dial-press"
      hover-stay-time="80"
    >
      <text class="edit-label">手机号</text>
      <text class="edit-readonly edit-readonly--phone">{{form.phone || '未绑定手机'}}</text>
      <text wx:if="{{form.phone}}" class="edit-dial-hint">点击拨打</text>
    </view>
    <view wx:else class="edit-field">
      <text class="edit-label">手机号 <text class="edit-required">*</text></text>
      <input
        wx:if="{{!phoneLocked}}"
        class="edit-input"
        type="number"
        maxlength="11"
        placeholder-class="edit-placeholder"
        placeholder="请输入 11 位手机号"
        value="{{form.phone}}"
        bindinput="onInput"
        data-key="phone"
      />
      <text wx:else class="edit-readonly">{{form.phone}}</text>
      <text wx:if="{{phoneLocked}}" class="edit-field-hint">已绑定微信，手机号仅可由客户在顾客端更换</text>
    </view>

    <view wx:if="{{!isFollowUp}}" class="edit-field edit-field--gender">
      <view class="gender-row">
        <text class="edit-label">性别</text>
        <view class="gender-row-ctrl">
          <view class="gender-filter">
            <view
              class="gender-filter-btn {{form.gender === 'male' ? 'active' : ''}}"
              bindtap="onGenderTap"
              data-value="male"
            >男</view>
            <view
              class="gender-filter-btn {{form.gender === 'female' ? 'active' : ''}}"
              bindtap="onGenderTap"
              data-value="female"
            >女</view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{!isFollowUp}}" class="edit-field edit-field--textarea">
      <text class="edit-label">住址</text>
      <textarea
        class="edit-textarea"
        placeholder-class="edit-placeholder"
        placeholder="选填，仅门店可见"
        value="{{form.address}}"
        bindinput="onInput"
        data-key="address"
        maxlength="200"
        auto-height
        show-confirm-bar="{{false}}"
      />
      <text class="edit-field-hint--store">仅门店端可见，顾客不可见</text>
    </view>

    <view class="edit-field edit-field--textarea">
      <text class="edit-label">备注</text>
      <textarea
        class="edit-textarea"
        placeholder-class="edit-placeholder"
        placeholder="选填，可记录客户偏好、拍摄要求等"
        value="{{form.remark}}"
        bindinput="onRemarkInput"
        maxlength="200"
        auto-height
        show-confirm-bar="{{false}}"
      />
    </view>
  </view>

  <view class="save-bar {{isFollowUp ? 'save-bar--single' : ''}}">
    <view
      wx:if="{{!isFollowUp && canDelete}}"
      class="delete-btn {{deleting || saving ? 'delete-btn--disabled' : ''}}"
      hover-class="delete-btn-hover"
      hover-stay-time="80"
      bindtap="onDelete"
    >删除档案</view>
    <view
      class="save-btn {{saving || !canSave ? 'save-btn--disabled' : ''}}"
      hover-class="save-btn-hover"
      hover-stay-time="80"
      bindtap="onSave"
    >保存</view>
  </view>
</view>
