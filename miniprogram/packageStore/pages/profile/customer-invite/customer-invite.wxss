.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.hint {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #888;
  line-height: 1.6;
}

.btn {
  margin-top: 28rpx;
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.btn.primary {
  background: #2563eb;
  color: #fff;
}

.btn.outline {
  background: #f0f4ff;
  color: #2563eb;
}

.label {
  font-size: 24rpx;
  color: #888;
}

.path {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #333;
  word-break: break-all;
  line-height: 1.5;
}

.expire {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #f59e0b;
}

.tip {
  margin-top: 20rpx;
  font-size: 22rpx;
  color: #aaa;
  line-height: 1.5;
}
