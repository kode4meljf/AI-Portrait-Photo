.invite-page {
  min-height: 100vh;
  background: #f3f4f6;
}

.scroll-area {
  height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 32rpx 0;
}

/* 与员工管理 invite-card 一致 */
.invite-card {
  background: linear-gradient(145deg, #1a1a2e 0%, #16213e 55%, #0f3460 100%);
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(26, 26, 46, 0.18);
}

.invite-head {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  margin-bottom: 28rpx;
}

.invite-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #fff7ed 0%, #ffe4c7 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.5);
}

.invite-icon {
  width: 48rpx;
  height: 48rpx;
}

.invite-text {
  flex: 1;
  min-width: 0;
}

.invite-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10rpx;
}

.invite-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.55);
  line-height: 1.5;
}

.invite-action {
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #e8b86d, #c9922a);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.invite-action--disabled {
  opacity: 0.65;
}

.invite-action-active {
  opacity: 0.9;
  transform: scale(0.98);
}

.invite-token-box {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.1);
}

.invite-qr-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.invite-qr-img {
  width: 320rpx;
  height: 320rpx;
  display: block;
  background: #1a1a2e;
  border-radius: 12rpx;
}

.invite-qr-img--wxacode {
  background: #fff;
  border-radius: 50%;
  padding: 8rpx;
  box-sizing: border-box;
}

.invite-qr-fail {
  margin-bottom: 20rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  background: rgba(239, 68, 68, 0.12);
  font-size: 22rpx;
  color: #fca5a5;
  line-height: 1.45;
  text-align: center;
}

.link-block {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.invite-qr-hint {
  margin-top: 16rpx;
  padding: 0 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.72);
  text-align: center;
  line-height: 1.45;
}

.token-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
  margin-bottom: 12rpx;
}

.path-copy {
  flex-shrink: 0;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(232, 184, 109, 0.2);
  font-size: 24rpx;
  color: #e8b86d;
  font-weight: 500;
  text-align: center;
}

.path-copy {
  display: block;
  width: 100%;
  box-sizing: border-box;
  margin-top: 16rpx;
}

.token-copy-active {
  opacity: 0.75;
}

.expire-line {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: rgba(232, 184, 109, 0.85);
}

.path-row {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.path-value {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
  word-break: break-all;
  line-height: 1.45;
}

.hint-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(26, 26, 46, 0.06);
}

.hint-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.hint-line {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.page-footer {
  height: 48rpx;
}
