/* 遮罩层 */
.picker-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 999;
  pointer-events: none;
  transition: background 0.3s ease;
}

.picker-overlay.active {
  background: rgba(0, 0, 0, 0.5);
  pointer-events: auto;
}

/* 滑出面板 */
.picker-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 72vh;
  max-height: 72vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.12);
  z-index: 1000;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.picker-sheet.active {
  transform: translateY(0);
}

/* 顶部栏 */
.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 24rpx;
  flex-shrink: 0;
}

.picker-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.close-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #999;
  line-height: 1;
}

.close-btn:active {
  opacity: 0.7;
}

.header-line {
  height: 1rpx;
  background: #f0f0f0;
  flex-shrink: 0;
}

/* 搜索栏 */
.search-bar-wrap {
  padding: 20rpx 32rpx 16rpx;
  flex-shrink: 0;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 44rpx;
  padding: 16rpx 24rpx;
  gap: 12rpx;
}

.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1;
}

.clear-icon {
  font-size: 32rpx;
  color: #ccc;
  padding: 4rpx;
  flex-shrink: 0;
}

/* 客户列表 */
.customer-scroll {
  flex: 1;
  height: 0;
  padding: 0 24rpx;
  -webkit-overflow-scrolling: touch;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

.customer-item {
  display: flex;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  gap: 14rpx;
}

.customer-item:last-child {
  border-bottom: none;
}

.customer-item.selected {
  background: rgba(59, 130, 246, 0.04);
  border-radius: 16rpx;
  margin: 0;
  padding: 22rpx 0;
  border-bottom: none;
}

.customer-avatar {
  width: 74rpx;
  height: 74rpx;
  border-radius: 50%;
  background: #eee;
  flex-shrink: 0;
}

.customer-info {
  flex: 1;
  min-width: 0;
}

.customer-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 6rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.customer-phone {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.customer-right {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 6rpx;
  flex: 0 0 auto;
  min-width: 0;
  max-width: 54%;
  margin-left: auto;
}

.right-status-col {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-end;
  min-width: 0;
  max-width: 100%;
  flex: 1;
}

.right-status-col.has-checkin {
  gap: 4rpx;
}

.right-status-col.only-checkins {
  min-height: 52rpx;
}

.right-checkins {
  color: #b5b5b5;
  font-size: 19rpx;
  white-space: normal;
  text-align: right;
  word-break: break-word;
  line-height: 1.2;
}

.right-checkins-num {
  font-size: 30rpx;
  color: #6f6f6f;
  font-weight: 600;
}

.right-tag {
  font-size: 19rpx;
  color: #ef4444;
  white-space: nowrap;
  max-width: 100%;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.2;
}

.arrow-icon {
  font-size: 32rpx;
  color: #ccc;
  font-weight: 300;
  flex-shrink: 0;
  margin-left: 2rpx;
}

.loading-tip,
.no-more {
  text-align: center;
  padding: 24rpx;
  color: #999;
  font-size: 24rpx;
}

/* 底部统计栏 */
.stats-bar {
  flex-shrink: 0;
  background: #f7f7f7;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #f0f0f0;
  text-align: center;
}

.stats-bar text {
  font-size: 24rpx;
  color: #999;
}
